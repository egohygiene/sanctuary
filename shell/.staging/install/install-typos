#!/usr/bin/env bash
set -euo pipefail

# ============================================
# install-typos
# Install typos (source code spell checker) from GitHub release archive.
# Reference: https://github.com/crate-ci/typos
# Supports: latest or specific version
# ============================================

# -----------------------------
# Config
# -----------------------------
OWNER="crate-ci"
REPO="typos"
INSTALL_DIR="/usr/local/bin"

# Detect platform
OS="$(uname -s)"
ARCH="$(uname -m)"

case "$OS" in
  Linux)  PLATFORM="unknown-linux-musl" ;;
  Darwin) PLATFORM="apple-darwin" ;;
  *) echo "❌ Unsupported OS: $OS"; exit 1 ;;
esac

case "$ARCH" in
  x86_64)        ARCH_LABEL="x86_64" ;;
  arm64|aarch64) ARCH_LABEL="aarch64" ;;
  *) echo "❌ Unsupported architecture: $ARCH"; exit 1 ;;
esac

# -----------------------------
# Functions
# -----------------------------

get_latest_release() {
  curl -s "https://api.github.com/repos/$OWNER/$REPO/releases/latest" \
    | grep '"tag_name":' \
    | sed -E 's/.*"v([^"]+)".*/\1/'
}

download_and_install() {
  local version="$1"

  FILENAME="typos-v${version}-${ARCH_LABEL}-${PLATFORM}.tar.gz"
  DOWNLOAD_URL="https://github.com/${OWNER}/${REPO}/releases/download/v${version}/${FILENAME}"

  echo "📦 Downloading typos v${version} from ${DOWNLOAD_URL}..."
  curl -fsSL "$DOWNLOAD_URL" -o "/tmp/$FILENAME"

  # Verify checksum if sha256sums.txt is available
  CHECKSUMS_URL="https://github.com/${OWNER}/${REPO}/releases/download/v${version}/sha256sums.txt"
  CHECKSUMS_FILE="/tmp/typos_sha256sums.txt"
  if curl -fsSL "$CHECKSUMS_URL" -o "$CHECKSUMS_FILE" 2>/dev/null; then
    EXPECTED=$(grep "${FILENAME}$" "$CHECKSUMS_FILE" | awk '{print $1}' || true)
    if [[ -n "$EXPECTED" ]]; then
      echo "🔐 Verifying checksum..."
      if command -v sha256sum >/dev/null 2>&1; then
        echo "${EXPECTED}  /tmp/${FILENAME}" | sha256sum --check --quiet
      elif command -v shasum >/dev/null 2>&1; then
        echo "${EXPECTED}  /tmp/${FILENAME}" | shasum -a 256 --check --quiet
      else
        echo "⚠️  No sha256sum or shasum found; skipping checksum verification"
      fi
      echo "✅ Checksum verified"
    fi
    rm -f "$CHECKSUMS_FILE"
  fi

  echo "📂 Extracting and installing to $INSTALL_DIR..."
  tar -xzf "/tmp/$FILENAME" -C /tmp "./typos"
  sudo mv "/tmp/typos" "$INSTALL_DIR/typos"
  sudo chmod +x "$INSTALL_DIR/typos"
  rm -f "/tmp/$FILENAME"

  echo "✅ Installed typos v${version} at $(command -v typos)"
  typos --version
}

# -----------------------------
# Main
# -----------------------------
usage() {
  echo "Usage: $0 [--version x.y.z] [--help]"
  exit 1
}

VERSION=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --version)
      VERSION="$2"
      shift 2
      ;;
    --help|-h)
      usage
      ;;
    *)
      echo "❌ Unknown argument: $1"
      usage
      ;;
  esac
done

if [[ -z "$VERSION" ]]; then
  echo "🔍 Fetching latest typos release..."
  VERSION=$(get_latest_release)
fi

download_and_install "$VERSION"
