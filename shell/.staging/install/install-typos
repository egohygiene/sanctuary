#!/usr/bin/env bash
set -Eeuo pipefail

: "${EGOHYGIENE_SHELL_ROOT:=$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." >/dev/null 2>&1 && pwd)}"

# shellcheck disable=SC1091
source "${EGOHYGIENE_SHELL_ROOT}/lib/install/runtime.sh"

export INSTALL_TOOL_NAME="typos"
export INSTALL_OWNER="crate-ci"
export INSTALL_REPO="typos"
export INSTALL_ASSET_TEMPLATE="typos-v{{version}}-{{arch}}-{{platform}}.tar.gz"
export INSTALL_PLATFORM_LINUX="unknown-linux-musl"
export INSTALL_PLATFORM_DARWIN="apple-darwin"
export INSTALL_ARCH_X86_64="x86_64"
export INSTALL_ARCH_ARM64="aarch64"
export INSTALL_CHECKSUM_ASSET="sha256sums.txt"
export INSTALL_ARCHIVE_FORMAT="tar.gz"
export INSTALL_ARCHIVE_MEMBER_TEMPLATE="typos"
export INSTALL_BIN_NAME="typos"
# shellcheck disable=SC2034
declare -a INSTALL_VERIFY_ARGS=(--version)

install::github::main "$@"
