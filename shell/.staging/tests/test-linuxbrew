#!/usr/bin/env bash
# test-linuxbrew
# Verifies that Homebrew (Linuxbrew) is installed and functional.

set -euo pipefail

HOMEBREW_PREFIX="${HOMEBREW_PREFIX:-/home/linuxbrew/.linuxbrew}"
BREW_BIN="${HOMEBREW_PREFIX}/bin/brew"
BREW_USER="${BREW_USER:-linuxbrew}"

check_brew_binary() {
    if [[ ! -x "${BREW_BIN}" ]]; then
        echo "❌ brew not found at ${BREW_BIN}" >&2
        return 1
    fi
}

check_brew_version() {
    su -s /bin/bash "${BREW_USER}" -c "${BREW_BIN} --version" >/dev/null 2>&1 || {
        echo "❌ 'brew --version' failed" >&2
        return 1
    }
}

check_brew_config() {
    su -s /bin/bash "${BREW_USER}" -c "${BREW_BIN} config" >/dev/null 2>&1 || {
        echo "❌ 'brew config' failed" >&2
        return 1
    }
}

main() {
    echo "🔍 Testing Homebrew (Linuxbrew)..."
    check_brew_binary
    check_brew_version
    check_brew_config
    echo "✅ Homebrew check passed"
}

main "$@"
