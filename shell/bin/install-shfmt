#!/usr/bin/env bash
set -Eeuo pipefail

: "${EGOHYGIENE_SHELL_ROOT:=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." >/dev/null 2>&1 && pwd)}"

# shellcheck disable=SC1091
source "${EGOHYGIENE_SHELL_ROOT}/lib/install/runtime.sh"

export INSTALL_TOOL_NAME="shfmt"
export INSTALL_OWNER="mvdan"
export INSTALL_REPO="sh"
export INSTALL_ASSET_TEMPLATE="shfmt_v{{version}}_{{platform}}_{{arch}}"
export INSTALL_PLATFORM_LINUX="linux"
export INSTALL_PLATFORM_DARWIN="darwin"
export INSTALL_ARCH_X86_64="amd64"
export INSTALL_ARCH_ARM64="arm64"
export INSTALL_CHECKSUM_ASSET="sha256sums.txt"
export INSTALL_ARCHIVE_FORMAT="raw"
export INSTALL_BIN_NAME="shfmt"
# shellcheck disable=SC2034
declare -a INSTALL_VERIFY_ARGS=(--version)

install::github::main "$@"
