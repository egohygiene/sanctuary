#!/usr/bin/env bash
# shellcheck shell=bash

set -euo pipefail

readonly PROGRAM_NAME="remove-pdf-password"
readonly VERSION="2.0.0"

INPUT_FILE=""
OUTPUT_FILE=""
SUPPLIED_PASSWORD_FILE=""
PASSWORD_FROM_STDIN=false
ALLOW_UNENCRYPTED=false
LINEARIZE=false
FORCE=false
DRY_RUN=false
QUIET=false
VERBOSE=false
INPUT_IS_ENCRYPTED=false
PASSWORD_IS_REQUIRED=false
TEMPORARY_PASSWORD_FILE=""
TEMPORARY_OUTPUT_FILE=""
PASSWORD_FILE=""

declare -a POSITIONAL_ARGUMENTS=()
declare -a QPDF_COMMAND=()

# @description Print usage, security behavior, examples, dependencies, and exits.
# @stdout Complete help text.
print_help() {
    printf '%s\n' "Usage: ${PROGRAM_NAME} [OPTIONS] INPUT.pdf [OUTPUT.pdf]

Create an unencrypted copy of a PDF using qpdf's native structural
transformation. A hidden password prompt is used only when the input requires a
nonempty password.

Options:
  --output FILE             Explicit output path; alternative to positional
                            OUTPUT.pdf.
  --password-file FILE      Read the first password line from FILE.
  --password-stdin          Read one password line from standard input.
  --allow-unencrypted       Permit rewriting an input that is already
                            unencrypted.
  --linearize               Web-optimize the resulting PDF.
  --force                   Replace an existing output, but never the input.
  --dry-run                 Validate and print the qpdf operation without
                            reading a password or writing output.
  --quiet                   Suppress normal progress messages.
  --verbose                 Print qpdf commands and diagnostics.
  --help                    Show this help and exit.
  --version                 Show version information and exit.

Examples:
  ${PROGRAM_NAME} protected.pdf
  ${PROGRAM_NAME} protected.pdf unlocked.pdf
  ${PROGRAM_NAME} --output unlocked.pdf protected.pdf
  ${PROGRAM_NAME} --password-file ~/.secrets/pdf-password protected.pdf
  printf '%s\\n' \"\${PDF_PASSWORD}\" | ${PROGRAM_NAME} --password-stdin protected.pdf
  ${PROGRAM_NAME} --linearize --force protected.pdf unlocked.pdf

Output naming:
  The default output is <input-stem>-unlocked.pdf beside the input. Output is
  written to a same-directory partial file and atomically published only after
  qpdf succeeds and verification confirms that encryption was removed.

Security and fidelity:
  Passwords are never accepted as command-line values. Interactive input is
  hidden; stdin passwords are not echoed by this program; temporary password
  files are created with user-only permissions and removed on exit. qpdf is
  used instead of Ghostscript because it decrypts PDF structure without
  rendering pages through pdfwrite. Stream and object-stream data are preserved
  where possible. Digital signatures may no longer validate after any rewrite.

  Use this command only for documents you are authorized to decrypt. It does
  not guess, recover, or bypass unknown passwords.

Dependencies:
  Bash 3.2+, qpdf 8.4+ for Unicode password handling, and standard mktemp,
  mv, rm, tr, and pwd utilities.

Exit codes:
  0    Success.
  2    Invalid command-line usage.
  3    Invalid input or output path.
  4    Input is not encrypted or is not a valid readable PDF.
  5    Password is missing or incorrect.
  6    qpdf decryption or output validation failed.
  7    Completed output could not be published.
  127  qpdf or another required command is unavailable.
"
}

# @description Print an informational message unless quiet mode is enabled.
# @arg $1 string Message.
log_info() {
    [[ "$QUIET" == true ]] || printf '%s: %s\n' "$PROGRAM_NAME" "$1"
}

# @description Print an error message to standard error.
# @arg $1 string Message.
log_error() {
    printf '%s: error: %s\n' "$PROGRAM_NAME" "$1" >&2
}

# @description Exit with a command-line usage error.
# @arg $1 string Explanation.
# @exitcode 2 Always.
usage_error() {
    log_error "$1"
    printf "Try '%s --help' for more information.\n" "$PROGRAM_NAME" >&2
    exit 2
}

# @description Require an option value and store it in OPTION_VALUE.
# @arg $1 string Option name.
# @arg $2 integer Remaining argument count.
# @arg $3 string|unset Candidate value.
# @exitcode 2 If absent.
require_option_value() {
    if (($2 < 2)) || [[ -z "${3-}" ]]; then
        usage_error "$1 requires a value"
    fi
    OPTION_VALUE=$3
}

# @description Parse command-line arguments.
# @arg $@ string Arguments.
# @exitcode 2 For invalid usage.
parse_arguments() {
    while (($# > 0)); do
        case "$1" in
            --output | -o)
                require_option_value "$1" "$#" "${2-}"
                OUTPUT_FILE=$OPTION_VALUE
                shift
                ;;
            --password-file)
                require_option_value "$1" "$#" "${2-}"
                SUPPLIED_PASSWORD_FILE=$OPTION_VALUE
                shift
                ;;
            --password-stdin) PASSWORD_FROM_STDIN=true ;;
            --allow-unencrypted) ALLOW_UNENCRYPTED=true ;;
            --linearize) LINEARIZE=true ;;
            --force | -f) FORCE=true ;;
            --dry-run) DRY_RUN=true ;;
            --quiet | -q) QUIET=true ;;
            --verbose | -v) VERBOSE=true ;;
            --help | -h)
                print_help
                exit 0
                ;;
            --version)
                printf '%s %s\n' "$PROGRAM_NAME" "$VERSION"
                exit 0
                ;;
            --)
                shift
                while (($# > 0)); do POSITIONAL_ARGUMENTS+=("$1"); shift; done
                break
                ;;
            -*) usage_error "unknown option: $1" ;;
            *) POSITIONAL_ARGUMENTS+=("$1") ;;
        esac
        shift
    done
}

# @description Split a path into DIRECTORY_NAME and FILE_NAME.
# @arg $1 string Path.
split_path() {
    case "$1" in
        */*) DIRECTORY_NAME=${1%/*}; FILE_NAME=${1##*/}; [[ -n "$DIRECTORY_NAME" ]] || DIRECTORY_NAME="/" ;;
        *) DIRECTORY_NAME="."; FILE_NAME=$1 ;;
    esac
}

# @description Derive the default output beside the input.
# @arg $1 string Input path.
# @stdout Default output path.
default_output_path() {
    local directory
    local filename
    local stem
    split_path "$1"
    directory=$DIRECTORY_NAME
    filename=$FILE_NAME
    case "$filename" in *.*) stem=${filename%.*} ;; *) stem=$filename ;; esac
    if [[ "$directory" == "." ]]; then printf '%s-unlocked.pdf\n' "$stem"
    elif [[ "$directory" == "/" ]]; then printf '/%s-unlocked.pdf\n' "$stem"
    else printf '%s/%s-unlocked.pdf\n' "$directory" "$stem"
    fi
}

# @description Return a lowercase extension without a leading dot.
# @arg $1 string Path.
# @stdout Lowercase extension.
lowercase_extension() {
    local filename=${1##*/}
    local extension=""
    case "$filename" in *.*) extension=${filename##*.} ;; esac
    printf '%s' "$extension" | tr '[:upper:]' '[:lower:]'
}

# @description Normalize a path whose parent exists.
# @arg $1 string Path.
# @stdout Absolute parent plus basename.
# @exitcode 1 If unresolved.
normalize_path() {
    local parent
    local basename
    split_path "$1"
    parent=$DIRECTORY_NAME
    basename=$FILE_NAME
    parent=$(cd "$parent" 2>/dev/null && pwd -P) || return 1
    printf '%s/%s\n' "${parent%/}" "$basename"
}

# @description Validate arguments, paths, dependencies, and overwrite policy.
# @exitcode 2 For invalid usage.
# @exitcode 3 For invalid paths.
# @exitcode 127 For missing dependencies.
validate_arguments() {
    local command_name
    local normalized_input
    local normalized_output
    ((${#POSITIONAL_ARGUMENTS[@]} >= 1 && ${#POSITIONAL_ARGUMENTS[@]} <= 2)) || \
        usage_error "INPUT.pdf and at most one OUTPUT.pdf are required"
    INPUT_FILE=${POSITIONAL_ARGUMENTS[0]}
    if [[ -n "$OUTPUT_FILE" && ${#POSITIONAL_ARGUMENTS[@]} == 2 ]]; then
        usage_error "use positional OUTPUT.pdf or --output, not both"
    fi
    if [[ -z "$OUTPUT_FILE" && ${#POSITIONAL_ARGUMENTS[@]} == 2 ]]; then
        OUTPUT_FILE=${POSITIONAL_ARGUMENTS[1]}
    fi
    [[ -n "$OUTPUT_FILE" ]] || OUTPUT_FILE=$(default_output_path "$INPUT_FILE")
    [[ "$PASSWORD_FROM_STDIN" != true || -z "$SUPPLIED_PASSWORD_FILE" ]] || \
        usage_error "--password-stdin and --password-file cannot be combined"
    [[ "$QUIET" != true || "$VERBOSE" != true ]] || usage_error "--quiet and --verbose cannot be combined"
    [[ "$(lowercase_extension "$INPUT_FILE")" == pdf ]] || usage_error "input filename must end in .pdf"
    [[ "$(lowercase_extension "$OUTPUT_FILE")" == pdf ]] || usage_error "output filename must end in .pdf"
    case "$INPUT_FILE$OUTPUT_FILE$SUPPLIED_PASSWORD_FILE" in *$'\n'*) usage_error "paths containing newlines are unsupported" ;; esac

    for command_name in qpdf mktemp mv pwd rm tr; do
        if ! command -v "$command_name" >/dev/null 2>&1; then
            log_error "required command was not found on PATH: $command_name"
            if [[ "$command_name" == qpdf ]]; then
                printf '%s\n' "Install qpdf with your package manager, for example 'brew install qpdf' or 'sudo apt install qpdf'." >&2
            fi
            exit 127
        fi
    done
    [[ -f "$INPUT_FILE" && -r "$INPUT_FILE" ]] || { log_error "input is not a readable regular file: $INPUT_FILE"; exit 3; }
    if [[ -n "$SUPPLIED_PASSWORD_FILE" && ( ! -f "$SUPPLIED_PASSWORD_FILE" || ! -r "$SUPPLIED_PASSWORD_FILE" ) ]]; then
        log_error "password file is not a readable regular file: $SUPPLIED_PASSWORD_FILE"
        exit 3
    fi
    split_path "$OUTPUT_FILE"
    [[ -n "$FILE_NAME" ]] || { log_error "invalid output filename: $OUTPUT_FILE"; exit 3; }
    [[ -d "$DIRECTORY_NAME" ]] || { log_error "output directory does not exist: $DIRECTORY_NAME"; exit 3; }
    [[ -w "$DIRECTORY_NAME" ]] || { log_error "output directory is not writable: $DIRECTORY_NAME"; exit 3; }
    normalized_input=$(normalize_path "$INPUT_FILE") || { log_error "could not resolve input path: $INPUT_FILE"; exit 3; }
    normalized_output=$(normalize_path "$OUTPUT_FILE") || { log_error "could not resolve output path: $OUTPUT_FILE"; exit 3; }
    [[ "$normalized_input" != "$normalized_output" ]] || { log_error "output must not replace the input PDF"; exit 3; }
    [[ ! -d "$OUTPUT_FILE" ]] || { log_error "output path is a directory: $OUTPUT_FILE"; exit 3; }
    if [[ -e "$OUTPUT_FILE" && "$FORCE" != true ]]; then
        log_error "output already exists; pass --force to replace it: $OUTPUT_FILE"
        exit 3
    fi
}

# @description Inspect whether the input is encrypted and requires a password.
# @exitcode 4 If invalid or already unencrypted without permission.
inspect_input() {
    local status
    set +e
    qpdf --is-encrypted "$INPUT_FILE" >/dev/null 2>&1
    status=$?
    set -e
    case "$status" in
        0) INPUT_IS_ENCRYPTED=true ;;
        2)
            INPUT_IS_ENCRYPTED=false
            [[ "$ALLOW_UNENCRYPTED" == true ]] || { log_error "input PDF is not encrypted; pass --allow-unencrypted to rewrite it"; exit 4; }
            ;;
        *) log_error "qpdf could not inspect the input PDF"; exit 4 ;;
    esac
    if [[ "$INPUT_IS_ENCRYPTED" == true ]]; then
        set +e
        qpdf --requires-password "$INPUT_FILE" >/dev/null 2>&1
        status=$?
        set -e
        case "$status" in
            0) PASSWORD_IS_REQUIRED=true ;;
            3) PASSWORD_IS_REQUIRED=false ;;
            *) log_error "qpdf could not determine password requirements"; exit 4 ;;
        esac
    fi
}

# @description Store a password in a temporary user-only file.
# @arg $1 string Password.
# @exitcode 3 If secure temporary storage fails.
write_temporary_password() {
    local password=$1
    local old_umask
    old_umask=$(umask)
    umask 077
    TEMPORARY_PASSWORD_FILE=$(mktemp "${TMPDIR:-/tmp}/${PROGRAM_NAME}.password.XXXXXX") || {
        umask "$old_umask"
        log_error "could not create a temporary password file"
        exit 3
    }
    printf '%s\n' "$password" > "$TEMPORARY_PASSWORD_FILE"
    umask "$old_umask"
}

# @description Read a required password without placing it in process arguments.
# @exitcode 5 If input is unavailable.
acquire_password() {
    local password=""
    [[ "$PASSWORD_IS_REQUIRED" == true ]] || return 0
    if [[ -n "$SUPPLIED_PASSWORD_FILE" ]]; then
        PASSWORD_FILE=$SUPPLIED_PASSWORD_FILE
        return 0
    fi
    if [[ "$DRY_RUN" == true ]]; then
        PASSWORD_FILE="<password-file>"
        return 0
    fi
    if [[ "$PASSWORD_FROM_STDIN" == true ]]; then
        if ! IFS= read -r password && [[ -z "$password" ]]; then
            log_error "standard input ended before a password was read"
            exit 5
        fi
    else
        [[ -t 0 ]] || { log_error "password prompt requires a terminal; use --password-stdin or --password-file"; exit 5; }
        IFS= read -r -s -p "PDF password: " password || { printf '\n' >&2; log_error "could not read password"; exit 5; }
        printf '\n' >&2
    fi
    write_temporary_password "$password"
    password=""
    PASSWORD_FILE=$TEMPORARY_PASSWORD_FILE
}

# @description Validate a supplied password before rewriting the document.
# @exitcode 5 If incorrect.
validate_password() {
    local status
    [[ "$PASSWORD_IS_REQUIRED" == true && "$DRY_RUN" != true ]] || return 0
    set +e
    qpdf --password-file="$PASSWORD_FILE" --requires-password "$INPUT_FILE" >/dev/null 2>&1
    status=$?
    set -e
    [[ "$status" == 3 ]] || { log_error "password is incorrect"; exit 5; }
}

# @description Print a shell-escaped qpdf command with no password value.
# @arg $@ string Command and arguments.
print_command() {
    local argument
    printf '%s:' "$PROGRAM_NAME"
    for argument in "$@"; do printf ' %q' "$argument"; done
    printf '\n'
}

# @description Build the decryption command and temporary output path.
build_command() {
    local directory
    local basename
    split_path "$OUTPUT_FILE"
    directory=$DIRECTORY_NAME
    basename=$FILE_NAME
    TEMPORARY_OUTPUT_FILE="${directory%/}/.${basename}.partial.$$.pdf"
    [[ "$directory" == "/" ]] && TEMPORARY_OUTPUT_FILE="/.${basename}.partial.$$.pdf"
    [[ ! -e "$TEMPORARY_OUTPUT_FILE" ]] || { log_error "temporary output already exists: $TEMPORARY_OUTPUT_FILE"; exit 3; }
    QPDF_COMMAND=(qpdf --warning-exit-0)
    [[ "$PASSWORD_IS_REQUIRED" != true ]] || QPDF_COMMAND+=(--password-file="$PASSWORD_FILE")
    QPDF_COMMAND+=(--decrypt --stream-data=preserve --object-streams=preserve)
    [[ "$LINEARIZE" != true ]] || QPDF_COMMAND+=(--linearize)
    QPDF_COMMAND+=("$INPUT_FILE" "$TEMPORARY_OUTPUT_FILE")
}

# @description Verify that output is valid and unencrypted.
# @exitcode 6 If validation fails.
verify_output() {
    local status
    [[ -s "$TEMPORARY_OUTPUT_FILE" ]] || { log_error "qpdf produced no output"; exit 6; }
    qpdf --warning-exit-0 --check "$TEMPORARY_OUTPUT_FILE" >/dev/null || { log_error "output PDF failed structural validation"; exit 6; }
    set +e
    qpdf --is-encrypted "$TEMPORARY_OUTPUT_FILE" >/dev/null 2>&1
    status=$?
    set -e
    [[ "$status" == 2 ]] || { log_error "output PDF remains encrypted"; exit 6; }
}

# @description Remove temporary password and output files.
cleanup() {
    local status=$?
    [[ -z "$TEMPORARY_PASSWORD_FILE" || ! -f "$TEMPORARY_PASSWORD_FILE" ]] || rm -f "$TEMPORARY_PASSWORD_FILE"
    [[ -z "$TEMPORARY_OUTPUT_FILE" || ! -f "$TEMPORARY_OUTPUT_FILE" ]] || rm -f "$TEMPORARY_OUTPUT_FILE"
    return "$status"
}

# @description Run remove-pdf-password.
# @arg $@ string Command-line arguments.
main() {
    parse_arguments "$@"
    validate_arguments
    trap cleanup EXIT
    trap 'exit 130' INT
    trap 'exit 143' TERM
    inspect_input
    acquire_password
    validate_password
    build_command
    log_info "input: $INPUT_FILE"
    log_info "output: $OUTPUT_FILE"
    [[ "$VERBOSE" == true || "$DRY_RUN" == true ]] && print_command "${QPDF_COMMAND[@]}"
    if [[ "$DRY_RUN" == true ]]; then log_info "dry run complete; no PDF was written"; return 0; fi
    "${QPDF_COMMAND[@]}" || { log_error "qpdf decryption failed"; exit 6; }
    verify_output
    mv -f "$TEMPORARY_OUTPUT_FILE" "$OUTPUT_FILE" || { log_error "could not publish output: $OUTPUT_FILE"; exit 7; }
    TEMPORARY_OUTPUT_FILE=""
    log_info "password removed successfully: $OUTPUT_FILE"
    trap - EXIT INT TERM
    cleanup
}

main "$@"
