#!/usr/bin/env bash
# shellcheck shell=bash

set -euo pipefail

readonly PROGRAM_NAME="freeze-github-release"
readonly VERSION="2.0.0"
readonly GITHUB_API="https://api.github.com"

REPOSITORY=""
MODE="release"
REQUESTED_REF=""
SOURCE_MODE_SET=false
FALLBACK_DEFAULT_BRANCH=false
INCLUDE_SHA512=false
INCLUDE_MD5=false
FORMAT="shell"
OUTPUT_FILE=""
ARCHIVE_OUTPUT=""
FORCE=false
QUIET=false
VERBOSE=false
TOKEN_ENV=""

WORK_DIRECTORY=""
ARCHIVE_FILE=""
FORMATTED_FILE=""
JSON_BACKEND=""
TOKEN=""

REF_TYPE=""
RESOLVED_REF=""
COMMIT_SHA=""
PUBLISHED_AT=""
SOURCE_URL=""
SOURCE_SIZE=""
SOURCE_SHA256=""
SOURCE_SHA512=""
SOURCE_MD5=""
LAST_HTTP_STATUS=""

# @description Print usage, resolution behavior, examples, dependencies, and exits.
# @stdout Complete help text.
print_help() {
    printf '%s\n' "Usage: ${PROGRAM_NAME} [OPTIONS] OWNER/REPOSITORY

Resolve a GitHub release, tag, branch, or commit to an exact commit archive,
download it, and emit integrity metadata suitable for reproducible builds.

Source selection (mutually exclusive):
  --latest-release           Latest published, non-draft, non-prerelease release
                             (default).
  --tag TAG                  Resolve an explicit Git tag.
  --default-branch           Resolve the repository's current default branch.
  --branch BRANCH            Resolve an explicit branch.
  --commit SHA               Resolve an explicit commit or commit-ish value.
  --archive                  Compatibility alias for --default-branch.

Options:
  --fallback-default-branch  If no latest release exists, explicitly fall back
                             to the default branch instead of failing.
  --sha512                   Also calculate SHA-512.
  --md5                      Also calculate legacy MD5.
  --format FORMAT            shell or json (default: shell).
  --output FILE              Write metadata atomically to FILE.
  --archive-output FILE      Keep the downloaded .tar.gz at FILE.
  --token-env NAME           Read a GitHub token from environment variable NAME.
                             Defaults to GH_TOKEN, then GITHUB_TOKEN.
  --force                    Replace existing output/archive files.
  --quiet                    Suppress normal progress messages.
  --verbose                  Print resolution and dependency diagnostics.
  -h, --help                 Show this help and exit.
  --version                  Show version information and exit.

Examples:
  ${PROGRAM_NAME} ImageMagick/ImageMagick
  ${PROGRAM_NAME} --tag 7.1.1-47 ImageMagick/ImageMagick
  ${PROGRAM_NAME} --default-branch PDAL/PDAL
  ${PROGRAM_NAME} --branch release/2.9 PDAL/PDAL
  ${PROGRAM_NAME} --commit abc123 owner/repo
  ${PROGRAM_NAME} --sha512 --md5 --format json owner/repo
  ${PROGRAM_NAME} --output source.env --archive-output source.tar.gz owner/repo

Shell output variables:
  GITHUB_REPOSITORY, GITHUB_REF_TYPE, GITHUB_REF, GITHUB_COMMIT,
  GITHUB_RELEASE_PUBLISHED_AT, SOURCE_URL, SOURCE_SIZE, SOURCE_SHA256,
  and optional SOURCE_SHA512/SOURCE_MD5.

Reproducibility notes:
  Branch and latest-release discovery are mutable lookup operations, but this
  command immediately resolves them to a full commit SHA and emits a codeload
  URL containing that SHA. Git tags can be moved, so tag mode is resolved the
  same way. GitHub-generated source archives are not a substitute for a signed
  release asset or vendored source: retain the checksum and consider retaining
  the archive for long-term byte-for-byte reproducibility.

  MD5 is available only for compatibility and is not a modern integrity or
  security checksum. SHA-256 is always generated.

Authentication:
  Public repositories work without a token but are subject to lower API rate
  limits. Private repositories require a token with repository Contents read
  access. Tokens are read only from environment variables and never accepted as
  command-line values.

Dependencies:
  Bash 3.2+, curl, awk, mktemp, mv, rm, sed, tr, wc, plus jq or Python 3 for
  JSON parsing. Checksums use sha256sum/shasum/openssl, with similar portable
  fallbacks for SHA-512 and MD5. --archive-output additionally requires cp.

Exit codes:
  0    Metadata generated successfully.
  2    Invalid command-line usage.
  3    Invalid or conflicting output path.
  4    GitHub API request or reference resolution failed.
  5    Archive download or checksum generation failed.
  6    Latest release was unavailable and fallback was not requested.
  7    Output/archive publication failed.
  127  A required dependency or checksum implementation is unavailable.
"
}

# @description Print an informational message unless quiet mode is active.
# @arg $1 string Message.
log_info() { [[ "$QUIET" == true ]] || printf '%s: %s\n' "$PROGRAM_NAME" "$1" >&2; }

# @description Print a verbose diagnostic.
# @arg $1 string Message.
log_verbose() { [[ "$VERBOSE" != true ]] || printf '%s: %s\n' "$PROGRAM_NAME" "$1" >&2; }

# @description Print an error message.
# @arg $1 string Message.
log_error() { printf '%s: error: %s\n' "$PROGRAM_NAME" "$1" >&2; }

# @description Exit with an invalid-usage error.
# @arg $1 string Explanation.
# @exitcode 2 Always.
usage_error() { log_error "$1"; printf "Try '%s --help' for more information.\n" "$PROGRAM_NAME" >&2; exit 2; }

# @description Require and expose an option value as OPTION_VALUE.
require_option_value() {
    if (($2 < 2)) || [[ -z "${3-}" ]]; then usage_error "$1 requires a nonempty value"; fi
    OPTION_VALUE=$3
}

# @description Select one source mode and reject conflicting selectors.
# @arg $1 string Mode.
# @arg $2 string Optional ref.
select_mode() {
    local mode=$1
    local ref=${2:-}
    [[ "$SOURCE_MODE_SET" != true ]] || usage_error "source selection options are mutually exclusive"
    MODE=$mode
    REQUESTED_REF=$ref
    SOURCE_MODE_SET=true
}

# @description Parse command-line arguments.
# @arg $@ string CLI arguments.
parse_arguments() {
    local -a positional=()
    while (($# > 0)); do
        case "$1" in
            --latest-release) select_mode release "" ;;
            --tag) require_option_value "$1" "$#" "${2-}"; select_mode tag "$OPTION_VALUE"; shift ;;
            --default-branch | --archive) select_mode default-branch "" ;;
            --branch) require_option_value "$1" "$#" "${2-}"; select_mode branch "$OPTION_VALUE"; shift ;;
            --commit) require_option_value "$1" "$#" "${2-}"; select_mode commit "$OPTION_VALUE"; shift ;;
            --fallback-default-branch) FALLBACK_DEFAULT_BRANCH=true ;;
            --sha512) INCLUDE_SHA512=true ;;
            --md5) INCLUDE_MD5=true ;;
            --format) require_option_value "$1" "$#" "${2-}"; FORMAT=$OPTION_VALUE; shift ;;
            --json) FORMAT=json ;;
            --output) require_option_value "$1" "$#" "${2-}"; OUTPUT_FILE=$OPTION_VALUE; shift ;;
            --archive-output) require_option_value "$1" "$#" "${2-}"; ARCHIVE_OUTPUT=$OPTION_VALUE; shift ;;
            --token-env) require_option_value "$1" "$#" "${2-}"; TOKEN_ENV=$OPTION_VALUE; shift ;;
            --force | -f) FORCE=true ;;
            --quiet | -q) QUIET=true ;;
            --verbose | -v) VERBOSE=true ;;
            --help | -h) print_help; exit 0 ;;
            --version) printf '%s %s\n' "$PROGRAM_NAME" "$VERSION"; exit 0 ;;
            --) shift; while (($# > 0)); do positional+=("$1"); shift; done; break ;;
            -*) usage_error "unknown option: $1" ;;
            *) positional+=("$1") ;;
        esac
        shift
    done
    ((${#positional[@]} == 1)) || usage_error "exactly one OWNER/REPOSITORY argument is required"
    REPOSITORY=${positional[0]}
}

# @description Normalize a destination whose parent directory already exists.
# @arg $1 string Destination path.
# @stdout Absolute parent plus filename.
normalize_destination() {
    local path=$1 parent filename
    case "$path" in */*) parent=${path%/*}; filename=${path##*/}; [[ -n "$parent" ]] || parent=/ ;; *) parent=.; filename=$path ;; esac
    parent=$(cd "$parent" 2>/dev/null && pwd -P) || return 1
    printf '%s/%s\n' "${parent%/}" "$filename"
}

# @description Validate repository syntax, modes, and destination paths.
validate_arguments() {
    local path parent filename
    local normalized_output
    local normalized_archive
    case "$FORMAT" in shell | json) ;; *) usage_error "unknown format: $FORMAT" ;; esac
    [[ "$REPOSITORY" =~ ^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$ ]] || usage_error "repository must use OWNER/REPOSITORY syntax"
    case "$REQUESTED_REF$OUTPUT_FILE$ARCHIVE_OUTPUT$TOKEN_ENV" in *$'\n'* | *$'\r'*) usage_error "values containing line breaks are unsupported" ;; esac
    if [[ -n "$TOKEN_ENV" && ! "$TOKEN_ENV" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then usage_error "invalid token environment variable name: $TOKEN_ENV"; fi
    [[ "$FALLBACK_DEFAULT_BRANCH" != true || "$MODE" == release ]] || usage_error "--fallback-default-branch is only valid with latest-release mode"
    for path in "$OUTPUT_FILE" "$ARCHIVE_OUTPUT"; do
        [[ -n "$path" ]] || continue
        case "$path" in */*) parent=${path%/*}; filename=${path##*/}; [[ -n "$parent" ]] || parent=/ ;; *) parent=.; filename=$path ;; esac
        [[ -n "$filename" ]] || { log_error "destination has no filename: $path"; exit 3; }
        [[ -d "$parent" && -w "$parent" ]] || { log_error "destination parent is not writable: $parent"; exit 3; }
        [[ ! -d "$path" ]] || { log_error "destination is a directory: $path"; exit 3; }
        [[ ! -e "$path" || "$FORCE" == true ]] || { log_error "destination exists; pass --force: $path"; exit 3; }
    done
    if [[ -n "$OUTPUT_FILE" && -n "$ARCHIVE_OUTPUT" ]]; then
        normalized_output=$(normalize_destination "$OUTPUT_FILE") || { log_error "could not resolve metadata destination"; exit 3; }
        normalized_archive=$(normalize_destination "$ARCHIVE_OUTPUT") || { log_error "could not resolve archive destination"; exit 3; }
        [[ "$normalized_output" != "$normalized_archive" ]] || usage_error "metadata and archive outputs must differ"
    fi
}

# @description Require core commands and select JSON/checksum implementations.
require_dependencies() {
    local command_name
    for command_name in curl awk mktemp mv rm sed tr wc; do
        command -v "$command_name" >/dev/null 2>&1 || { log_error "required command was not found: $command_name"; exit 127; }
    done
    if command -v jq >/dev/null 2>&1; then JSON_BACKEND=jq
    elif command -v python3 >/dev/null 2>&1; then JSON_BACKEND=python3
    else log_error "JSON parsing requires jq or Python 3"; exit 127
    fi
    if ! command -v sha256sum >/dev/null 2>&1 && ! command -v shasum >/dev/null 2>&1 && ! command -v openssl >/dev/null 2>&1; then
        log_error "SHA-256 requires sha256sum, shasum, or openssl"; exit 127
    fi
    if [[ "$INCLUDE_SHA512" == true ]] && ! command -v sha512sum >/dev/null 2>&1 && ! command -v shasum >/dev/null 2>&1 && ! command -v openssl >/dev/null 2>&1; then
        log_error "SHA-512 requires sha512sum, shasum, or openssl"; exit 127
    fi
    if [[ "$INCLUDE_MD5" == true ]] && ! command -v md5sum >/dev/null 2>&1 && ! command -v md5 >/dev/null 2>&1 && ! command -v openssl >/dev/null 2>&1; then
        log_error "MD5 requires md5sum, md5, or openssl"; exit 127
    fi
    if [[ -n "$ARCHIVE_OUTPUT" ]] && ! command -v cp >/dev/null 2>&1; then log_error "--archive-output requires cp"; exit 127; fi
    log_verbose "JSON parser: $JSON_BACKEND"
}

# @description Load authentication from the configured/default environment variable.
load_token() {
    if [[ -n "$TOKEN_ENV" ]]; then TOKEN=${!TOKEN_ENV:-}
    elif [[ -n "${GH_TOKEN:-}" ]]; then TOKEN=$GH_TOKEN
    elif [[ -n "${GITHUB_TOKEN:-}" ]]; then TOKEN=$GITHUB_TOKEN
    fi
    [[ -n "$TOKEN_ENV" && -z "$TOKEN" ]] && { log_error "token environment variable is empty or unset: $TOKEN_ENV"; exit 4; }
    [[ -z "$TOKEN" ]] || log_verbose "GitHub authentication enabled from environment"
}

# @description Create private working storage.
create_work_directory() {
    local old_umask
    old_umask=$(umask); umask 077
    WORK_DIRECTORY=$(mktemp -d "${TMPDIR:-/tmp}/${PROGRAM_NAME}.XXXXXX") || { umask "$old_umask"; log_error "could not create work directory"; exit 3; }
    umask "$old_umask"
    ARCHIVE_FILE="${WORK_DIRECTORY}/source.tar.gz"
    FORMATTED_FILE="${WORK_DIRECTORY}/metadata"
}

# @description Remove unfinished temporary data.
cleanup() { local status=$?; [[ -z "$WORK_DIRECTORY" || ! -d "$WORK_DIRECTORY" ]] || rm -rf "$WORK_DIRECTORY"; return "$status"; }

# @description Request a GitHub API endpoint into a file.
# @arg $1 string API path beginning with slash.
# @arg $2 string Output file.
# @arg $@ remaining curl query arguments.
api_request() {
    local endpoint=$1 output=$2
    local curl_status
    local http_status
    shift 2
    local -a arguments=(--fail --silent --show-error --location --retry 3 --connect-timeout 15
        --header 'Accept: application/vnd.github+json'
        --header 'X-GitHub-Api-Version: 2022-11-28'
        --header "User-Agent: ${PROGRAM_NAME}/${VERSION}")
    [[ -z "$TOKEN" ]] || arguments+=(--header "Authorization: Bearer $TOKEN")
    arguments+=(--output "$output")
    set +e
    http_status=$(curl "${arguments[@]}" --write-out '%{http_code}' "$@" "${GITHUB_API}${endpoint}")
    curl_status=$?
    set -e
    LAST_HTTP_STATUS=$http_status
    return "$curl_status"
}

# @description Extract a dotted JSON field, including numeric array components.
# @arg $1 string JSON file.
# @arg $2 string Dotted path such as 0.sha.
# @stdout Scalar value or empty.
json_field() {
    local file=$1 path=$2
    if [[ "$JSON_BACKEND" == jq ]]; then
        jq -r --arg path "$path" 'getpath($path | split(".") | map(if test("^[0-9]+$") then tonumber else . end)) // empty' "$file"
    else
        python3 -c 'import json,sys
d=json.load(open(sys.argv[1],encoding="utf-8"))
try:
    for p in sys.argv[2].split("."): d=d[int(p)] if p.isdigit() else d[p]
    if d is not None: print(str(d).lower() if isinstance(d,bool) else d)
except (KeyError,IndexError,TypeError): pass' "$file" "$path"
    fi
}

# @description Resolve a ref or commit-ish to a full commit SHA.
# @arg $1 string Ref.
# @stdout Full SHA.
resolve_commit() {
    local ref=$1
    local response="${WORK_DIRECTORY}/commit.json"
    api_request "/repos/${REPOSITORY}/commits" "$response" --get --data-urlencode "sha=$ref" --data-urlencode 'per_page=1' || {
        log_error "could not resolve GitHub ref: $ref"; exit 4
    }
    local sha
    sha=$(json_field "$response" '0.sha') || { log_error "could not parse commit response"; exit 4; }
    [[ "$sha" =~ ^[0-9a-fA-F]{40}$ ]] || { log_error "GitHub returned no full commit SHA for ref: $ref"; exit 4; }
    printf '%s\n' "$sha"
}

# @description Resolve latest release metadata, optionally falling back explicitly.
resolve_latest_release() {
    local response="${WORK_DIRECTORY}/release.json"
    if ! api_request "/repos/${REPOSITORY}/releases/latest" "$response"; then
        if [[ "$LAST_HTTP_STATUS" == 404 && "$FALLBACK_DEFAULT_BRANCH" == true ]]; then
            log_info "latest release unavailable; resolving default branch by request"
            MODE=default-branch
            resolve_default_branch
            return 0
        fi
        if [[ "$LAST_HTTP_STATUS" == 404 ]]; then
            log_error "latest published release was not found for $REPOSITORY"
            exit 6
        fi
        log_error "GitHub API request for the latest release failed (HTTP ${LAST_HTTP_STATUS:-unknown})"
        exit 4
    fi
    RESOLVED_REF=$(json_field "$response" tag_name) || exit 4
    PUBLISHED_AT=$(json_field "$response" published_at) || exit 4
    [[ -n "$RESOLVED_REF" ]] || { log_error "latest release response contained no tag"; exit 6; }
    REF_TYPE=release
    COMMIT_SHA=$(resolve_commit "$RESOLVED_REF")
}

# @description Resolve the repository's default branch.
resolve_default_branch() {
    local response="${WORK_DIRECTORY}/repository.json"
    api_request "/repos/${REPOSITORY}" "$response" || { log_error "could not read repository metadata: $REPOSITORY"; exit 4; }
    RESOLVED_REF=$(json_field "$response" default_branch) || exit 4
    [[ -n "$RESOLVED_REF" ]] || { log_error "repository response contained no default branch"; exit 4; }
    REF_TYPE=branch
    COMMIT_SHA=$(resolve_commit "$RESOLVED_REF")
}

# @description Resolve the selected source mode to a full commit SHA.
resolve_source() {
    case "$MODE" in
        release) resolve_latest_release ;;
        default-branch) resolve_default_branch ;;
        tag) REF_TYPE=tag; RESOLVED_REF=$REQUESTED_REF; COMMIT_SHA=$(resolve_commit "$RESOLVED_REF") ;;
        branch) REF_TYPE=branch; RESOLVED_REF=$REQUESTED_REF; COMMIT_SHA=$(resolve_commit "$RESOLVED_REF") ;;
        commit) REF_TYPE=commit; RESOLVED_REF=$REQUESTED_REF; COMMIT_SHA=$(resolve_commit "$RESOLVED_REF") ;;
    esac
    SOURCE_URL="https://codeload.github.com/${REPOSITORY}/tar.gz/${COMMIT_SHA}"
    log_verbose "resolved $REF_TYPE '$RESOLVED_REF' to $COMMIT_SHA"
}

# @description Download the commit-pinned source archive.
download_archive() {
    local -a arguments=(--fail --silent --show-error --location --retry 3 --connect-timeout 15
        --header "User-Agent: ${PROGRAM_NAME}/${VERSION}" --output "$ARCHIVE_FILE")
    [[ -z "$TOKEN" ]] || arguments+=(--header "Authorization: Bearer $TOKEN")
    log_info "downloading commit archive for $REPOSITORY at $COMMIT_SHA"
    curl "${arguments[@]}" "$SOURCE_URL" || { log_error "archive download failed"; exit 5; }
    [[ -s "$ARCHIVE_FILE" ]] || { log_error "downloaded archive is empty"; exit 5; }
    SOURCE_SIZE=$(wc -c < "$ARCHIVE_FILE" | tr -d '[:space:]')
    [[ "$SOURCE_SIZE" =~ ^[0-9]+$ ]] || { log_error "could not determine archive size"; exit 5; }
}

# @description Calculate SHA-256 using the first portable implementation.
# @arg $1 string File.
# @stdout Hex digest.
checksum_sha256() {
    if command -v sha256sum >/dev/null 2>&1; then sha256sum "$1" | awk '{print $1}'
    elif command -v shasum >/dev/null 2>&1; then shasum -a 256 "$1" | awk '{print $1}'
    else openssl dgst -sha256 "$1" | sed 's/^.*= //'
    fi
}

# @description Calculate SHA-512 using the first portable implementation.
checksum_sha512() {
    if command -v sha512sum >/dev/null 2>&1; then sha512sum "$1" | awk '{print $1}'
    elif command -v shasum >/dev/null 2>&1; then shasum -a 512 "$1" | awk '{print $1}'
    else openssl dgst -sha512 "$1" | sed 's/^.*= //'
    fi
}

# @description Calculate legacy MD5 using the first portable implementation.
checksum_md5() {
    if command -v md5sum >/dev/null 2>&1; then md5sum "$1" | awk '{print $1}'
    elif command -v md5 >/dev/null 2>&1; then md5 -q "$1"
    else openssl dgst -md5 "$1" | sed 's/^.*= //'
    fi
}

# @description Calculate and validate requested archive digests.
calculate_checksums() {
    SOURCE_SHA256=$(checksum_sha256 "$ARCHIVE_FILE") || { log_error "SHA-256 calculation failed"; exit 5; }
    [[ "$SOURCE_SHA256" =~ ^[0-9a-fA-F]{64}$ ]] || { log_error "invalid SHA-256 result"; exit 5; }
    if [[ "$INCLUDE_SHA512" == true ]]; then
        SOURCE_SHA512=$(checksum_sha512 "$ARCHIVE_FILE") || { log_error "SHA-512 calculation failed"; exit 5; }
        [[ "$SOURCE_SHA512" =~ ^[0-9a-fA-F]{128}$ ]] || { log_error "invalid SHA-512 result"; exit 5; }
    fi
    if [[ "$INCLUDE_MD5" == true ]]; then
        SOURCE_MD5=$(checksum_md5 "$ARCHIVE_FILE") || { log_error "MD5 calculation failed"; exit 5; }
        [[ "$SOURCE_MD5" =~ ^[0-9a-fA-F]{32}$ ]] || { log_error "invalid MD5 result"; exit 5; }
    fi
}

# @description Quote one value safely for POSIX-compatible shell assignment.
# @arg $1 string Value.
# @stdout Single-quoted shell word.
shell_quote() { local value=${1//\'/\'\\\'\'}; printf "'%s'" "$value"; }

# @description Escape one scalar for JSON string output.
# @arg $1 string Value.
# @stdout JSON-escaped content without quotes.
json_escape() { printf '%s' "$1" | awk 'BEGIN{ORS=""}{if(NR>1)printf "\\n";gsub(/\\/,"\\\\");gsub(/\"/,"\\\"");gsub(/\r/,"\\r");printf "%s",$0}'; }

# @description Format metadata as exportable shell assignments.
format_shell() {
    printf 'export GITHUB_REPOSITORY=%s\n' "$(shell_quote "$REPOSITORY")"
    printf 'export GITHUB_REF_TYPE=%s\n' "$(shell_quote "$REF_TYPE")"
    printf 'export GITHUB_REF=%s\n' "$(shell_quote "$RESOLVED_REF")"
    printf 'export GITHUB_COMMIT=%s\n' "$(shell_quote "$COMMIT_SHA")"
    printf 'export GITHUB_RELEASE_PUBLISHED_AT=%s\n' "$(shell_quote "$PUBLISHED_AT")"
    printf 'export SOURCE_URL=%s\n' "$(shell_quote "$SOURCE_URL")"
    printf 'export SOURCE_SIZE=%s\n' "$(shell_quote "$SOURCE_SIZE")"
    printf 'export SOURCE_SHA256=%s\n' "$(shell_quote "$SOURCE_SHA256")"
    [[ "$INCLUDE_SHA512" != true ]] || printf 'export SOURCE_SHA512=%s\n' "$(shell_quote "$SOURCE_SHA512")"
    [[ "$INCLUDE_MD5" != true ]] || printf 'export SOURCE_MD5=%s\n' "$(shell_quote "$SOURCE_MD5")"
}

# @description Format metadata as dependency-free JSON.
format_json() {
    printf '{\n'
    printf '  "repository":"%s",\n' "$(json_escape "$REPOSITORY")"
    printf '  "ref_type":"%s",\n' "$(json_escape "$REF_TYPE")"
    printf '  "ref":"%s",\n' "$(json_escape "$RESOLVED_REF")"
    printf '  "commit":"%s",\n' "$COMMIT_SHA"
    printf '  "release_published_at":"%s",\n' "$(json_escape "$PUBLISHED_AT")"
    printf '  "source_url":"%s",\n' "$(json_escape "$SOURCE_URL")"
    printf '  "source_size":%s,\n' "$SOURCE_SIZE"
    printf '  "source_sha256":"%s"' "$SOURCE_SHA256"
    [[ "$INCLUDE_SHA512" != true ]] || printf ',\n  "source_sha512":"%s"' "$SOURCE_SHA512"
    [[ "$INCLUDE_MD5" != true ]] || printf ',\n  "source_md5":"%s"' "$SOURCE_MD5"
    printf '\n}\n'
}

# @description Generate selected metadata format.
format_metadata() {
    case "$FORMAT" in shell) format_shell ;; json) format_json ;; esac > "$FORMATTED_FILE" || { log_error "metadata formatting failed"; exit 7; }
}

# @description Atomically copy a prepared file to a destination.
# @arg $1 string Source.
# @arg $2 string Destination.
# @exitcode 7 If publication fails.
publish_file() {
    local source=$1 destination=$2 parent filename temporary
    case "$destination" in */*) parent=${destination%/*}; filename=${destination##*/}; [[ -n "$parent" ]] || parent=/ ;; *) parent=.; filename=$destination ;; esac
    temporary=$(mktemp "${parent%/}/.${filename}.tmp.XXXXXX") || { log_error "could not create temporary output beside $destination"; exit 7; }
    # cp is intentionally avoided as a mandatory dependency; stream through awk only for text.
    if [[ "$source" == "$FORMATTED_FILE" ]]; then awk '{print}' "$source" > "$temporary"
    else
        command -v cp >/dev/null 2>&1 || { rm -f "$temporary"; log_error "retaining an archive requires cp"; exit 127; }
        cp "$source" "$temporary"
    fi || { rm -f "$temporary"; log_error "could not stage output: $destination"; exit 7; }
    mv -f "$temporary" "$destination" || { rm -f "$temporary"; log_error "could not publish output: $destination"; exit 7; }
}

# @description Publish metadata and optionally retain the downloaded archive.
publish_outputs() {
    if [[ -n "$OUTPUT_FILE" ]]; then publish_file "$FORMATTED_FILE" "$OUTPUT_FILE"; log_info "metadata written to $OUTPUT_FILE"
    else awk '{print}' "$FORMATTED_FILE"
    fi
    if [[ -n "$ARCHIVE_OUTPUT" ]]; then publish_file "$ARCHIVE_FILE" "$ARCHIVE_OUTPUT"; log_info "archive written to $ARCHIVE_OUTPUT"; fi
}

# @description Run freeze-github-release.
# @arg $@ string CLI arguments.
main() {
    parse_arguments "$@"
    validate_arguments
    require_dependencies
    load_token
    create_work_directory
    trap cleanup EXIT
    trap 'exit 130' INT
    trap 'exit 143' TERM
    resolve_source
    download_archive
    calculate_checksums
    format_metadata
    publish_outputs
    trap - EXIT INT TERM
    cleanup
}

main "$@"
