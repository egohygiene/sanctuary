#!/usr/bin/env bash
set -Eeuo pipefail

: "${EGOHYGIENE_SHELL_ROOT:=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." >/dev/null 2>&1 && pwd)}"

# shellcheck disable=SC1091
source "${EGOHYGIENE_SHELL_ROOT}/lib/install/runtime.sh"

export INSTALL_TOOL_NAME="dust"
export INSTALL_OWNER="bootandy"
export INSTALL_REPO="dust"
export INSTALL_ASSET_TEMPLATE="dust-v{{version}}-{{arch}}-{{platform}}.tar.gz"
export INSTALL_PLATFORM_LINUX="unknown-linux-gnu"
export INSTALL_PLATFORM_DARWIN="apple-darwin"
export INSTALL_ARCH_X86_64="x86_64"
export INSTALL_ARCH_ARM64="aarch64"
export INSTALL_ARCHIVE_FORMAT="tar.gz"
export INSTALL_ARCHIVE_MEMBER_TEMPLATE="dust-v{{version}}-{{arch}}-{{platform}}/dust"
export INSTALL_BIN_NAME="dust"
# shellcheck disable=SC2034
declare -a INSTALL_VERIFY_ARGS=(--version)

install::github::main "$@"
