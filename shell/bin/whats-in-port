#!/usr/bin/env bash
# shellcheck shell=bash

set -euo pipefail

readonly PROGRAM_NAME="whats-in-port"
readonly VERSION="2.0.0"

PROTOCOL="both"
LISTEN_ONLY=true
BACKEND="auto"
FORMAT="table"
USE_SUDO=false
REQUIRE_PROCESS=false
QUIET=false
VERBOSE=false
LIST_BACKENDS=false

SELECTED_BACKEND=""
WORK_DIRECTORY=""
RAW_FILE=""
NORMALIZED_FILE=""
FORMATTED_FILE=""
SUCCESSFUL_EMPTY=false
PERMISSION_FAILURE=false

declare -a PORTS=()
declare -a INSPECT_PREFIX=()
declare -a CANDIDATE_BACKENDS=()

# @description Print CLI usage, schema, backends, examples, and exits.
# @stdout Complete help text.
print_help() {
    printf '%s\n' "Usage: ${PROGRAM_NAME} [OPTIONS] PORT [PORT ...]

Inspect processes and sockets bound to one or more local TCP/UDP ports using
the best available platform tool.

Options:
  --protocol NAME       tcp, udp, or both (default: both).
  --all-connections     Include non-listening TCP connections whose local port
                        matches; default is listeners/bound UDP endpoints only.
  --backend NAME        Force auto, lsof, ss, sockstat, powershell, netstat,
                        or fuser.
  --format FORMAT       table, tsv, json, or pids (default: table).
  --sudo                Retry inspection through sudo on Unix.
  --require-process     Fail if a socket is found but PID/command ownership is
                        hidden or unavailable.
  --list-backends       Show backend availability for this host and exit.
  --quiet               Suppress warnings and diagnostics.
  --verbose             Explain backend fallback decisions.
  -h, --help            Show this help and exit.
  --version             Show version information and exit.

Normalized fields:
  protocol, local_address, local_port, remote_address, remote_port, state,
  pid, user, command, backend

Examples:
  ${PROGRAM_NAME} 3000
  ${PROGRAM_NAME} --protocol tcp 80 443
  ${PROGRAM_NAME} --all-connections --format json 5432
  ${PROGRAM_NAME} --sudo --require-process 445
  ${PROGRAM_NAME} --backend ss --format pids 8080
  ${PROGRAM_NAME} --list-backends

Backend order:
  Linux:       lsof, ss, sockstat, netstat, fuser
  macOS/BSD:   lsof, sockstat, netstat
  Windows Bash: PowerShell Get-NetTCPConnection/Get-NetUDPEndpoint, then
                netstat -ano

Permission behavior:
  The command first falls through installed backends when one cannot inspect
  sockets. Some operating systems reveal an occupied port but hide its PID or
  process name from unprivileged users. Partial records are printed with a
  warning and exit 0; use --sudo for an explicit elevated retry on Unix, or
  --require-process to treat incomplete ownership as exit 4. On Windows, rerun
  the terminal as Administrator if ownership remains unavailable.

Dependencies:
  Bash 3.2+, awk, grep, mktemp, mv, rm, sort, uname, and at least one socket backend.
  Process enrichment additionally uses ps when available. --sudo requires sudo.

Exit codes:
  0    One or more matching sockets were displayed.
  1    No matching socket was found on the requested local port(s).
  2    Invalid command-line usage.
  3    No supported socket-inspection backend is installed.
  4    Inspection was denied/failed, or required process data was unavailable.
  5    Backend output could not be normalized or formatted.
  127  A required base command is unavailable.
"
}

# @description Print an error message.
# @arg $1 string Message.
log_error() { printf '%s: error: %s\n' "$PROGRAM_NAME" "$1" >&2; }

# @description Print a warning unless quiet mode is active.
# @arg $1 string Message.
log_warning() { [[ "$QUIET" == true ]] || printf '%s: warning: %s\n' "$PROGRAM_NAME" "$1" >&2; }

# @description Print a verbose diagnostic.
# @arg $1 string Message.
log_verbose() { [[ "$VERBOSE" != true ]] || printf '%s: %s\n' "$PROGRAM_NAME" "$1" >&2; }

# @description Exit with an invalid-usage error.
# @arg $1 string Explanation.
# @exitcode 2 Always.
usage_error() { log_error "$1"; printf "Try '%s --help' for more information.\n" "$PROGRAM_NAME" >&2; exit 2; }

# @description Require and expose an option value as OPTION_VALUE.
require_option_value() {
    if (($2 < 2)) || [[ -z "${3-}" ]]; then usage_error "$1 requires a nonempty value"; fi
    OPTION_VALUE=$3
}

# @description Parse options and port arguments.
# @arg $@ string CLI arguments.
parse_arguments() {
    while (($# > 0)); do
        case "$1" in
            --protocol) require_option_value "$1" "$#" "${2-}"; PROTOCOL=$OPTION_VALUE; shift ;;
            --all-connections | --all) LISTEN_ONLY=false ;;
            --backend) require_option_value "$1" "$#" "${2-}"; BACKEND=$OPTION_VALUE; shift ;;
            --format) require_option_value "$1" "$#" "${2-}"; FORMAT=$OPTION_VALUE; shift ;;
            --json) FORMAT=json ;;
            --sudo) USE_SUDO=true ;;
            --require-process) REQUIRE_PROCESS=true ;;
            --list-backends) LIST_BACKENDS=true ;;
            --quiet | -q) QUIET=true ;;
            --verbose | -v) VERBOSE=true ;;
            --help | -h) print_help; exit 0 ;;
            --version) printf '%s %s\n' "$PROGRAM_NAME" "$VERSION"; exit 0 ;;
            --) shift; while (($# > 0)); do PORTS+=("$1"); shift; done; break ;;
            -*) usage_error "unknown option: $1" ;;
            *) PORTS+=("$1") ;;
        esac
        shift
    done
}

# @description Validate protocol, backend, format, and numeric ports.
validate_arguments() {
    local port
    case "$PROTOCOL" in tcp | udp | both) ;; *) usage_error "unknown protocol: $PROTOCOL" ;; esac
    case "$BACKEND" in auto | lsof | ss | sockstat | powershell | netstat | fuser) ;; *) usage_error "unknown backend: $BACKEND" ;; esac
    case "$FORMAT" in table | tsv | json | pids) ;; *) usage_error "unknown format: $FORMAT" ;; esac
    if [[ "$LIST_BACKENDS" != true ]]; then ((${#PORTS[@]} > 0)) || usage_error "at least one port is required"; fi
    for port in "${PORTS[@]}"; do
        case "$port" in *[!0-9]* | "") usage_error "port must be an integer: $port" ;; esac
        ((10#$port >= 1 && 10#$port <= 65535)) || usage_error "port must be between 1 and 65535: $port"
    done
}

# @description Require commands used by the core normalization pipeline.
require_base_dependencies() {
    local command_name
    for command_name in awk grep mktemp mv rm sort uname; do
        command -v "$command_name" >/dev/null 2>&1 || { log_error "required command was not found: $command_name"; exit 127; }
    done
}

# @description Locate PowerShell on Windows-compatible systems.
# @stdout Executable name.
find_powershell() {
    if command -v powershell.exe >/dev/null 2>&1; then printf 'powershell.exe\n'
    elif command -v pwsh.exe >/dev/null 2>&1; then printf 'pwsh.exe\n'
    elif command -v pwsh >/dev/null 2>&1; then printf 'pwsh\n'
    else return 1
    fi
}

# @description Return success if a backend executable is available.
# @arg $1 string Backend.
backend_available() {
    case "$1" in
        powershell) find_powershell >/dev/null 2>&1 ;;
        netstat)
            command -v netstat >/dev/null 2>&1 || command -v netstat.exe >/dev/null 2>&1
            ;;
        *) command -v "$1" >/dev/null 2>&1 ;;
    esac
}

# @description Build platform-appropriate fallback order.
build_backend_candidates() {
    local platform
    CANDIDATE_BACKENDS=()
    if [[ "$BACKEND" != auto ]]; then CANDIDATE_BACKENDS=("$BACKEND"); return 0; fi
    platform=$(uname -s)
    case "$platform" in
        MINGW* | MSYS* | CYGWIN*) CANDIDATE_BACKENDS=(powershell netstat) ;;
        Darwin | FreeBSD | OpenBSD | NetBSD) CANDIDATE_BACKENDS=(lsof sockstat netstat) ;;
        *) CANDIDATE_BACKENDS=(lsof ss sockstat netstat fuser) ;;
    esac
}

# @description Configure explicit sudo inspection.
prepare_privileges() {
    [[ "$USE_SUDO" == true ]] || return 0
    case "$(uname -s)" in MINGW* | MSYS* | CYGWIN*) log_warning "--sudo is ignored on Windows; use an Administrator terminal"; return 0 ;; esac
    if ((EUID == 0)); then return 0; fi
    command -v sudo >/dev/null 2>&1 || { log_error "--sudo requested but sudo was not found"; exit 127; }
    INSPECT_PREFIX=(sudo)
}

# @description Create private collector files.
create_work_directory() {
    local old_umask
    old_umask=$(umask); umask 077
    WORK_DIRECTORY=$(mktemp -d "${TMPDIR:-/tmp}/${PROGRAM_NAME}.XXXXXX") || { umask "$old_umask"; log_error "could not create work directory"; exit 5; }
    umask "$old_umask"
    RAW_FILE="${WORK_DIRECTORY}/raw.tsv"
    NORMALIZED_FILE="${WORK_DIRECTORY}/normalized.tsv"
    FORMATTED_FILE="${WORK_DIRECTORY}/formatted"
}

# @description Remove temporary collector data.
cleanup() { local status=$?; [[ -z "$WORK_DIRECTORY" || ! -d "$WORK_DIRECTORY" ]] || rm -rf "$WORK_DIRECTORY"; return "$status"; }

# @description Split an endpoint into global ENDPOINT_ADDRESS and ENDPOINT_PORT.
# @arg $1 string Endpoint.
split_endpoint() {
    local endpoint=$1
    ENDPOINT_PORT=""
    ENDPOINT_ADDRESS=$endpoint
    case "$endpoint" in
        *:*) ENDPOINT_PORT=${endpoint##*:}; ENDPOINT_ADDRESS=${endpoint%:*} ;;
        *.*) ENDPOINT_PORT=${endpoint##*.}; ENDPOINT_ADDRESS=${endpoint%.*} ;;
    esac
    case "$ENDPOINT_ADDRESS" in
        \[*\]) ENDPOINT_ADDRESS=${ENDPOINT_ADDRESS#?}; ENDPOINT_ADDRESS=${ENDPOINT_ADDRESS%?} ;;
    esac
}

# @description Collect sockets with lsof's portable tabular output.
collect_lsof() {
    local port protocol_name protocol_upper
    local -a arguments=()
    for port in "${PORTS[@]}"; do
        for protocol_name in tcp udp; do
            [[ "$PROTOCOL" == both || "$PROTOCOL" == "$protocol_name" ]] || continue
            if [[ "$protocol_name" == tcp ]]; then protocol_upper=TCP; else protocol_upper=UDP; fi
            arguments=(-nP "-i${protocol_upper}:$port")
            if [[ "$LISTEN_ONLY" == true && "$protocol_name" == tcp ]]; then arguments+=("-sTCP:LISTEN"); fi
            "${INSPECT_PREFIX[@]}" lsof "${arguments[@]}" |
                awk -v wanted="$port" -v proto="$protocol_name" 'NR>1 {
                    local=$9; remote=""; state=""
                    if(index(local,"->")){remote=local;sub(/^.*->/,"",remote);sub(/->.*/,"",local)}
                    if(match($0,/\([^()]+\)[[:space:]]*$/)){state=substr($0,RSTART+1,RLENGTH-2)}
                    lp=local;sub(/^.*:/,"",lp);gsub(/[^0-9]/,"",lp)
                    if(remote=="")remote="-";if(state=="")state="-"
                    if(lp==wanted) print proto "\t" local "\t" remote "\t" state "\t" $2 "\t" $3 "\t" $1 "\tlsof"
                }'
        done
    done
    return 0
}

# @description Collect sockets with Linux ss.
collect_ss() {
    local port protocol_name flags
    for port in "${PORTS[@]}"; do
        for protocol_name in tcp udp; do
            [[ "$PROTOCOL" == both || "$PROTOCOL" == "$protocol_name" ]] || continue
            if [[ "$protocol_name" == tcp ]]; then [[ "$LISTEN_ONLY" == true ]] && flags=-Hltnp || flags=-Hatnp
            else [[ "$LISTEN_ONLY" == true ]] && flags=-Hlunp || flags=-Haunp
            fi
            "${INSPECT_PREFIX[@]}" ss "$flags" "sport = :$port" |
                awk -v proto="$protocol_name" '{
                    pid="";command=""; text=$0
                    if(match(text,/pid=[0-9]+/)){pid=substr(text,RSTART+4,RLENGTH-4)}
                    if(match(text,/users:\(\(\"[^\"]+\"/)){command=substr(text,RSTART+9,RLENGTH-9);gsub(/\"/,"",command)}
                    if(pid=="")pid="-";if(command=="")command="-"
                    print proto "\t" $4 "\t" $5 "\t" $1 "\t" pid "\t-\t" command "\tss"
                }'
        done
    done
}

# @description Collect sockets with BSD sockstat.
collect_sockstat() {
    local port protocol_name
    for port in "${PORTS[@]}"; do
        for protocol_name in tcp udp; do
            [[ "$PROTOCOL" == both || "$PROTOCOL" == "$protocol_name" ]] || continue
            "${INSPECT_PREFIX[@]}" sockstat -4 -6 -l -P "$protocol_name" -p "$port" |
                awk -v proto="$protocol_name" 'NR>1 { remote=$7;if(remote=="")remote="-";print proto "\t" $6 "\t" remote "\t" (proto=="tcp"?"LISTEN":"BOUND") "\t" $3 "\t" $1 "\t" $2 "\tsockstat" }'
        done
    done
}

# @description Collect sockets with PowerShell NetTCPIP cmdlets.
collect_powershell() {
    local powershell ports_csv
    powershell=$(find_powershell) || return 1
    ports_csv=$(IFS=,; printf '%s' "${PORTS[*]}")
    "$powershell" -NoLogo -NoProfile -NonInteractive -Command '
      param($PortsCsv,$ProtocolName,$ListenOnly)
      $ErrorActionPreference="Stop"; $ports=$PortsCsv -split "," | ForEach-Object {[int]$_}
      function Emit($proto,$localAddress,$localPort,$remoteAddress,$remotePort,$state,$pid) {
        $command=""; try {$command=(Get-Process -Id $pid -ErrorAction Stop).ProcessName} catch {}
        @($proto,$localAddress,$localPort,$remoteAddress,$remotePort,$state,$pid,"",$command,"powershell") -join "`t"
      }
      if($ProtocolName -in @("tcp","both")) {
        Get-NetTCPConnection -LocalPort $ports -ErrorAction SilentlyContinue | Where-Object { $ListenOnly -ne "true" -or $_.State -eq "Listen" } | ForEach-Object { Emit "tcp" $_.LocalAddress $_.LocalPort $_.RemoteAddress $_.RemotePort $_.State $_.OwningProcess }
      if($ProtocolName -in @("udp","both")) {
        Get-NetUDPEndpoint -LocalPort $ports -ErrorAction SilentlyContinue | ForEach-Object { Emit "udp" $_.LocalAddress $_.LocalPort "*" "*" "BOUND" $_.OwningProcess }
      }
    ' "$ports_csv" "$PROTOCOL" "$LISTEN_ONLY"
}

# @description Collect sockets with Unix or Windows netstat.
collect_netstat() {
    local platform command_name
    platform=$(uname -s)
    if command -v netstat.exe >/dev/null 2>&1 && [[ "$platform" == MINGW* || "$platform" == MSYS* || "$platform" == CYGWIN* ]]; then
        command_name=netstat.exe
        "$command_name" -ano |
            awk -v ports=" ${PORTS[*]} " -v requested="$PROTOCOL" -v listen="$LISTEN_ONLY" '
              /^[[:space:]]*(TCP|UDP)/ {
                proto=tolower($1); local=$2; remote=(proto=="tcp"?$3:"*"); state=(proto=="tcp"?$4:"BOUND"); pid=(proto=="tcp"?$5:$4)
                p=local;sub(/^.*:/,"",p); if(index(ports," " p " ")==0 || (requested!="both"&&requested!=proto) || (listen=="true"&&proto=="tcp"&&state!="LISTENING"))next
                print proto "\t" local "\t" remote "\t" state "\t" pid "\t-\t-\tnetstat"
              }'
    elif [[ "$platform" == Darwin || "$platform" == FreeBSD || "$platform" == OpenBSD || "$platform" == NetBSD ]]; then
        for command_name in tcp udp; do
            [[ "$PROTOCOL" == both || "$PROTOCOL" == "$command_name" ]] || continue
            "${INSPECT_PREFIX[@]}" netstat -an -p "$command_name" |
                awk -v proto="$command_name" -v ports=" ${PORTS[*]} " -v listen="$LISTEN_ONLY" '
                  $1 ~ /^tcp/ || $1 ~ /^udp/ {
                    local=$4;remote=$5;state=(proto=="tcp"?$6:"BOUND");p=local;sub(/^.*[.]/,"",p)
                    if(index(ports," " p " ")==0 || (listen=="true"&&proto=="tcp"&&state!="LISTEN"))next
                    print proto "\t" local "\t" remote "\t" state "\t-\t-\t-\tnetstat"
                  }'
        done
    else
        command_name=netstat
        if [[ "$LISTEN_ONLY" == true ]]; then "${INSPECT_PREFIX[@]}" "$command_name" -lntup
        else "${INSPECT_PREFIX[@]}" "$command_name" -antup
        fi | awk -v ports=" ${PORTS[*]} " -v requested="$PROTOCOL" '
          /^(tcp|udp)/ {
            proto=substr($1,1,3); local=$4; remote=$5; p=local;gsub(/^.*[.:]/,"",p)
            if(index(ports," " p " ")==0 || (requested!="both"&&requested!=proto))next
            if(proto=="tcp"){state=$6;owner=$7}else{state="BOUND";owner=$6}
            pid=owner;sub(/\/.*/,"",pid);command=owner;sub(/^[0-9]+\//,"",command);if(pid=="-")pid="";if(command=="-")command=""
            if(pid=="")pid="-";if(command=="")command="-"
            print proto "\t" local "\t" remote "\t" state "\t" pid "\t-\t" command "\tnetstat"
          }'
    fi
}

# @description Collect PID-only ownership with fuser.
collect_fuser() {
    local port protocol_name output pid
    for port in "${PORTS[@]}"; do
        for protocol_name in tcp udp; do
            [[ "$PROTOCOL" == both || "$PROTOCOL" == "$protocol_name" ]] || continue
            output=$("${INSPECT_PREFIX[@]}" fuser -n "$protocol_name" "$port" 2>&1) || true
            for pid in $output; do
                [[ "$pid" == *[!0-9]* ]] || printf '%s\t*:%s\t*:*\tBOUND\t%s\t-\t-\tfuser\n' "$protocol_name" "$port" "$pid"
            done
        done
    done
}

# @description Dispatch one collector backend.
# @arg $1 string Backend.
collect_backend() {
    case "$1" in lsof) collect_lsof ;; ss) collect_ss ;; sockstat) collect_sockstat ;; powershell) collect_powershell ;; netstat) collect_netstat ;; fuser) collect_fuser ;; esac
}

# @description Try backends until one returns matching records.
select_and_collect() {
    local candidate collector_file error_file status
    local available_count=0
    for candidate in "${CANDIDATE_BACKENDS[@]}"; do
        if ! backend_available "$candidate"; then log_verbose "backend unavailable: $candidate"; continue; fi
        available_count=$((available_count+1)); collector_file="${WORK_DIRECTORY}/${candidate}.tsv"; error_file="${WORK_DIRECTORY}/${candidate}.err"
        log_verbose "trying backend: $candidate"
        set +e
        collect_backend "$candidate" > "$collector_file" 2>"$error_file"
        status=$?
        set -e
        if [[ -s "$collector_file" ]]; then SELECTED_BACKEND=$candidate; RAW_FILE=$collector_file; return 0; fi
        if grep -Eqi 'permission denied|operation not permitted|access (is )?denied|insufficient privilege|not authorized|cannot open (netlink|socket)' "$error_file" 2>/dev/null; then
            PERMISSION_FAILURE=true
            log_verbose "backend access was restricted: $candidate"
        elif [[ -s "$error_file" ]]; then
            log_verbose "backend reported an error: $candidate"
        elif ((status == 0)); then
            SUCCESSFUL_EMPTY=true
        else
            log_verbose "backend failed: $candidate (status $status)"
        fi
    done
    ((available_count > 0)) || { log_error "no supported socket inspection backend was found"; exit 3; }
    if [[ "$SUCCESSFUL_EMPTY" == true ]]; then return 1
    elif [[ "$PERMISSION_FAILURE" == true ]]; then
        log_error "socket inspection was denied by the operating system"
        [[ "$USE_SUDO" == true ]] || printf '%s\n' "Retry with --sudo on Unix or an Administrator terminal on Windows." >&2
    else log_error "installed socket backends could not inspect the requested ports"
    fi
    exit 4
}

# @description Normalize endpoints and enrich missing process metadata with ps.
normalize_records() {
    local protocol local_endpoint remote_endpoint state pid user command backend
    local local_address local_port remote_address remote_port ps_user ps_command
    : > "$NORMALIZED_FILE"
    while IFS=$'\t' read -r protocol local_endpoint remote_endpoint state pid user command backend; do
        [[ -n "$protocol" && -n "$local_endpoint" ]] || continue
        [[ "$remote_endpoint" == - ]] && remote_endpoint=""
        [[ "$state" == - ]] && state=""
        [[ "$pid" == - ]] && pid=""
        [[ "$user" == - ]] && user=""
        [[ "$command" == - ]] && command=""
        split_endpoint "$local_endpoint"; local_address=$ENDPOINT_ADDRESS; local_port=$ENDPOINT_PORT
        if [[ -n "$remote_endpoint" ]]; then split_endpoint "$remote_endpoint"; remote_address=$ENDPOINT_ADDRESS; remote_port=$ENDPOINT_PORT
        else remote_address=""; remote_port=""
        fi
        if [[ -n "$pid" && "$pid" != *[!0-9]* && ( -z "$user" || -z "$command" ) ]] && command -v ps >/dev/null 2>&1; then
            ps_user=$(ps -o user= -p "$pid" 2>/dev/null | awk '{$1=$1;print;exit}') || ps_user=""
            ps_command=$(ps -o comm= -p "$pid" 2>/dev/null | awk '{$1=$1;print;exit}') || ps_command=""
            [[ -n "$user" ]] || user=$ps_user
            [[ -n "$command" ]] || command=$ps_command
        fi
        printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$protocol" "$local_address" "$local_port" "$remote_address" "$remote_port" "$state" "$pid" "$user" "$command" "$backend" >> "$NORMALIZED_FILE"
    done < "$RAW_FILE"
    LC_ALL=C sort -t $'\t' -k3,3n -k1,1 -k7,7n -k2,2 -u "$NORMALIZED_FILE" > "${NORMALIZED_FILE}.sorted" || { log_error "could not sort socket records"; exit 5; }
    mv "${NORMALIZED_FILE}.sorted" "$NORMALIZED_FILE"
    [[ -s "$NORMALIZED_FILE" ]] || { log_error "backend output could not be normalized"; exit 5; }
}

# @description Warn or fail when process ownership is unavailable.
check_process_visibility() {
    local incomplete
    incomplete=$(awk -F '\t' '$7=="" || $9=="" {count++} END{print count+0}' "$NORMALIZED_FILE")
    ((incomplete == 0)) && return 0
    if [[ "$REQUIRE_PROCESS" == true ]]; then log_error "$incomplete socket record(s) lack PID or command ownership"; exit 4; fi
    log_warning "$incomplete socket record(s) lack complete process ownership; retry with --sudo or elevated privileges"
}

# @description Format records as a readable table.
format_table() {
    awk -F '\t' 'BEGIN{printf "%-5s  %-28s  %-9s  %-7s  %-12s  %-18s  %s\n","PROTO","LOCAL","STATE","PID","USER","COMMAND","REMOTE"}
      {local=$2 ":" $3;remote=($4==""?"":$4 ":" $5);printf "%-5s  %-28s  %-9s  %-7s  %-12s  %-18s  %s\n",toupper($1),local,$6,$7,$8,$9,remote}' "$NORMALIZED_FILE"
}

# @description Format records as headered TSV.
format_tsv() { printf 'protocol\tlocal_address\tlocal_port\tremote_address\tremote_port\tstate\tpid\tuser\tcommand\tbackend\n'; awk '{print}' "$NORMALIZED_FILE"; }

# @description Format unique numeric PIDs.
format_pids() { awk -F '\t' '$7 ~ /^[0-9]+$/ && !seen[$7]++ {print $7}' "$NORMALIZED_FILE"; }

# @description Format records as dependency-free JSON.
format_json() {
    awk -F '\t' 'function e(v){gsub(/\\/,"\\\\",v);gsub(/\"/,"\\\"",v);gsub(/\r/,"\\r",v);return v}
      BEGIN{print "[";first=1}{if(!first)print ",";printf "  {\"protocol\":\"%s\",\"local_address\":\"%s\",\"local_port\":%s,\"remote_address\":\"%s\",\"remote_port\":%s,\"state\":\"%s\",\"pid\":%s,\"user\":\"%s\",\"command\":\"%s\",\"backend\":\"%s\"}",e($1),e($2),$3,e($4),($5~/^[0-9]+$/?$5:"null"),e($6),($7~/^[0-9]+$/?$7:"null"),e($8),e($9),e($10);first=0}END{if(!first)print "";print "]"}' "$NORMALIZED_FILE"
}

# @description Generate selected output format.
format_records() {
    case "$FORMAT" in table) format_table ;; tsv) format_tsv ;; json) format_json ;; pids) format_pids ;; esac > "$FORMATTED_FILE" || { log_error "could not format socket records"; exit 5; }
}

# @description Show backend detection status without inspecting ports.
list_backends() {
    local candidate
    build_backend_candidates
    printf '%-12s  %s\n' BACKEND STATUS
    for candidate in lsof ss sockstat powershell netstat fuser; do
        if backend_available "$candidate"; then printf '%-12s  available\n' "$candidate"; else printf '%-12s  missing\n' "$candidate"; fi
    done
    printf 'order         %s\n' "${CANDIDATE_BACKENDS[*]}"
}

# @description Run whats-in-port.
# @arg $@ string CLI arguments.
main() {
    parse_arguments "$@"
    validate_arguments
    require_base_dependencies
    if [[ "$LIST_BACKENDS" == true ]]; then list_backends; return 0; fi
    build_backend_candidates
    prepare_privileges
    create_work_directory
    trap cleanup EXIT
    trap 'exit 130' INT
    trap 'exit 143' TERM
    if ! select_and_collect; then
        trap - EXIT INT TERM; cleanup
        log_verbose "no matching local socket found"
        return 1
    fi
    log_verbose "selected backend: $SELECTED_BACKEND"
    normalize_records
    check_process_visibility
    format_records
    awk '{print}' "$FORMATTED_FILE"
    trap - EXIT INT TERM
    cleanup
}

main "$@"
