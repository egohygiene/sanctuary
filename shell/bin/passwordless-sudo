#!/usr/bin/env bash
# shellcheck shell=bash
#
# passwordless-sudo - Manage isolated passwordless sudo policy files safely.
#
# Purpose:
#   Grant, inspect, or revoke NOPASSWD sudo privileges without appending directly
#   to /etc/sudoers. Changes are previewed unless --execute is supplied.
#
# Usage:
#   passwordless-sudo grant --user USER --command /absolute/program [options]
#   passwordless-sudo grant --user USER --all --acknowledge-full-root-access
#   passwordless-sudo status --user USER
#   passwordless-sudo revoke --user USER [--execute]
#
# Examples:
#   passwordless-sudo grant --user deploy --command /usr/bin/systemctl
#   sudo passwordless-sudo grant --user deploy --command /usr/bin/systemctl --execute
#   sudo passwordless-sudo grant --user alan --all \
#     --acknowledge-full-root-access --execute
#   sudo passwordless-sudo revoke --user alan --execute
#
# Dependencies:
#   sudo/visudo, getent or id, and standard Unix utilities
#
# Exit codes:
#   0   Success
#   1   Operation or sudoers validation failed
#   2   Invalid command-line usage
#   69  sudoers.d is unsupported or not included by the host configuration
#   77  Insufficient permission or missing safety acknowledgement
#   127 Missing dependency

set -euo pipefail

readonly PROGRAM_NAME="passwordless-sudo"
readonly VERSION="1.0.0"
readonly SUDOERS_FILE="/etc/sudoers"
readonly SUDOERS_DIR="/etc/sudoers.d"

EXECUTE=false
VERBOSE=false
TARGET_USER=""
GRANT_ALL=false
ACKNOWLEDGE_FULL_ROOT_ACCESS=false
declare -a ALLOWED_COMMANDS=()

TMP_DIR=""
POLICY_FILE=""
BACKUP_FILE=""

_usage() {
  cat <<'EOF'
Usage:
  passwordless-sudo grant --user USER --command /absolute/program [options]
  passwordless-sudo grant --user USER --all --acknowledge-full-root-access [options]
  passwordless-sudo status --user USER
  passwordless-sudo revoke --user USER [--execute]

Commands:
  grant       Create or replace this tool's policy for USER
  status      Display this tool's policy for USER
  revoke      Remove this tool's policy for USER

Options:
  --user USER                     Explicit local account to manage
  --command PATH                  Passwordless executable; repeatable
  --all                           Allow every command as every user/group
  --acknowledge-full-root-access  Required with --all
  --execute                       Apply the change; otherwise show a preview
  --dry-run                       Explicitly preview (the default)
  --verbose                       Show additional diagnostics
  -h, --help                      Show help
  -v, --version                   Show version

Safety:
  --all is equivalent to unrestricted passwordless root access. Prefer one or
  more --command entries wherever possible. A --command path permits that
  executable with arbitrary arguments, so programs with shell escapes or
  configuration-management powers may still provide effective root access.
  This utility never edits /etc/sudoers directly.
EOF
}

_log() {
  printf '%s: %s\n' "${PROGRAM_NAME}" "$*" >&2
}

_verbose() {
  [[ "${VERBOSE}" == true ]] && _log "$@" || true
}

_die() {
  local code="$1"
  shift
  _log "error: $*"
  exit "${code}"
}

_has_command() {
  command -v "$1" >/dev/null 2>&1
}

_require_command() {
  _has_command "$1" || _die 127 "missing dependency: $1"
}

_require_root_for_execute() {
  if [[ "${EXECUTE}" == true && "${EUID}" -ne 0 ]]; then
    _die 77 "applying this operation requires root; rerun it with sudo"
  fi
}

_cleanup() {
  [[ -z "${TMP_DIR}" || ! -d "${TMP_DIR}" ]] || rm -rf -- "${TMP_DIR}"
}

_init_workspace() {
  [[ -n "${TMP_DIR}" ]] && return 0
  TMP_DIR="$(mktemp -d "${TMPDIR:-/tmp}/${PROGRAM_NAME}.XXXXXX")"
}

_validate_user() {
  [[ -n "${TARGET_USER}" ]] || _die 2 "--user is required"
  [[ "${TARGET_USER}" =~ ^[a-zA-Z_][a-zA-Z0-9_-]*\$?$ ]] ||
    _die 2 "unsupported user name: ${TARGET_USER}"
  [[ "${TARGET_USER}" != root ]] ||
    _die 2 "root already has administrative access; a passwordless policy is unnecessary"

  if _has_command getent; then
    getent passwd "${TARGET_USER}" >/dev/null || _die 2 "unknown account: ${TARGET_USER}"
  else
    id "${TARGET_USER}" >/dev/null 2>&1 || _die 2 "unknown account: ${TARGET_USER}"
  fi

  if [[ -r /etc/passwd ]]; then
    awk -F: -v name="${TARGET_USER}" '$1 == name {found=1} END {exit !found}' /etc/passwd ||
      _die 2 "refusing to manage a non-local account: ${TARGET_USER}"
  fi
}

_validate_command_path() {
  local path="$1"
  [[ "${path}" == /* ]] || _die 2 "--command must be an absolute path: ${path}"
  [[ "${path}" != *[$'\n\r\t ,:\\']* ]] ||
    _die 2 "--command contains unsupported sudoers syntax characters: ${path}"
  if [[ -e "${path}" && ! -x "${path}" ]]; then
    _die 2 "command exists but is not executable: ${path}"
  fi
}

_policy_path() {
  local uid
  uid="$(id -u "${TARGET_USER}")" || _die 2 "could not resolve UID for ${TARGET_USER}"
  printf '%s/60-sanctuary-passwordless-%s\n' "${SUDOERS_DIR}" "${uid}"
}

_verify_sudoers_include() {
  local required="${1:-true}"
  [[ -r "${SUDOERS_FILE}" ]] || {
    if [[ "${required}" != true ]]; then
      _log "warning: cannot verify the sudoers.d include during an unprivileged preview"
      return 0
    fi
    [[ "${EUID}" -eq 0 ]] || _die 77 "cannot inspect ${SUDOERS_FILE}; rerun with sudo"
    _die 69 "cannot read ${SUDOERS_FILE}"
  }

  awk '
    /^[[:space:]]*([#@]includedir|@include)[[:space:]]+/ {
      if ($0 ~ /\/etc\/sudoers\.d/ || $0 ~ /\/private\/etc\/sudoers\.d/) found=1
    }
    END {exit !found}
  ' "${SUDOERS_FILE}" ||
    _die 69 "${SUDOERS_FILE} does not include ${SUDOERS_DIR}; refusing to edit the main file"
}

_generate_policy() {
  local destination="$1" command index
  {
    printf '%s\n' '# Managed by passwordless-sudo. Local edits may be replaced.'
    printf '# Account: %s\n' "${TARGET_USER}"
    if [[ "${GRANT_ALL}" == true ]]; then
      printf '%s ALL=(ALL:ALL) NOPASSWD: ALL\n' "${TARGET_USER}"
    else
      printf '%s ALL=(ALL:ALL) NOPASSWD: ' "${TARGET_USER}"
      for ((index = 0; index < ${#ALLOWED_COMMANDS[@]}; index += 1)); do
        ((index == 0)) || printf ', '
        command="${ALLOWED_COMMANDS[index]}"
        printf '%s' "${command}"
      done
      printf '\n'
    fi
  } >"${destination}"
  chmod 0440 "${destination}"
}

_validate_fragment() {
  local fragment="$1"
  _require_command visudo
  visudo -cf "${fragment}" >/dev/null || _die 1 "generated sudoers policy failed validation"
}

_preview_policy() {
  local generated="$1" existing="$2"
  printf '%s\n' "Target: ${existing}" >&2
  if [[ -f "${existing}" ]] && _has_command diff; then
    diff -u -- "${existing}" "${generated}" >&2 || true
  else
    sed 's/^/+ /' "${generated}" >&2
  fi
}

_backup_policy() {
  local source="$1" backup_dir
  [[ -e "${source}" ]] || return 0
  backup_dir="/var/backups/${PROGRAM_NAME}/$(date -u '+%Y%m%dT%H%M%SZ')-$$"
  install -d -o root -g root -m 0700 -- "${backup_dir}"
  BACKUP_FILE="${backup_dir}/$(basename -- "${source}")"
  cp -a -- "${source}" "${BACKUP_FILE}"
  _log "backup saved to ${BACKUP_FILE}"
}

_grant() {
  local generated
  _validate_user
  if [[ "${GRANT_ALL}" == true ]]; then
    ((${#ALLOWED_COMMANDS[@]} == 0)) || _die 2 "--all and --command are mutually exclusive"
    [[ "${ACKNOWLEDGE_FULL_ROOT_ACCESS}" == true ]] ||
      _die 77 "--all requires --acknowledge-full-root-access"
  else
    ((${#ALLOWED_COMMANDS[@]} > 0)) || _die 2 "grant requires --command or --all"
  fi

  local command
  for command in "${ALLOWED_COMMANDS[@]}"; do
    _validate_command_path "${command}"
  done

  _require_root_for_execute
  _verify_sudoers_include "${EXECUTE}"
  _init_workspace
  POLICY_FILE="$(_policy_path)"
  generated="${TMP_DIR}/policy"
  _generate_policy "${generated}"
  _validate_fragment "${generated}"
  _preview_policy "${generated}" "${POLICY_FILE}"

  if [[ "${EXECUTE}" == false ]]; then
    _log "preview only; pass --execute to install this policy"
    return 0
  fi

  _backup_policy "${POLICY_FILE}"
  install -d -o root -g root -m 0750 -- "${SUDOERS_DIR}"
  install -o root -g root -m 0440 -- "${generated}" "${POLICY_FILE}"

  if ! visudo -cf "${SUDOERS_FILE}" >/dev/null; then
    _log "installed configuration failed full validation; restoring previous state"
    if [[ -n "${BACKUP_FILE}" && -f "${BACKUP_FILE}" ]]; then
      cp -a -- "${BACKUP_FILE}" "${POLICY_FILE}"
    else
      rm -f -- "${POLICY_FILE}"
    fi
    _die 1 "policy was not installed"
  fi

  _log "installed ${POLICY_FILE}"
}

_status() {
  _validate_user
  POLICY_FILE="$(_policy_path)"
  if [[ ! -e "${POLICY_FILE}" ]]; then
    printf 'No managed passwordless-sudo policy for %s.\n' "${TARGET_USER}"
    return 1
  fi
  [[ -r "${POLICY_FILE}" ]] || _die 77 "cannot read ${POLICY_FILE}; rerun with sudo"
  printf 'Policy: %s\n' "${POLICY_FILE}"
  sed -n '1,120p' "${POLICY_FILE}"
}

_revoke() {
  _validate_user
  _require_root_for_execute
  _verify_sudoers_include "${EXECUTE}"
  POLICY_FILE="$(_policy_path)"
  if [[ ! -e "${POLICY_FILE}" ]]; then
    _log "no managed policy exists for ${TARGET_USER}"
    return 0
  fi
  if [[ "${EXECUTE}" == false ]]; then
    _log "would remove ${POLICY_FILE}"
    _log "preview only; pass --execute to revoke this policy"
    return 0
  fi

  _require_command visudo
  _backup_policy "${POLICY_FILE}"
  rm -f -- "${POLICY_FILE}"
  if ! visudo -cf "${SUDOERS_FILE}" >/dev/null; then
    cp -a -- "${BACKUP_FILE}" "${POLICY_FILE}"
    _die 1 "sudoers validation failed after removal; policy restored"
  fi
  _log "removed ${POLICY_FILE}"
}

_parse_options() {
  while (($#)); do
    case "$1" in
      --user|--command)
        (($# >= 2)) || _die 2 "$1 requires a value"
        if [[ "$1" == --user ]]; then
          [[ -z "${TARGET_USER}" ]] || _die 2 "--user may be specified only once"
          TARGET_USER="$2"
        else
          ALLOWED_COMMANDS+=("$2")
        fi
        shift 2
        ;;
      --all) GRANT_ALL=true; shift ;;
      --acknowledge-full-root-access) ACKNOWLEDGE_FULL_ROOT_ACCESS=true; shift ;;
      --execute) EXECUTE=true; shift ;;
      --dry-run) EXECUTE=false; shift ;;
      --verbose) VERBOSE=true; shift ;;
      -h|--help) _usage; exit 0 ;;
      -v|--version) printf '%s %s\n' "${PROGRAM_NAME}" "${VERSION}"; exit 0 ;;
      *) _die 2 "unknown option: $1" ;;
    esac
  done
  _verbose "mode: $([[ "${EXECUTE}" == true ]] && printf execute || printf preview)"
}

# @description Run the passwordless-sudo command-line application.
# @arg $@ string CLI arguments.
# @exitcode 0 Success.
# @exitcode 1 Operation or validation failure.
# @exitcode 2 Invalid usage.
# @exitcode 69 Unsupported sudoers configuration.
# @exitcode 77 Insufficient permission or missing acknowledgement.
# @exitcode 127 Missing dependency.
main() {
  local command
  (($#)) || { _usage; return 2; }
  case "$1" in
    -h|--help) _usage; return 0 ;;
    -v|--version) printf '%s %s\n' "${PROGRAM_NAME}" "${VERSION}"; return 0 ;;
  esac
  command="$1"
  shift
  _parse_options "$@"
  case "${command}" in
    grant) _grant ;;
    status) _status ;;
    revoke) _revoke ;;
    *) _die 2 "unknown command: ${command}" ;;
  esac
}

trap _cleanup EXIT
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM
main "$@"
