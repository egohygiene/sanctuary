#!/usr/bin/env bash
# shellcheck shell=bash
#
# harden-system - Audit and apply focused Linux host-hardening controls.
#
# Purpose:
#   Replace a collection of one-off hardening scripts with a guarded,
#   idempotent CLI. Mutating commands preview their work unless --execute is
#   supplied. Configuration is written to owned drop-in files where supported.
#
# Usage:
#   harden-system audit [--format text|json]
#   harden-system <command> [options] [--execute]
#
# Examples:
#   harden-system audit
#   sudo harden-system sysctl --execute
#   sudo harden-system firewall --allow-ssh --execute
#   sudo harden-system ssh --acknowledge-lockout-risk --execute
#   sudo harden-system account --user deploy --nologin --lock-password --execute
#
# Dependencies:
#   Required: Bash 4+, standard Linux userland
#   Optional by command: systemd, systemd-timesyncd, OpenSSH, UFW or firewalld,
#   USBGuard, AIDE, Lynis
#
# Exit codes:
#   0   Success
#   1   Audit found warnings or an operation failed
#   2   Invalid command-line usage
#   69  Unsupported platform or unavailable facility
#   77  Insufficient permission or missing safety acknowledgement
#   127 Missing dependency

set -euo pipefail

readonly PROGRAM_NAME="harden-system"
readonly VERSION="1.0.0"

EXECUTE=false
VERBOSE=false
USE_COLOR=true
INSTALL_MISSING=false
OUTPUT_FORMAT="text"
ACKNOWLEDGE_LOCKOUT_RISK=false

TMP_DIR=""
BACKUP_DIR=""

declare -a AUDIT_NAMES=()
declare -a AUDIT_STATES=()
declare -a AUDIT_DETAILS=()
declare -a REMAINING_ARGS=()

_usage() {
  cat <<'EOF'
Usage:
  harden-system audit [--format text|json]
  harden-system sysctl [--execute]
  harden-system limits [options] [--execute]
  harden-system timesync [options] [--execute]
  harden-system firewall [options] [--execute]
  harden-system ssh [options] --acknowledge-lockout-risk [--execute]
  harden-system usbguard --acknowledge-lockout-risk [--install-missing] [--execute]
  harden-system aide [--install-missing] [--execute]
  harden-system umask [options] [--execute]
  harden-system account [options] [--execute]
  harden-system lynis [--install-missing]
  harden-system systemd-delta

Commands:
  audit           Inspect hardening facilities without changing the system
  sysctl          Install conservative kernel/network sysctl settings
  limits          Install systemd manager resource-limit drop-ins
  timesync        Configure systemd-timesyncd and optionally the timezone
  firewall        Configure and enable UFW or firewalld safely
  ssh             Disable password-based SSH authentication
  usbguard        Initialize and enable USBGuard from currently attached devices
  aide            Initialize AIDE and enable aidecheck.timer when available
  umask           Install a system-wide shell umask and optional idle timeout
  account         Modify only explicitly named local accounts
  lynis           Run a Lynis system audit
  systemd-delta   Show local systemd overrides

Global options:
  --execute               Apply changes; otherwise mutation commands preview
  --dry-run               Explicitly preview (the default)
  --install-missing       Install a command's package using a known package manager
  --verbose               Show commands and additional diagnostics
  --no-color              Disable terminal colors
  -h, --help              Show help
  -v, --version           Show version

Run "harden-system <command> --help" for command-specific options.
EOF
}

_command_usage() {
  case "$1" in
    limits)
      cat <<'EOF'
Usage: harden-system limits [options]
  --nofile N              DefaultLimitNOFILE (default: 65536)
  --nproc N               DefaultLimitNPROC (default: 4096)
  --core N                DefaultLimitCORE (default: 0)
EOF
      ;;
    timesync)
      cat <<'EOF'
Usage: harden-system timesync [options]
  --ntp HOST              Preferred NTP host; repeatable
  --fallback-ntp HOST     Fallback NTP host; repeatable
  --timezone ZONE         Set a timezone recognized by timedatectl
EOF
      ;;
    firewall)
      cat <<'EOF'
Usage: harden-system firewall [options]
  --backend auto|ufw|firewalld
  --allow-ssh             Add an SSH rule before enabling the firewall
  --ssh-port PORT         SSH TCP port (default: 22)
  --ssh-source CIDR       Restrict SSH to a source address/network; repeatable

When invoked from SSH, --allow-ssh is mandatory. Existing unrelated firewall
rules are preserved.
EOF
      ;;
    ssh)
      cat <<'EOF'
Usage: harden-system ssh [options]
  --permit-root-login VALUE   no or prohibit-password (default: prohibit-password)
  --acknowledge-lockout-risk  Required acknowledgement

Disables PasswordAuthentication and KbdInteractiveAuthentication. The complete
OpenSSH configuration is validated before reload and restored on failure.
EOF
      ;;
    umask)
      cat <<'EOF'
Usage: harden-system umask [options]
  --value MASK             Shell umask (default: 027)
  --tmout SECONDS          Read-only interactive Bash timeout; 0 disables it
EOF
      ;;
    account)
      cat <<'EOF'
Usage: harden-system account --user NAME [--user NAME ...] [actions]
  --nologin                Set the account shell to nologin
  --lock-password          Lock the account password
  --acknowledge-lockout-risk
                            Required for root or the invoking administrator

At least one explicit user and one action are required. There is deliberately
no "all users" mode.
EOF
      ;;
    audit)
      printf '%s\n' 'Usage: harden-system audit [--format text|json]'
      ;;
    *) _usage ;;
  esac
}

_color_enabled() {
  [[ "${USE_COLOR}" == true && -t 2 && -z "${NO_COLOR:-}" ]]
}

_log() {
  local level="$1"
  shift
  local color="" reset=""
  if _color_enabled; then
    reset=$'\033[0m'
    case "${level}" in
      INFO) color=$'\033[36m' ;;
      OK) color=$'\033[32m' ;;
      WARN) color=$'\033[33m' ;;
      ERROR) color=$'\033[31m' ;;
    esac
  fi
  printf '%s%s: %s%s\n' "${color}" "${PROGRAM_NAME}" "$*" "${reset}" >&2
}

_info() { _log INFO "$@"; }
_success() { _log OK "$@"; }
_warn() { _log WARN "$@"; }

_die() {
  local code="$1"
  shift
  _log ERROR "$@"
  exit "${code}"
}

_has_command() {
  command -v "$1" >/dev/null 2>&1
}

_require_command() {
  _has_command "$1" || _die 127 "missing dependency: $1"
}

_require_linux() {
  ((BASH_VERSINFO[0] >= 4)) ||
    _die 69 "Bash 4 or newer is required (found ${BASH_VERSION})"
  [[ "$(uname -s)" == "Linux" ]] ||
    _die 69 "this command manages Linux facilities and is unsupported on $(uname -s)"
}

_require_root_for_execute() {
  if [[ "${EXECUTE}" == true && "${EUID}" -ne 0 ]]; then
    _die 77 "this operation requires root; rerun it with sudo"
  fi
}

_is_systemd() {
  [[ -d /run/systemd/system ]] && _has_command systemctl
}

_is_container() {
  [[ -f /.dockerenv ]] && return 0
  grep -qaE '(docker|containerd|kubepods|lxc)' /proc/1/cgroup 2>/dev/null
}

_quote_command() {
  local arg
  printf '  $'
  for arg in "$@"; do
    printf ' %q' "${arg}"
  done
  printf '\n'
}

_run() {
  if [[ "${VERBOSE}" == true || "${EXECUTE}" == false ]]; then
    _quote_command "$@" >&2
  fi
  [[ "${EXECUTE}" == true ]] || return 0
  "$@"
}

_init_workspace() {
  [[ -n "${TMP_DIR}" ]] && return 0
  TMP_DIR="$(mktemp -d "${TMPDIR:-/tmp}/${PROGRAM_NAME}.XXXXXX")"
  BACKUP_DIR="/var/backups/${PROGRAM_NAME}/$(date -u '+%Y%m%dT%H%M%SZ')"
}

_cleanup() {
  [[ -z "${TMP_DIR}" || ! -d "${TMP_DIR}" ]] || rm -rf -- "${TMP_DIR}"
}

_show_change() {
  local source="$1" destination="$2"
  printf '\n%s\n' "--- ${destination}" >&2
  if [[ -f "${destination}" ]] && _has_command diff; then
    diff -u -- "${destination}" "${source}" >&2 || true
  else
    sed 's/^/+ /' "${source}" >&2
  fi
}

_backup_file() {
  local path="$1" backup
  [[ -e "${path}" ]] || return 0
  backup="${BACKUP_DIR}${path}"
  install -d -m 0700 -- "$(dirname -- "${backup}")"
  cp -a -- "${path}" "${backup}"
  _info "backup saved to ${backup}"
}

_install_managed_file() {
  local source="$1" destination="$2" mode="${3:-0644}"
  if [[ -f "${destination}" ]] && cmp -s -- "${source}" "${destination}"; then
    _info "already current: ${destination}"
    return 0
  fi
  _show_change "${source}" "${destination}"
  [[ "${EXECUTE}" == true ]] || return 0
  _backup_file "${destination}"
  install -d -m 0755 -- "$(dirname -- "${destination}")"
  install -o root -g root -m "${mode}" -- "${source}" "${destination}"
  _success "installed ${destination}"
}

_validate_integer() {
  local name="$1" value="$2" minimum="${3:-0}" maximum="${4:-2147483647}"
  [[ "${value}" =~ ^[0-9]+$ ]] || _die 2 "${name} must be an integer"
  ((value >= minimum && value <= maximum)) ||
    _die 2 "${name} must be between ${minimum} and ${maximum}"
}

_validate_port() {
  _validate_integer "port" "$1" 1 65535
}

_validate_umask() {
  [[ "$1" =~ ^0?[0-7]{3}$ ]] || _die 2 "umask must be a three- or four-digit octal value"
}

_validate_hostname() {
  [[ "$1" =~ ^[A-Za-z0-9._:-]+$ ]] || _die 2 "invalid NTP host: $1"
}

_package_manager() {
  local manager
  for manager in apt-get dnf yum zypper pacman; do
    if _has_command "${manager}"; then
      printf '%s\n' "${manager}"
      return 0
    fi
  done
  return 1
}

_install_package() {
  local package="$1" manager
  if [[ "${INSTALL_MISSING}" != true ]]; then
    _die 127 "${package} is not installed; install it or pass --install-missing"
  fi
  manager="$(_package_manager)" || _die 127 "no supported package manager found"
  case "${manager}" in
    apt-get)
      _run apt-get update
      _run apt-get install -y --no-install-recommends "${package}"
      ;;
    dnf|yum) _run "${manager}" install -y "${package}" ;;
    zypper) _run zypper --non-interactive install "${package}" ;;
    pacman) _run pacman --sync --needed --noconfirm "${package}" ;;
  esac
}

_audit_add() {
  AUDIT_NAMES+=("$1")
  AUDIT_STATES+=("$2")
  AUDIT_DETAILS+=("$3")
}

_json_escape() {
  local value="$1"
  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  value=${value//$'\n'/\\n}
  value=${value//$'\r'/\\r}
  value=${value//$'\t'/\\t}
  printf '%s' "${value}"
}

_render_audit() {
  local index failed=0
  if [[ "${OUTPUT_FORMAT}" == "json" ]]; then
    printf '[\n'
    for ((index = 0; index < ${#AUDIT_NAMES[@]}; index += 1)); do
      ((index == 0)) || printf ',\n'
      printf '  {"check":"%s","status":"%s","detail":"%s"}' \
        "$(_json_escape "${AUDIT_NAMES[index]}")" \
        "$(_json_escape "${AUDIT_STATES[index]}")" \
        "$(_json_escape "${AUDIT_DETAILS[index]}")"
      [[ "${AUDIT_STATES[index]}" == "warn" ]] && failed=1
    done
    printf '\n]\n'
  else
    printf '%-20s %-8s %s\n' CHECK STATUS DETAIL
    printf '%-20s %-8s %s\n' '--------------------' '--------' '------'
    for ((index = 0; index < ${#AUDIT_NAMES[@]}; index += 1)); do
      printf '%-20s %-8s %s\n' \
        "${AUDIT_NAMES[index]}" "${AUDIT_STATES[index]}" "${AUDIT_DETAILS[index]}"
      [[ "${AUDIT_STATES[index]}" == "warn" ]] && failed=1
    done
  fi
  return "${failed}"
}

_audit_system() {
  local value
  _audit_add platform pass "$(uname -srmo 2>/dev/null || uname -a)"

  if _is_container; then
    _audit_add environment info "container detected; some host controls are inapplicable"
  else
    _audit_add environment pass "host or virtual machine"
  fi

  if _is_systemd; then
    _audit_add init pass "systemd"
  else
    _audit_add init warn "systemd is not PID 1 or systemctl is unavailable"
  fi

  [[ -f /etc/sysctl.d/60-sanctuary-hardening.conf ]] &&
    _audit_add sysctl pass "managed drop-in installed" ||
    _audit_add sysctl info "managed drop-in not installed"

  if _has_command timedatectl; then
    value="$(timedatectl show -p NTPSynchronized --value 2>/dev/null || printf unknown)"
    [[ "${value}" == yes ]] &&
      _audit_add time-sync pass "clock synchronized" ||
      _audit_add time-sync warn "NTPSynchronized=${value}"
  else
    _audit_add time-sync info "timedatectl unavailable"
  fi

  if _has_command sshd; then
    value="$(sshd -T 2>/dev/null | awk '$1 == "passwordauthentication" {print $2; exit}')"
    [[ "${value}" == no ]] &&
      _audit_add ssh-password pass "disabled" ||
      _audit_add ssh-password warn "effective value: ${value:-unknown}"
  else
    _audit_add ssh-password info "OpenSSH server not installed"
  fi

  if _has_command ufw; then
    value="$(ufw status 2>/dev/null | awk -F': ' '/^Status:/ {print $2; exit}')"
    [[ "${value}" == active ]] &&
      _audit_add firewall pass "ufw active" ||
      _audit_add firewall warn "ufw ${value:-status unavailable}"
  elif _has_command firewall-cmd; then
    if firewall-cmd --state >/dev/null 2>&1; then
      _audit_add firewall pass "firewalld active"
    else
      _audit_add firewall warn "firewalld installed but inactive"
    fi
  else
    _audit_add firewall warn "neither ufw nor firewalld found"
  fi

  if _has_command usbguard; then
    if _is_systemd && systemctl is-active --quiet usbguard.service; then
      _audit_add usbguard pass "service active"
    else
      _audit_add usbguard info "installed but inactive"
    fi
  else
    _audit_add usbguard info "not installed"
  fi

  if _has_command aide || _has_command aideinit; then
    _audit_add aide pass "installed"
  else
    _audit_add aide info "not installed"
  fi

  _has_command lynis && _audit_add lynis pass "installed" ||
    _audit_add lynis info "not installed"

  [[ -f /etc/profile.d/60-sanctuary-umask.sh ]] &&
    _audit_add shell-umask pass "managed profile installed" ||
    _audit_add shell-umask info "managed profile not installed"

  [[ -f /etc/systemd/system.conf.d/60-sanctuary-limits.conf ]] &&
    _audit_add systemd-limits pass "managed drop-in installed" ||
    _audit_add systemd-limits info "managed drop-in not installed"
}

_apply_sysctl() {
  local config
  _require_linux
  _require_command sysctl
  _require_root_for_execute
  _init_workspace
  config="${TMP_DIR}/60-sanctuary-hardening.conf"
  cat >"${config}" <<'EOF'
# Managed by harden-system. Local edits may be replaced.

# Limit kernel information exposure.
-kernel.dmesg_restrict = 1
-kernel.kptr_restrict = 2
-kernel.yama.ptrace_scope = 1

# Protect links and special files in world-writable directories.
-fs.protected_hardlinks = 1
-fs.protected_symlinks = 1
-fs.protected_fifos = 2
-fs.protected_regular = 2

# Reject ICMP redirects and avoid sending IPv4 redirects.
net.ipv4.conf.all.accept_redirects = 0
net.ipv4.conf.default.accept_redirects = 0
net.ipv4.conf.all.secure_redirects = 0
net.ipv4.conf.default.secure_redirects = 0
net.ipv4.conf.all.send_redirects = 0
net.ipv4.conf.default.send_redirects = 0
-net.ipv6.conf.all.accept_redirects = 0
-net.ipv6.conf.default.accept_redirects = 0

# Basic network-stack safeguards.
net.ipv4.icmp_echo_ignore_broadcasts = 1
net.ipv4.icmp_ignore_bogus_error_responses = 1
net.ipv4.tcp_syncookies = 1
EOF
  _install_managed_file "${config}" /etc/sysctl.d/60-sanctuary-hardening.conf
  _run sysctl --system
}

_apply_limits() {
  local nofile=65536 nproc=4096 core=0 config option
  while (($#)); do
    option="$1"
    case "${option}" in
      --nofile|--nproc|--core)
        (($# >= 2)) || _die 2 "${option} requires a value"
        case "${option}" in
          --nofile) nofile="$2" ;;
          --nproc) nproc="$2" ;;
          --core) core="$2" ;;
        esac
        shift 2
        ;;
      -h|--help) _command_usage limits; return 0 ;;
      *) _die 2 "unknown limits option: ${option}" ;;
    esac
  done
  _validate_integer nofile "${nofile}" 1024
  _validate_integer nproc "${nproc}" 256
  _validate_integer core "${core}" 0
  _require_linux
  _is_systemd || _die 69 "systemd is required for limits"
  _require_root_for_execute
  _init_workspace
  config="${TMP_DIR}/60-sanctuary-limits.conf"
  cat >"${config}" <<EOF
# Managed by harden-system. Local edits may be replaced.
[Manager]
DefaultLimitCORE=${core}
DefaultLimitNOFILE=${nofile}
DefaultLimitNPROC=${nproc}
EOF
  _install_managed_file "${config}" /etc/systemd/system.conf.d/60-sanctuary-limits.conf
  _install_managed_file "${config}" /etc/systemd/user.conf.d/60-sanctuary-limits.conf
  _run systemctl daemon-reexec
}

_apply_timesync() {
  local timezone="" option config
  local -a ntp=() fallback_ntp=()
  while (($#)); do
    option="$1"
    case "${option}" in
      --ntp|--fallback-ntp|--timezone)
        (($# >= 2)) || _die 2 "${option} requires a value"
        case "${option}" in
          --ntp) ntp+=("$2") ;;
          --fallback-ntp) fallback_ntp+=("$2") ;;
          --timezone) timezone="$2" ;;
        esac
        shift 2
        ;;
      -h|--help) _command_usage timesync; return 0 ;;
      *) _die 2 "unknown timesync option: ${option}" ;;
    esac
  done
  ((${#ntp[@]})) || ntp=(pool.ntp.org)
  ((${#fallback_ntp[@]})) || fallback_ntp=(time.cloudflare.com time.google.com)
  local host
  for host in "${ntp[@]}" "${fallback_ntp[@]}"; do _validate_hostname "${host}"; done
  _require_linux
  _is_systemd || _die 69 "systemd is required for timesync"
  _require_command timedatectl
  _require_root_for_execute
  if [[ -n "${timezone}" ]] && ! timedatectl list-timezones 2>/dev/null | grep -Fxq -- "${timezone}"; then
    _die 2 "unknown timezone: ${timezone}"
  fi
  _init_workspace
  config="${TMP_DIR}/60-sanctuary.conf"
  cat >"${config}" <<EOF
# Managed by harden-system. Local edits may be replaced.
[Time]
NTP=${ntp[*]}
FallbackNTP=${fallback_ntp[*]}
EOF
  _install_managed_file "${config}" /etc/systemd/timesyncd.conf.d/60-sanctuary.conf
  [[ -z "${timezone}" ]] || _run timedatectl set-timezone "${timezone}"
  _run systemctl enable --now systemd-timesyncd.service
  _run systemctl restart systemd-timesyncd.service
}

_detect_firewall() {
  local requested="$1"
  if [[ "${requested}" != auto ]]; then
    printf '%s\n' "${requested}"
  elif _has_command ufw && ufw status 2>/dev/null | grep -q '^Status: active'; then
    printf '%s\n' ufw
  elif _has_command firewall-cmd && firewall-cmd --state >/dev/null 2>&1; then
    printf '%s\n' firewalld
  elif _has_command ufw; then
    printf '%s\n' ufw
  elif _has_command firewall-cmd; then
    printf '%s\n' firewalld
  else
    return 1
  fi
}

_apply_firewall() {
  local backend=auto allow_ssh=false ssh_port=22 option selected
  local -a ssh_sources=()
  while (($#)); do
    option="$1"
    case "${option}" in
      --backend|--ssh-port|--ssh-source)
        (($# >= 2)) || _die 2 "${option} requires a value"
        case "${option}" in
          --backend) backend="$2" ;;
          --ssh-port) ssh_port="$2" ;;
          --ssh-source) ssh_sources+=("$2") ;;
        esac
        shift 2
        ;;
      --allow-ssh) allow_ssh=true; shift ;;
      -h|--help) _command_usage firewall; return 0 ;;
      *) _die 2 "unknown firewall option: ${option}" ;;
    esac
  done
  [[ "${backend}" =~ ^(auto|ufw|firewalld)$ ]] || _die 2 "invalid firewall backend: ${backend}"
  _validate_port "${ssh_port}"
  ((${#ssh_sources[@]} == 0)) || [[ "${allow_ssh}" == true ]] ||
    _die 2 "--ssh-source requires --allow-ssh"
  if [[ -n "${SSH_CONNECTION:-}" && "${allow_ssh}" != true ]]; then
    _die 77 "an SSH session is active; pass --allow-ssh to prevent lockout"
  fi
  _require_linux
  _require_root_for_execute
  selected="$(_detect_firewall "${backend}")" ||
    _die 127 "neither ufw nor firewalld is installed"
  _info "selected firewall backend: ${selected}"

  if [[ "${selected}" == ufw ]]; then
    _require_command ufw
    if [[ "${allow_ssh}" == true ]]; then
      if ((${#ssh_sources[@]})); then
        local source
        for source in "${ssh_sources[@]}"; do
          _run ufw allow proto tcp from "${source}" to any port "${ssh_port}" comment "${PROGRAM_NAME} ssh"
        done
      else
        _run ufw limit "${ssh_port}/tcp" comment "${PROGRAM_NAME} ssh"
      fi
    fi
    _run ufw default deny incoming
    _run ufw default allow outgoing
    _run ufw logging low
    _run ufw --force enable
    _run ufw status verbose
  else
    _require_command firewall-cmd
    local firewall_command=firewall-cmd
    local -a permanent_option=(--permanent)
    if ! firewall-cmd --state >/dev/null 2>&1; then
      _require_command firewall-offline-cmd
      firewall_command=firewall-offline-cmd
      permanent_option=()
      _info "firewalld is inactive; staging permanent rules before startup"
    fi
    if [[ "${allow_ssh}" == true ]]; then
      if ((${#ssh_sources[@]})); then
        local source family
        for source in "${ssh_sources[@]}"; do
          family=ipv4
          [[ "${source}" != *:* ]] || family=ipv6
          _run "${firewall_command}" "${permanent_option[@]}" --add-rich-rule="rule family=${family} source address=${source} port port=${ssh_port} protocol=tcp accept"
        done
      elif [[ "${ssh_port}" == 22 ]]; then
        _run "${firewall_command}" "${permanent_option[@]}" --add-service=ssh
      else
        _run "${firewall_command}" "${permanent_option[@]}" --add-port="${ssh_port}/tcp"
      fi
    fi
    _run systemctl enable --now firewalld.service
    [[ "${firewall_command}" != firewall-cmd ]] || _run firewall-cmd --reload
    _run firewall-cmd --list-all
  fi
}

_reload_sshd() {
  if _is_systemd; then
    if systemctl list-unit-files sshd.service >/dev/null 2>&1; then
      systemctl reload sshd.service
    elif systemctl list-unit-files ssh.service >/dev/null 2>&1; then
      systemctl reload ssh.service
    else
      _warn "OpenSSH configuration is valid, but no SSH service unit was found"
    fi
  elif _has_command service; then
    service ssh reload
  else
    _warn "OpenSSH configuration is valid; reload the SSH daemon manually"
  fi
}

_apply_ssh() {
  local root_login=prohibit-password option config destination effective_password effective_keyboard effective_root
  while (($#)); do
    option="$1"
    case "${option}" in
      --permit-root-login)
        (($# >= 2)) || _die 2 "${option} requires a value"
        root_login="$2"
        shift 2
        ;;
      -h|--help) _command_usage ssh; return 0 ;;
      *) _die 2 "unknown ssh option: ${option}" ;;
    esac
  done
  [[ "${root_login}" =~ ^(no|prohibit-password)$ ]] ||
    _die 2 "--permit-root-login must be no or prohibit-password"
  [[ "${ACKNOWLEDGE_LOCKOUT_RISK}" == true ]] ||
    _die 77 "SSH changes require --acknowledge-lockout-risk"
  _require_linux
  _require_command sshd
  _require_root_for_execute
  [[ -d /etc/ssh/sshd_config.d ]] ||
    _die 69 "/etc/ssh/sshd_config.d is unavailable; this tool will not edit sshd_config directly"
  _init_workspace
  config="${TMP_DIR}/60-sanctuary-hardening.conf"
  destination=/etc/ssh/sshd_config.d/60-sanctuary-hardening.conf
  cat >"${config}" <<EOF
# Managed by harden-system. Local edits may be replaced.
PasswordAuthentication no
KbdInteractiveAuthentication no
PermitRootLogin ${root_login}
EOF
  _install_managed_file "${config}" "${destination}" 0600
  [[ "${EXECUTE}" == true ]] || return 0
  effective_password="$(sshd -T 2>/dev/null | awk '$1 == "passwordauthentication" {print $2; exit}')"
  effective_keyboard="$(sshd -T 2>/dev/null | awk '$1 == "kbdinteractiveauthentication" {print $2; exit}')"
  effective_root="$(sshd -T 2>/dev/null | awk '$1 == "permitrootlogin" {print $2; exit}')"
  if ! sshd -t || [[ "${effective_password}" != no || "${effective_keyboard}" != no || "${effective_root}" != "${root_login}" ]]; then
    _log ERROR "OpenSSH validation failed or the managed settings are overridden; restoring the previous configuration"
    if [[ -f "${BACKUP_DIR}${destination}" ]]; then
      cp -a -- "${BACKUP_DIR}${destination}" "${destination}"
    else
      rm -f -- "${destination}"
    fi
    _die 1 "SSH configuration was not applied"
  fi
  _reload_sshd
  _success "SSH password authentication disabled"
}

_apply_usbguard() {
  local policy
  [[ "${ACKNOWLEDGE_LOCKOUT_RISK}" == true ]] ||
    _die 77 "USBGuard requires --acknowledge-lockout-risk"
  _require_linux
  _is_container && _die 69 "USBGuard is not applicable inside a container"
  _is_systemd || _die 69 "systemd is required for USBGuard management"
  _require_root_for_execute
  _has_command usbguard || _install_package usbguard
  [[ "${EXECUTE}" == false ]] || _require_command usbguard
  _init_workspace
  policy="${TMP_DIR}/usbguard.rules"
  if [[ "${EXECUTE}" == true ]]; then
    usbguard generate-policy >"${policy}"
  else
    printf '%s\n' '# Generated from currently attached USB devices at execution time.' >"${policy}"
  fi
  _install_managed_file "${policy}" /etc/usbguard/rules.conf 0600
  _run systemctl enable --now usbguard.service
}

_apply_aide() {
  _require_linux
  _require_root_for_execute
  if ! _has_command aideinit && ! _has_command aide; then
    _install_package aide
  fi
  if [[ "${EXECUTE}" == false ]]; then
    _info "would initialize the AIDE database"
    _is_systemd && _info "would enable aidecheck.timer when installed"
    return 0
  fi
  if _has_command aideinit; then
    aideinit --yes
  else
    _die 69 "this AIDE package has no aideinit helper; initialize it according to the distribution's database layout"
  fi
  if [[ -x /etc/cron.daily/aide ]]; then
    _info "AIDE is already scheduled by /etc/cron.daily/aide"
  elif _is_systemd && systemctl list-unit-files aidecheck.timer >/dev/null 2>&1; then
    systemctl enable --now aidecheck.timer
  else
    _warn "AIDE initialized, but no cron job or aidecheck.timer was found; schedule checks manually"
  fi
}

_apply_umask() {
  local value=027 tmout=0 option config
  while (($#)); do
    option="$1"
    case "${option}" in
      --value|--tmout)
        (($# >= 2)) || _die 2 "${option} requires a value"
        case "${option}" in
          --value) value="$2" ;;
          --tmout) tmout="$2" ;;
        esac
        shift 2
        ;;
      -h|--help) _command_usage umask; return 0 ;;
      *) _die 2 "unknown umask option: ${option}" ;;
    esac
  done
  _validate_umask "${value}"
  _validate_integer tmout "${tmout}" 0 86400
  _require_linux
  _require_root_for_execute
  _init_workspace
  config="${TMP_DIR}/60-sanctuary-umask.sh"
  {
    printf '%s\n' '# Managed by harden-system. Local edits may be replaced.'
    printf 'umask %s\n' "${value}"
    if ((tmout > 0)); then
      cat <<EOF
# TMOUT is honored by interactive Bash; other POSIX shells ignore it.
case \$- in
  *i*)
    TMOUT=${tmout}
    readonly TMOUT
    export TMOUT
    ;;
esac
EOF
    fi
  } >"${config}"
  _install_managed_file "${config}" /etc/profile.d/60-sanctuary-umask.sh 0644
}

_account_shell() {
  if [[ -x /usr/sbin/nologin ]]; then
    printf '%s\n' /usr/sbin/nologin
  elif [[ -x /sbin/nologin ]]; then
    printf '%s\n' /sbin/nologin
  elif [[ -x /bin/false ]]; then
    printf '%s\n' /bin/false
  else
    return 1
  fi
}

_apply_account() {
  local set_nologin=false lock_password=false option shell invoking_user
  local -a users=()
  while (($#)); do
    option="$1"
    case "${option}" in
      --user)
        (($# >= 2)) || _die 2 "${option} requires a value"
        users+=("$2")
        shift 2
        ;;
      --nologin) set_nologin=true; shift ;;
      --lock-password) lock_password=true; shift ;;
      -h|--help) _command_usage account; return 0 ;;
      *) _die 2 "unknown account option: ${option}" ;;
    esac
  done
  ((${#users[@]})) || _die 2 "account requires at least one --user"
  [[ "${set_nologin}" == true || "${lock_password}" == true ]] ||
    _die 2 "account requires --nologin and/or --lock-password"
  _require_linux
  _require_command getent
  _require_root_for_execute
  shell="$(_account_shell)" || _die 127 "no nologin-compatible shell found"
  invoking_user="${SUDO_USER:-${USER:-}}"
  local user
  for user in "${users[@]}"; do
    getent passwd "${user}" >/dev/null || _die 2 "unknown account: ${user}"
    awk -F: -v name="${user}" '$1 == name {found=1} END {exit !found}' /etc/passwd ||
      _die 2 "refusing non-local account: ${user}"
    if [[ "${user}" == root || "${user}" == "${invoking_user}" ]]; then
      [[ "${ACKNOWLEDGE_LOCKOUT_RISK}" == true ]] ||
        _die 77 "changing ${user} requires --acknowledge-lockout-risk"
    fi
  done
  for user in "${users[@]}"; do
    [[ "${set_nologin}" != true ]] || _run usermod --shell "${shell}" "${user}"
    [[ "${lock_password}" != true ]] || _run passwd --lock "${user}"
  done
}

_run_lynis() {
  _require_linux
  _has_command lynis || _install_package lynis
  if [[ "${EXECUTE}" == false && ! -x "$(command -v lynis 2>/dev/null || true)" ]]; then
    _info "would run: lynis audit system --quick --no-colors"
    return 0
  fi
  _require_command lynis
  lynis audit system --quick --no-colors
}

_show_systemd_delta() {
  _require_linux
  _require_command systemd-delta
  systemd-delta --no-pager
}

_parse_global_options() {
  local -a remaining=()
  while (($#)); do
    case "$1" in
      --execute) EXECUTE=true ;;
      --dry-run) EXECUTE=false ;;
      --install-missing) INSTALL_MISSING=true ;;
      --acknowledge-lockout-risk) ACKNOWLEDGE_LOCKOUT_RISK=true ;;
      --verbose) VERBOSE=true ;;
      --no-color) USE_COLOR=false ;;
      --format)
        (($# >= 2)) || _die 2 "--format requires a value"
        OUTPUT_FORMAT="$2"
        shift
        ;;
      -v|--version)
        printf '%s %s\n' "${PROGRAM_NAME}" "${VERSION}"
        exit 0
        ;;
      -h|--help) remaining+=("$1") ;;
      *) remaining+=("$1") ;;
    esac
    shift
  done
  [[ "${OUTPUT_FORMAT}" =~ ^(text|json)$ ]] || _die 2 "--format must be text or json"
  REMAINING_ARGS=("${remaining[@]}")
}

# @description Run the harden-system command-line application.
# @arg $@ string CLI arguments.
# @exitcode 0 Success.
# @exitcode 1 Audit warning or operational failure.
# @exitcode 2 Invalid usage.
# @exitcode 69 Unsupported platform or facility.
# @exitcode 77 Insufficient permission or missing safety acknowledgement.
# @exitcode 127 Missing dependency.
main() {
  local command
  REMAINING_ARGS=()
  (($#)) || { _usage; return 2; }
  case "$1" in
    -h|--help) _usage; return 0 ;;
    -v|--version) printf '%s %s\n' "${PROGRAM_NAME}" "${VERSION}"; return 0 ;;
  esac
  command="$1"
  shift
  _parse_global_options "$@"
  set -- "${REMAINING_ARGS[@]}"

  if (($# == 1)) && [[ "$1" == "-h" || "$1" == "--help" ]]; then
    _command_usage "${command}"
    return 0
  fi

  case "${command}" in
    audit|status)
      (($# == 0)) || _die 2 "audit accepts only global options"
      _require_linux
      _audit_system
      _render_audit
      ;;
    sysctl) (($# == 0)) || _die 2 "sysctl accepts only global options"; _apply_sysctl ;;
    limits) _apply_limits "$@" ;;
    timesync) _apply_timesync "$@" ;;
    firewall) _apply_firewall "$@" ;;
    ssh) _apply_ssh "$@" ;;
    usbguard) (($# == 0)) || _die 2 "usbguard accepts only global options"; _apply_usbguard ;;
    aide) (($# == 0)) || _die 2 "aide accepts only global options"; _apply_aide ;;
    umask) _apply_umask "$@" ;;
    account) _apply_account "$@" ;;
    lynis) (($# == 0)) || _die 2 "lynis accepts only global options"; _run_lynis ;;
    systemd-delta|delta) (($# == 0)) || _die 2 "systemd-delta accepts no options"; _show_systemd_delta ;;
    help) _usage ;;
    *) _die 2 "unknown command: ${command}" ;;
  esac
}

trap _cleanup EXIT
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM
main "$@"
