#!/usr/bin/env python3
"""Hash and verify passwords with bcrypt without exposing them in argv."""

from __future__ import annotations

import argparse
import getpass
import hmac
import importlib
import os
import subprocess
import sys
from typing import Any, Optional, Sequence


PROGRAM_NAME = "bcrypt-password"
VERSION = "1.0.0"
DEFAULT_ROUNDS = 12
MAX_PASSWORD_BYTES = 72
MIN_ROUNDS = 4
MAX_ROUNDS = 16


class CliError(Exception):
    """An expected command failure with a stable process exit code."""

    def __init__(self, message: str, exit_code: int) -> None:
        super().__init__(message)
        self.exit_code = exit_code


def rounds_value(value: str) -> int:
    """Parse a bounded bcrypt logarithmic work factor."""

    try:
        rounds = int(value)
    except ValueError as error:
        raise argparse.ArgumentTypeError("must be an integer") from error
    if not MIN_ROUNDS <= rounds <= MAX_ROUNDS:
        raise argparse.ArgumentTypeError(
            f"must be between {MIN_ROUNDS} and {MAX_ROUNDS}"
        )
    return rounds


def add_password_source_options(parser: argparse.ArgumentParser) -> None:
    """Add mutually exclusive password-input options to a subcommand parser."""

    source_group = parser.add_mutually_exclusive_group()
    source_group.add_argument(
        "--stdin",
        action="store_true",
        help="read one password line from standard input",
    )
    source_group.add_argument(
        "--password-env",
        metavar="VARIABLE",
        help="read the password from an environment variable",
    )
    parser.add_argument(
        "--allow-empty", action="store_true", help="permit an empty password"
    )


def build_parser() -> argparse.ArgumentParser:
    """Create and return the command-line parser."""

    parser = argparse.ArgumentParser(
        prog=PROGRAM_NAME,
        description=(
            "Hash and verify UTF-8 passwords using bcrypt. Passwords are read "
            "from a hidden terminal prompt by default and are never accepted "
            "as positional command-line arguments."
        ),
        epilog=(
            "Examples:\n"
            "  bcrypt-password hash\n"
            "  bcrypt-password hash --rounds 13\n"
            "  printf '%s\\n' \"$PASSWORD\" | bcrypt-password hash --stdin\n"
            "  bcrypt-password verify '$2b$12$...'\n"
            "  bcrypt-password verify --quiet '$2b$12$...'\n\n"
            "Security:\n"
            "  bcrypt processes at most 72 password bytes. This command rejects "
            "longer UTF-8 input instead of silently truncating it. --stdin and "
            "--password-env are intended for controlled automation; a hidden "
            "interactive prompt is safer for manual use.\n\n"
            "Dependencies:\n"
            "  Python 3.8+ and the PyCA bcrypt package. If bcrypt is missing, an "
            "interactive terminal may offer to install it with this interpreter's "
            "pip after explicit confirmation.\n\n"
            "Exit codes:\n"
            "  0    Hash created or password matched.\n"
            "  1    Password did not match during verification.\n"
            "  2    Invalid command-line usage.\n"
            "  3    Password input was unavailable or invalid.\n"
            "  4    Hash parsing or bcrypt processing failed.\n"
            "  127  The bcrypt dependency is unavailable or installation failed.\n"
            "  130  Interrupted by the user."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "--no-install-prompt",
        action="store_true",
        help="do not offer to install bcrypt when it is missing",
    )
    parser.add_argument(
        "--version", action="version", version=f"%(prog)s {VERSION}"
    )

    subparsers = parser.add_subparsers(dest="command", required=True)

    hash_parser = subparsers.add_parser(
        "hash", help="create a salted bcrypt password hash"
    )
    add_password_source_options(hash_parser)
    hash_parser.add_argument(
        "--rounds",
        type=rounds_value,
        default=DEFAULT_ROUNDS,
        help=f"logarithmic work factor from {MIN_ROUNDS} to {MAX_ROUNDS} "
        f"(default: {DEFAULT_ROUNDS})",
    )
    hash_parser.add_argument(
        "--no-confirm",
        action="store_true",
        help="do not request confirmation for an interactive password",
    )

    verify_parser = subparsers.add_parser(
        "verify", help="verify a password against an existing bcrypt hash"
    )
    add_password_source_options(verify_parser)
    verify_parser.add_argument("hash", help="encoded bcrypt hash to verify")
    verify_parser.add_argument(
        "-q",
        "--quiet",
        action="store_true",
        help="report the result through the exit status only",
    )
    return parser


def running_in_virtual_environment() -> bool:
    """Return whether the current interpreter appears to be in a virtualenv."""

    return sys.prefix != getattr(sys, "base_prefix", sys.prefix)


def import_bcrypt(*, allow_prompt: bool) -> Any:
    """Import bcrypt or offer an explicitly approved pip installation."""

    try:
        return importlib.import_module("bcrypt")
    except ImportError as import_error:
        interactive = sys.stdin.isatty() and sys.stderr.isatty()
        if allow_prompt and interactive:
            print(
                f"{PROGRAM_NAME}: the required 'bcrypt' package is not installed.",
                file=sys.stderr,
            )
            response = input(
                f"Install bcrypt using {sys.executable} -m pip? [y/N] "
            ).strip().lower()
            if response in {"y", "yes"}:
                command = [sys.executable, "-m", "pip", "install"]
                if not running_in_virtual_environment():
                    command.append("--user")
                command.append("bcrypt")
                try:
                    subprocess.run(command, check=True)
                except (OSError, subprocess.CalledProcessError) as error:
                    raise CliError(
                        f"bcrypt installation failed: {error}", 127
                    ) from error
                importlib.invalidate_caches()
                try:
                    return importlib.import_module("bcrypt")
                except ImportError as retry_error:
                    raise CliError(
                        "bcrypt installation completed but the package is still unavailable",
                        127,
                    ) from retry_error

        raise CliError(
            "the 'bcrypt' package is required; install it with: "
            f"{sys.executable} -m pip install bcrypt",
            127,
        ) from import_error


def read_password_line() -> str:
    """Read exactly one text line from standard input."""

    line = sys.stdin.readline()
    if line == "":
        raise CliError("standard input ended before a password was read", 3)
    return line.rstrip("\r\n")


def read_password(
    args: argparse.Namespace, *, prompt: str, confirm: bool = False
) -> bytes:
    """Read, optionally confirm, encode, and validate a password."""

    if args.stdin:
        password = read_password_line()
    elif args.password_env:
        if args.password_env not in os.environ:
            raise CliError(
                f"password environment variable is not set: {args.password_env}", 3
            )
        password = os.environ[args.password_env]
    else:
        try:
            password = getpass.getpass(prompt)
            if confirm:
                confirmation = getpass.getpass("Confirm password: ")
                if not hmac.compare_digest(password, confirmation):
                    raise CliError("passwords did not match", 3)
        except EOFError as error:
            raise CliError("could not read a password from the terminal", 3) from error

    if not password and not args.allow_empty:
        raise CliError("empty passwords are rejected; pass --allow-empty to permit one", 3)
    encoded = password.encode("utf-8")
    if len(encoded) > MAX_PASSWORD_BYTES:
        raise CliError(
            f"password is {len(encoded)} UTF-8 bytes; bcrypt accepts at most "
            f"{MAX_PASSWORD_BYTES}",
            3,
        )
    return encoded


def validate_hash(encoded_hash: str) -> bytes:
    """Encode and structurally validate a bcrypt modular crypt hash."""

    try:
        hash_bytes = encoded_hash.encode("ascii")
    except UnicodeEncodeError as error:
        raise CliError("bcrypt hash must contain ASCII characters only", 4) from error
    if len(hash_bytes) != 60 or not hash_bytes.startswith((b"$2a$", b"$2b$", b"$2y$")):
        raise CliError("invalid bcrypt hash format", 4)
    try:
        rounds = int(hash_bytes[4:6])
    except ValueError as error:
        raise CliError("invalid bcrypt cost field", 4) from error
    if not 4 <= rounds <= 31:
        raise CliError("bcrypt hash contains an invalid cost field", 4)
    return hash_bytes


def hash_password(args: argparse.Namespace, bcrypt: Any) -> int:
    """Read and hash a password, writing only the encoded hash to stdout."""

    confirm = not args.no_confirm and not args.stdin and not args.password_env
    password = read_password(args, prompt="Password: ", confirm=confirm)
    if args.rounds < 10:
        print(
            f"{PROGRAM_NAME}: warning: bcrypt rounds below 10 are intended only "
            "for compatibility or testing",
            file=sys.stderr,
        )
    try:
        encoded_hash = bcrypt.hashpw(password, bcrypt.gensalt(rounds=args.rounds))
    except (TypeError, ValueError) as error:
        raise CliError(f"bcrypt hashing failed: {error}", 4) from error
    print(encoded_hash.decode("ascii"))
    return 0


def verify_password(args: argparse.Namespace, bcrypt: Any) -> int:
    """Verify a password and return zero only when it matches."""

    encoded_hash = validate_hash(args.hash)
    password = read_password(args, prompt="Password: ")
    try:
        matched = bool(bcrypt.checkpw(password, encoded_hash))
    except (TypeError, ValueError) as error:
        raise CliError(f"bcrypt verification failed: {error}", 4) from error
    if not args.quiet:
        print("MATCH" if matched else "NO MATCH")
    return 0 if matched else 1


def run(args: argparse.Namespace) -> int:
    """Load the dependency and dispatch the selected operation."""

    bcrypt = import_bcrypt(allow_prompt=not args.no_install_prompt)
    if args.command == "hash":
        return hash_password(args, bcrypt)
    if args.command == "verify":
        return verify_password(args, bcrypt)
    raise CliError(f"unsupported command: {args.command}", 2)


def main(argv: Optional[Sequence[str]] = None) -> int:
    """Parse arguments and translate expected failures into process exit codes."""

    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        return run(args)
    except CliError as error:
        print(f"{PROGRAM_NAME}: error: {error}", file=sys.stderr)
        return error.exit_code
    except KeyboardInterrupt:
        print(f"\n{PROGRAM_NAME}: interrupted", file=sys.stderr)
        return 130
    except OSError as error:
        print(f"{PROGRAM_NAME}: error: operating system failure: {error}", file=sys.stderr)
        return 4


if __name__ == "__main__":
    raise SystemExit(main())
