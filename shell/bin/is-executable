#!/usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail

usage() {
  cat >&2 <<'EOF'
Usage:
  is-executable <command-or-path>
EOF
}

if [[ $# -ne 1 ]]; then
  usage
  exit 2
fi

target="$1"

if [[ "${target}" == */* ]]; then
  [[ -f "${target}" ]] && [[ -x "${target}" ]]
  exit $?
fi

command -v "${target}" >/dev/null 2>&1
