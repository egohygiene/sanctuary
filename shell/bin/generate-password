#!/usr/bin/env bash
# generate-password — Generate a secure random password (portable CLI tool)

set -o errexit
set -o nounset
set -o pipefail

# =============================================================================
# 🧾 Defaults
# =============================================================================
readonly DEFAULT_PASSWORD_LENGTH="32"

USE_COLOR=true
COPY_TO_CLIPBOARD=false
PASSWORD_LENGTH="${DEFAULT_PASSWORD_LENGTH}"

# =============================================================================
# 🎨 Color Handling (TTY-aware)
# =============================================================================
## color_init
# @description Initialize ANSI color codes if TTY and enabled
color_init() {
    if [[ "${USE_COLOR}" == true ]] && [[ -t 1 ]]; then
        COLOR_RESET="$(printf "\033[0m")"
        COLOR_CYAN="$(printf "\033[36m")"
        COLOR_GREEN="$(printf "\033[32m")"
        COLOR_YELLOW="$(printf "\033[33m")"
        COLOR_RED="$(printf "\033[31m")"
    else
        COLOR_RESET=""
        COLOR_CYAN=""
        COLOR_GREEN=""
        COLOR_YELLOW=""
        COLOR_RED=""
    fi
}

# =============================================================================
# 🪵 Logging
# =============================================================================
## log
# @description Structured logging with levels
# @arg $1 string Log level (info|success|warn|error)
# @arg $@ string Message
log() {
    local log_level="$1"
    shift

    local prefix=""
    local color_code=""

    case "${log_level}" in
        info)
            prefix="👉"
            color_code="${COLOR_CYAN}"
            ;;
        success)
            prefix="✅"
            color_code="${COLOR_GREEN}"
            ;;
        warn)
            prefix="⚠️"
            color_code="${COLOR_YELLOW}"
            ;;
        error)
            prefix="❌"
            color_code="${COLOR_RED}"
            ;;
    esac

    if [[ "${log_level}" == "error" ]]; then
        printf "%s%s %s%s\n" "${color_code}" "${prefix}" "$*" "${COLOR_RESET}" >&2
        exit 1
    fi

    printf "%s%s %s%s\n" "${color_code}" "${prefix}" "$*" "${COLOR_RESET}"
}

# =============================================================================
# 🔍 Dependency Checks
# =============================================================================
## require_command
# @description Ensure command exists
# @arg $1 string Command name
require_command() {
    if ! command -v "$1" >/dev/null 2>&1; then
        log error "Required command not found: $1"
    fi
}

# =============================================================================
# 🔐 Password Generation
# =============================================================================
## generate_password
# @description Generate secure password using OpenSSL
# @arg $1 number Length
generate_password() {
    local requested_length="$1"

    # Generate more entropy than needed, then trim safely
    openssl rand -base64 64 | tr -d '\n' | head -c "${requested_length}"
}

# =============================================================================
# 📋 Clipboard Support (Cross-Platform)
# =============================================================================
## copy_to_clipboard
# @description Copy value to system clipboard
# @arg $1 string Value
copy_to_clipboard() {
    local value="$1"

    if command -v pbcopy >/dev/null 2>&1; then
        printf "%s" "${value}" | pbcopy
        log success "Copied password via pbcopy (macOS)"
    elif command -v wl-copy >/dev/null 2>&1; then
        printf "%s" "${value}" | wl-copy
        log success "Copied password via wl-copy (Wayland)"
    elif command -v xclip >/dev/null 2>&1; then
        printf "%s" "${value}" | xclip -selection clipboard
        log success "Copied password via xclip (X11)"
    else
        log warn "No clipboard utility found (pbcopy, wl-copy, xclip)"
    fi
}

# =============================================================================
# 📖 Help
# =============================================================================
print_help() {
    cat <<EOF
Usage: $(basename "$0") [options]

Generate a strong random password.

Options:
  --length <number>   Password length (default: ${DEFAULT_PASSWORD_LENGTH})
  --copy              Copy to clipboard
  --no-color          Disable color output
  --help              Show this help message
EOF
}

# =============================================================================
# 🧩 Argument Parsing (robust)
# =============================================================================
parse_arguments() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --length)
                PASSWORD_LENGTH="${2:-}"
                shift 2
                ;;
            --copy)
                COPY_TO_CLIPBOARD=true
                shift
                ;;
            --no-color)
                USE_COLOR=false
                shift
                ;;
            -h|--help)
                print_help
                exit 0
                ;;
            *)
                log error "Unknown argument: $1"
                ;;
        esac
    done
}

# =============================================================================
# 🚀 Main
# =============================================================================
main() {
    parse_arguments "$@"
    color_init

    require_command "openssl"

    if ! [[ "${PASSWORD_LENGTH}" =~ ^[0-9]+$ ]]; then
        log error "Password length must be a number"
    fi

    local password
    password="$(generate_password "${PASSWORD_LENGTH}")"

    log success "Generated password:"
    printf "%s\n" "${password}"

    if [[ "${COPY_TO_CLIPBOARD}" == true ]]; then
        copy_to_clipboard "${password}"
    fi
}

main "$@"
