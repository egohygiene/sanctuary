#!/usr/bin/env bash
# shellcheck shell=bash

set -euo pipefail

readonly PROGRAM_NAME="dlsite"
readonly VERSION="1.0.0"
readonly DEFAULT_DESTINATION="sites"
readonly DEFAULT_DEPTH="5"
readonly DEFAULT_WAIT="1"
readonly DEFAULT_TRIES="5"
readonly DEFAULT_TIMEOUT="30"

DESTINATION=$DEFAULT_DESTINATION
DEPTH=$DEFAULT_DEPTH
WAIT_SECONDS=$DEFAULT_WAIT
TRIES=$DEFAULT_TRIES
TIMEOUT=$DEFAULT_TIMEOUT
ALLOW_PARENT=false
SPAN_HOSTS=false
DOMAINS=""
IGNORE_ROBOTS=false
USER_AGENT=""
LIMIT_RATE=""
QUOTA=""
CONFIG_FILE=""
DRY_RUN=false
PRINT_COMMAND=false
QUIET=false
VERBOSE=false
URL=""

declare -a EXTRA_WGET_ARGUMENTS=()
declare -a COMMAND=()

# @description Print command usage, options, examples, dependencies, and exits.
# @stdout Complete help text.
print_help() {
    printf '%s\n' "Usage: ${PROGRAM_NAME} [OPTIONS] URL [-- WGET_OPTIONS...]

Create an updateable, offline-browsable mirror of a website with GNU Wget.

By default, dlsite follows links up to five levels deep, stays on the URL's
host and path hierarchy, respects robots.txt, and waits one second between
requests. Existing mirrors are updated using remote timestamps.

Scope options:
  --depth LEVEL            Maximum recursion depth. Defaults to 5.
  --unlimited-depth        Allow unlimited recursive depth.
  --allow-parent           Permit traversal above the URL's path hierarchy.
  --span-hosts DOMAINS     Follow links across hosts, restricted to the supplied
                           comma-separated domain allowlist.

Request options:
  --wait SECONDS           Delay between requests. Defaults to 1.
  --no-delay               Do not add a between-request delay.
  --tries NUMBER           Attempts per resource. Defaults to 5.
  --timeout SECONDS        DNS, connection, and read timeout. Defaults to 30.
  --limit-rate RATE        Maximum transfer rate, such as 500k or 2m.
  --quota QUOTA            Maximum total download size, such as 100m or 500m.
  --user-agent STRING      Use an explicit user-agent instead of GNU Wget's.
  --ignore-robots          Ignore robots.txt only when authorized to do so.

Output options:
  --destination DIRECTORY  Mirror root. Defaults to ./sites.
  --config FILE            Load one explicit GNU Wget configuration file.
  --dry-run                Crawl with Wget's spider mode without saving files.
  --print-command          Print the constructed command without running it.
  --quiet                  Suppress Wget output.
  --verbose                Enable full Wget diagnostic output.
  --help                   Show this help text and exit.
  --version                Show version information and exit.

Arguments after -- are appended to the Wget command before the URL. This
supports advanced GNU Wget behavior without expanding this wrapper's interface.

Examples:
  ${PROGRAM_NAME} --dry-run https://example.com/docs/
  ${PROGRAM_NAME} --destination \"~/Archives\" https://example.com/
  ${PROGRAM_NAME} --depth 2 --limit-rate 500k https://example.com/blog/
  ${PROGRAM_NAME} --span-hosts \"example.com,cdn.example.com\" \\
    https://example.com/
  ${PROGRAM_NAME} --ignore-robots https://site-you-own.example/
  ${PROGRAM_NAME} https://example.com/ -- --reject-regex \"/private/\"

Mirror layout:
  DESTINATION/
    example.com/
      index.html
      ...

Dependencies:
  Bash 3.2 or newer and GNU Wget. macOS users can install GNU Wget with
  Homebrew, MacPorts, or another package manager.

Exit codes:
  0    Success.
  2    Invalid command-line usage.
  3    Invalid destination, configuration, or Wget implementation.
  127  GNU Wget is unavailable.
  Other nonzero statuses are propagated from GNU Wget.

Notes:
  --dry-run still makes network requests. It does not create the destination.
  A trailing slash matters with --no-parent: use /docs/ rather than /docs when
  the starting URL represents a directory hierarchy.
  JavaScript-rendered content and browser-only application state are outside
  GNU Wget's static mirroring model. Download only content you are authorized
  to archive and comply with the site's terms and applicable law.
"
}

# @description Print an error message to standard error.
# @arg $1 string Error message.
# @stderr The formatted error message.
error() {
    printf '%s: error: %s\n' "$PROGRAM_NAME" "$1" >&2
}

# @description Print a warning message to standard error.
# @arg $1 string Warning message.
# @stderr The formatted warning message.
warning() {
    printf '%s: warning: %s\n' "$PROGRAM_NAME" "$1" >&2
}

# @description Exit with a command-line usage error.
# @arg $1 string Explanation of the invalid usage.
# @exitcode 2 Always.
usage_error() {
    error "$1"
    printf "Try '%s --help' for more information.\n" "$PROGRAM_NAME" >&2
    exit 2
}

# @description Require a nonempty value after an option and store it.
# @arg $1 string Option name.
# @arg $2 integer Number of remaining command-line arguments.
# @arg $3 string|unset Candidate option value.
# @exitcode 2 If the value is missing or empty.
require_option_value() {
    local option_name=$1
    local remaining_arguments=$2

    if ((remaining_arguments < 2)) || [[ -z "${3-}" ]]; then
        usage_error "$option_name requires a value"
    fi

    OPTION_VALUE=$3
}

# @description Parse wrapper arguments and preserve Wget passthrough arguments.
# @arg $@ string Command-line arguments.
# @exitcode 2 If an argument is invalid.
parse_arguments() {
    local url_provided=false

    while (($# > 0)); do
        case "$1" in
            --destination)
                require_option_value "$1" "$#" "${2-}"
                DESTINATION=$OPTION_VALUE
                shift
                ;;
            --depth)
                require_option_value "$1" "$#" "${2-}"
                DEPTH=$OPTION_VALUE
                shift
                ;;
            --unlimited-depth)
                DEPTH="inf"
                ;;
            --allow-parent)
                ALLOW_PARENT=true
                ;;
            --span-hosts)
                require_option_value "$1" "$#" "${2-}"
                DOMAINS=$OPTION_VALUE
                SPAN_HOSTS=true
                shift
                ;;
            --wait)
                require_option_value "$1" "$#" "${2-}"
                WAIT_SECONDS=$OPTION_VALUE
                shift
                ;;
            --no-delay)
                WAIT_SECONDS="0"
                ;;
            --tries)
                require_option_value "$1" "$#" "${2-}"
                TRIES=$OPTION_VALUE
                shift
                ;;
            --timeout)
                require_option_value "$1" "$#" "${2-}"
                TIMEOUT=$OPTION_VALUE
                shift
                ;;
            --limit-rate)
                require_option_value "$1" "$#" "${2-}"
                LIMIT_RATE=$OPTION_VALUE
                shift
                ;;
            --quota)
                require_option_value "$1" "$#" "${2-}"
                QUOTA=$OPTION_VALUE
                shift
                ;;
            --user-agent)
                require_option_value "$1" "$#" "${2-}"
                USER_AGENT=$OPTION_VALUE
                shift
                ;;
            --ignore-robots)
                IGNORE_ROBOTS=true
                ;;
            --config)
                require_option_value "$1" "$#" "${2-}"
                CONFIG_FILE=$OPTION_VALUE
                shift
                ;;
            --dry-run)
                DRY_RUN=true
                ;;
            --print-command)
                PRINT_COMMAND=true
                ;;
            --quiet)
                QUIET=true
                ;;
            --verbose)
                VERBOSE=true
                ;;
            --help)
                print_help
                exit 0
                ;;
            --version)
                printf '%s %s\n' "$PROGRAM_NAME" "$VERSION"
                exit 0
                ;;
            --)
                shift
                EXTRA_WGET_ARGUMENTS=("$@")
                break
                ;;
            -*)
                usage_error "unknown option: $1"
                ;;
            *)
                if [[ "$url_provided" == true ]]; then
                    usage_error "expected exactly one URL before --"
                fi
                URL=$1
                url_provided=true
                ;;
        esac
        shift
    done

    if [[ "$url_provided" != true ]]; then
        usage_error "missing required URL"
    fi
}

# @description Return whether a value is a nonnegative decimal number.
# @arg $1 string Candidate numeric value.
# @exitcode 0 If valid; otherwise 1.
is_nonnegative_decimal() {
    case "$1" in
        "" | *[!0-9.]* | *.*.* | .* | *.) return 1 ;;
        *) return 0 ;;
    esac
}

# @description Return whether a value is a positive decimal integer.
# @arg $1 string Candidate integer value.
# @exitcode 0 If valid; otherwise 1.
is_positive_integer() {
    case "$1" in
        "" | *[!0-9]* | 0 | 0*) return 1 ;;
        *) return 0 ;;
    esac
}

# @description Return whether a value is a positive GNU Wget byte quantity.
# @arg $1 string Candidate quantity.
# @arg $2 boolean Whether decimal quantities are permitted.
# @exitcode 0 If valid; otherwise 1.
is_positive_size() {
    local value=$1
    local allow_decimal=$2
    local amount

    case "$value" in
        *[kKmM]) amount=${value%?} ;;
        *) amount=$value ;;
    esac

    if [[ "$allow_decimal" == true ]]; then
        is_nonnegative_decimal "$amount" && [[ "$amount" == *[1-9]* ]]
    else
        is_positive_integer "$amount"
    fi
}

# @description Validate wrapper options without accessing the network.
# @exitcode 2 If a value has invalid syntax.
# @exitcode 3 If an explicit configuration file is invalid.
validate_options() {
    case "$URL" in
        http://* | https://*) ;;
        *) usage_error "URL must begin with http:// or https://" ;;
    esac

    if [[ "$DEPTH" != "inf" ]] && ! is_positive_integer "$DEPTH"; then
        usage_error "--depth must be a positive integer"
    fi

    if ! is_nonnegative_decimal "$WAIT_SECONDS"; then
        usage_error "--wait must be a nonnegative number of seconds"
    fi

    if ! is_positive_integer "$TRIES"; then
        usage_error "--tries must be a positive integer"
    fi

    if ! is_nonnegative_decimal "$TIMEOUT" || [[ "$TIMEOUT" != *[1-9]* ]]; then
        usage_error "--timeout must be greater than zero"
    fi

    if [[ "$SPAN_HOSTS" == true ]]; then
        case "$DOMAINS" in
            ,* | *, | *,,* | *[!A-Za-z0-9.,_*-]*)
                usage_error "--span-hosts contains an invalid domain list"
                ;;
        esac
    fi

    if [[ "$QUIET" == true && "$VERBOSE" == true ]]; then
        usage_error "--quiet and --verbose cannot be used together"
    fi

    if [[ -n "$LIMIT_RATE" ]] && ! is_positive_size "$LIMIT_RATE" true; then
        usage_error "--limit-rate must be a positive byte rate with optional k or m suffix"
    fi

    if [[ -n "$QUOTA" ]] && ! is_positive_size "$QUOTA" false; then
        usage_error "--quota must be a positive byte count with optional k or m suffix"
    fi

    if [[ -n "$CONFIG_FILE" && ! -f "$CONFIG_FILE" ]]; then
        error "GNU Wget configuration file not found: $CONFIG_FILE"
        exit 3
    fi
}

# @description Verify that GNU Wget is available rather than another wget variant.
# @exitcode 3 If wget exists but is not GNU Wget.
# @exitcode 127 If wget cannot be found or executed.
validate_dependency() {
    local wget_version

    if ! command -v wget >/dev/null 2>&1; then
        error "GNU Wget was not found on PATH"
        exit 127
    fi

    if ! wget_version=$(wget --version 2>&1); then
        error "could not execute 'wget --version'"
        exit 127
    fi

    case "$wget_version" in
        *"GNU Wget"*) ;;
        *)
            error "the wget on PATH is not GNU Wget"
            exit 3
            ;;
    esac
}

# @description Create and validate the destination for a real mirror operation.
# @exitcode 3 If the destination cannot be created or written.
prepare_destination() {
    if [[ "$PRINT_COMMAND" == true || "$DRY_RUN" == true ]]; then
        return 0
    fi

    if ! mkdir -p "$DESTINATION"; then
        error "could not create destination directory: $DESTINATION"
        exit 3
    fi

    if [[ ! -d "$DESTINATION" || ! -w "$DESTINATION" || ! -x "$DESTINATION" ]]; then
        error "destination is not a writable directory: $DESTINATION"
        exit 3
    fi
}

# @description Construct the GNU Wget command as a safely quoted Bash array.
build_command() {
    COMMAND=(wget)

    if [[ -n "$CONFIG_FILE" ]]; then
        COMMAND+=(--config "$CONFIG_FILE")
    else
        COMMAND+=(--no-config)
    fi

    COMMAND+=(
        --recursive
        --level "$DEPTH"
        --tries "$TRIES"
        --timeout "$TIMEOUT"
        --waitretry "$TIMEOUT"
        --retry-connrefused
    )

    if [[ "$WAIT_SECONDS" != "0" && "$WAIT_SECONDS" != "0.0" ]]; then
        COMMAND+=(--wait "$WAIT_SECONDS")
    fi

    if [[ "$ALLOW_PARENT" != true ]]; then
        COMMAND+=(--no-parent)
    fi

    if [[ "$SPAN_HOSTS" == true ]]; then
        COMMAND+=(--span-hosts --domains "$DOMAINS")
    fi

    if [[ -n "$LIMIT_RATE" ]]; then
        COMMAND+=(--limit-rate "$LIMIT_RATE")
    fi

    if [[ -n "$QUOTA" ]]; then
        COMMAND+=(--quota "$QUOTA")
    fi

    if [[ -n "$USER_AGENT" ]]; then
        COMMAND+=(--user-agent "$USER_AGENT")
    fi

    if [[ "$IGNORE_ROBOTS" == true ]]; then
        COMMAND+=(--execute "robots=off")
    fi

    if [[ "$QUIET" == true ]]; then
        COMMAND+=(--quiet)
    elif [[ "$VERBOSE" == true ]]; then
        COMMAND+=(--verbose)
    else
        COMMAND+=(--no-verbose)
    fi

    if [[ "$DRY_RUN" == true ]]; then
        COMMAND+=(--spider)
    else
        COMMAND+=(
            --directory-prefix "$DESTINATION"
            --timestamping
            --page-requisites
            --convert-links
            --backup-converted
            --adjust-extension
        )
    fi

    if ((${#EXTRA_WGET_ARGUMENTS[@]} > 0)); then
        COMMAND+=("${EXTRA_WGET_ARGUMENTS[@]}")
    fi

    COMMAND+=(-- "$URL")
}

# @description Print the constructed command with reusable shell quoting.
# @stdout One shell-escaped command line.
print_command() {
    local argument
    local separator=""

    for argument in "${COMMAND[@]}"; do
        printf '%s' "$separator"
        printf '%q' "$argument"
        separator=" "
    done
    printf '\n'
}

# @description Execute the constructed GNU Wget command and preserve its status.
# @exitcode 0 If GNU Wget succeeds.
run_command() {
    local status

    if "${COMMAND[@]}"; then
        return 0
    else
        status=$?
        error "GNU Wget failed with exit status $status"
        return "$status"
    fi
}

# @description Run the dlsite command.
# @arg $@ string Command-line arguments.
# @exitcode 0 On success.
# @exitcode 2 For invalid usage.
# @exitcode 3 For invalid filesystem inputs or Wget implementation.
# @exitcode 127 If GNU Wget is unavailable.
main() {
    parse_arguments "$@"
    validate_options
    build_command

    if [[ "$IGNORE_ROBOTS" == true ]]; then
        warning "robots.txt enforcement is disabled; continue only with authorization"
    fi

    if [[ "$PRINT_COMMAND" == true ]]; then
        print_command
        return 0
    fi

    validate_dependency
    prepare_destination
    run_command
}

main "$@"
