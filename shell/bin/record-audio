#!/usr/bin/env python3
"""Record audio safely from a local input device."""

from __future__ import annotations

import argparse
import importlib
import importlib.metadata
import importlib.util
import json
import os
from pathlib import Path
import signal
import stat
import subprocess
import sys
import tempfile
import threading
import time
from typing import Any, Dict, List, Optional, Sequence, Tuple


PROGRAM_NAME = "record-audio"
VERSION = "2.0.0"
REQUIRED_PACKAGES = ("sounddevice", "soundfile")
FORMAT_BY_SUFFIX = {
    ".aif": "AIFF",
    ".aiff": "AIFF",
    ".au": "AU",
    ".caf": "CAF",
    ".flac": "FLAC",
    ".ogg": "OGG",
    ".wav": "WAV",
    ".wave": "WAV",
}

sd: Any = None
sf: Any = None


class CLIError(Exception):
    """Expected command-line failure with a stable exit code."""

    def __init__(self, message: str, exit_code: int = 1) -> None:
        super().__init__(message)
        self.exit_code = exit_code


def positive_int(value: str) -> int:
    """Parse a positive integer for argparse."""
    try:
        parsed = int(value)
    except ValueError as error:
        raise argparse.ArgumentTypeError("must be an integer") from error
    if parsed <= 0:
        raise argparse.ArgumentTypeError("must be greater than zero")
    return parsed


def nonnegative_int(value: str) -> int:
    """Parse a non-negative integer for argparse."""
    try:
        parsed = int(value)
    except ValueError as error:
        raise argparse.ArgumentTypeError("must be an integer") from error
    if parsed < 0:
        raise argparse.ArgumentTypeError("must not be negative")
    return parsed


def nonnegative_float(value: str) -> float:
    """Parse a finite, non-negative floating-point value for argparse."""
    try:
        parsed = float(value)
    except ValueError as error:
        raise argparse.ArgumentTypeError("must be a number") from error
    if parsed < 0 or parsed == float("inf") or parsed != parsed:
        raise argparse.ArgumentTypeError("must be a finite value that is not negative")
    return parsed


def build_parser() -> argparse.ArgumentParser:
    """Create the command-line parser."""
    parser = argparse.ArgumentParser(
        prog=PROGRAM_NAME,
        description=(
            "Record audio from a local input device. Audio is streamed to an "
            "atomic temporary file instead of being buffered in memory."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
examples:
  record-audio
  record-audio interview.wav --duration 30
  record-audio voice.flac --duration 0 --device "MacBook Microphone"
  record-audio --list-devices
  record-audio --list-devices --json
  record-audio --doctor
  record-audio --install-dependencies --list-devices

duration:
  A duration of 0 records until Ctrl-C. Ctrl-C is considered a successful stop
  for an open-ended recording. Interrupting a timed recording saves the partial
  audio and exits 130.

dependencies:
  Python packages: sounddevice, soundfile
  Native libraries may also be required:
    macOS:          brew install portaudio libsndfile
    Debian/Ubuntu:  sudo apt install libportaudio2 libsndfile1
    Fedora:         sudo dnf install portaudio libsndfile

exit codes:
  0 success
  1 recording, device, or audio-format failure
  2 invalid command-line usage
  3 no usable input device
  4 output-file failure
  77 microphone permission denied
  127 missing dependency
  130 timed recording interrupted with Ctrl-C
  143 terminated
""",
    )
    parser.add_argument(
        "output",
        nargs="?",
        default="recording.wav",
        help="output audio file (default: recording.wav)",
    )
    parser.add_argument(
        "-d",
        "--duration",
        type=nonnegative_float,
        default=5.0,
        metavar="SECONDS",
        help="recording duration; 0 records until Ctrl-C (default: 5)",
    )
    parser.add_argument(
        "--device",
        metavar="INDEX_OR_NAME",
        help="input device index, exact name, or unique name substring",
    )
    parser.add_argument(
        "--samplerate",
        type=positive_int,
        metavar="HZ",
        help="sample rate; defaults to the selected device's native rate",
    )
    parser.add_argument(
        "--channels",
        type=positive_int,
        default=1,
        help="input channels (default: 1)",
    )
    parser.add_argument(
        "--format",
        dest="audio_format",
        metavar="FORMAT",
        help="libsndfile format code; otherwise inferred from the extension",
    )
    parser.add_argument(
        "--subtype",
        metavar="SUBTYPE",
        help="libsndfile subtype such as PCM_16, PCM_24, FLOAT, or VORBIS",
    )
    parser.add_argument(
        "--latency",
        choices=("low", "high"),
        default="high",
        help="PortAudio latency profile (default: high for stability)",
    )
    parser.add_argument(
        "--countdown",
        type=nonnegative_int,
        default=0,
        metavar="SECONDS",
        help="count down before recording (default: 0)",
    )
    parser.add_argument(
        "--overwrite",
        action="store_true",
        help="replace an existing output atomically",
    )
    parser.add_argument(
        "--no-progress",
        action="store_true",
        help="disable interactive recording progress",
    )
    parser.add_argument(
        "--quiet",
        action="store_true",
        help="suppress informational diagnostics",
    )
    parser.add_argument(
        "--json",
        action="store_true",
        help="print device or recording results as JSON",
    )
    parser.add_argument(
        "--list-devices",
        action="store_true",
        help="list available input devices and exit",
    )
    parser.add_argument(
        "--list-formats",
        action="store_true",
        help="list writable audio formats and subtypes, then exit",
    )
    parser.add_argument(
        "--doctor",
        action="store_true",
        help="inspect dependencies, PortAudio, libsndfile, and input devices",
    )
    parser.add_argument(
        "--install-dependencies",
        action="store_true",
        help="install missing Python packages into the active Python environment",
    )
    parser.add_argument(
        "--no-install-prompt",
        action="store_true",
        help="never offer an interactive dependency installation prompt",
    )
    parser.add_argument(
        "-v",
        "--version",
        action="version",
        version=f"{PROGRAM_NAME} {VERSION}",
    )
    return parser


def log(message: str, *, quiet: bool = False) -> None:
    """Write a diagnostic to stderr unless quiet mode is active."""
    if not quiet:
        print(f"{PROGRAM_NAME}: {message}", file=sys.stderr)


def missing_python_packages() -> List[str]:
    """Return required import names that are unavailable."""
    return [name for name in REQUIRED_PACKAGES if importlib.util.find_spec(name) is None]


def native_dependency_hint() -> str:
    """Return platform-specific native dependency guidance."""
    if sys.platform == "darwin":
        return "Install native libraries with: brew install portaudio libsndfile"
    if sys.platform.startswith("linux"):
        return (
            "Install PortAudio and libsndfile with your package manager, for example: "
            "sudo apt install libportaudio2 libsndfile1"
        )
    if sys.platform == "win32":
        return "Official sounddevice and soundfile wheels normally include required runtime libraries."
    return "Install the PortAudio and libsndfile runtime libraries for this platform."


def install_python_packages(packages: Sequence[str]) -> None:
    """Install missing packages into the active Python environment."""
    command = [
        sys.executable,
        "-m",
        "pip",
        "install",
        "--disable-pip-version-check",
        *packages,
    ]
    log("running: " + " ".join(command))
    try:
        completed = subprocess.run(command, check=False)
    except OSError as error:
        raise CLIError(f"could not start pip: {error}", 127) from error
    if completed.returncode != 0:
        raise CLIError(
            "dependency installation failed; use a virtual environment or install "
            f"the packages manually: {sys.executable} -m pip install {' '.join(packages)}",
            127,
        )
    importlib.invalidate_caches()


def ensure_dependencies(args: argparse.Namespace) -> Tuple[Any, Any]:
    """Load audio modules, optionally installing missing Python packages."""
    global sd, sf
    missing = missing_python_packages()
    should_install = args.install_dependencies
    if missing and not should_install:
        can_prompt = (
            not args.no_install_prompt
            and not args.json
            and sys.stdin.isatty()
            and sys.stderr.isatty()
        )
        if can_prompt:
            print(f"Missing Python packages: {', '.join(missing)}", file=sys.stderr)
            response = input("Install them into the active Python environment? [y/N] ")
            should_install = response.strip().lower() in {"y", "yes"}
    if missing and should_install:
        install_python_packages(missing)
        missing = missing_python_packages()
    if missing:
        raise CLIError(
            "missing Python packages: "
            + ", ".join(missing)
            + f". Install them with: {sys.executable} -m pip install {' '.join(missing)}",
            127,
        )
    try:
        sd = importlib.import_module("sounddevice")
        sf = importlib.import_module("soundfile")
    except (ImportError, OSError) as error:
        raise CLIError(f"audio dependency could not be loaded: {error}. {native_dependency_hint()}", 127) from error
    return sd, sf


def default_input_index() -> Optional[int]:
    """Return PortAudio's default input index when one is configured."""
    try:
        configured = sd.default.device
        try:
            value = configured[0]
        except (IndexError, TypeError):
            value = configured
        index = int(value)
        return index if index >= 0 else None
    except (AttributeError, IndexError, TypeError, ValueError):
        return None


def input_devices() -> List[Dict[str, Any]]:
    """Return normalized input-device metadata."""
    try:
        devices = list(sd.query_devices())
        hostapis = list(sd.query_hostapis())
    except Exception as error:
        raise CLIError(f"could not query audio devices: {error}. {native_dependency_hint()}", 3) from error
    default_index = default_input_index()
    normalized: List[Dict[str, Any]] = []
    for index, device in enumerate(devices):
        maximum = int(device.get("max_input_channels", 0))
        if maximum <= 0:
            continue
        hostapi_index = int(device.get("hostapi", -1))
        hostapi_name = "unknown"
        if 0 <= hostapi_index < len(hostapis):
            hostapi_name = str(hostapis[hostapi_index].get("name", "unknown"))
        normalized.append(
            {
                "index": index,
                "name": str(device.get("name", f"device-{index}")),
                "host_api": hostapi_name,
                "max_input_channels": maximum,
                "default_samplerate": int(round(float(device.get("default_samplerate", 0)))),
                "default": index == default_index,
            }
        )
    return normalized


def resolve_device(
    specification: Optional[str], *, quiet: bool = False
) -> Tuple[Optional[int], Dict[str, Any]]:
    """Resolve a device index/name and return its detailed PortAudio metadata."""
    devices = input_devices()
    if not devices:
        raise CLIError("no audio input devices were found", 3)

    selected_index: Optional[int]
    if specification is None:
        selected_index = default_input_index()
        if selected_index is None:
            selected_index = int(devices[0]["index"])
            log(
                f"no default input is configured; using device {selected_index}: {devices[0]['name']}",
                quiet=quiet,
            )
    else:
        try:
            selected_index = int(specification)
        except ValueError:
            lowered = specification.casefold()
            exact = [item for item in devices if item["name"].casefold() == lowered]
            matches = exact or [item for item in devices if lowered in item["name"].casefold()]
            if not matches:
                raise CLIError(f"no input device matches: {specification}", 3)
            if len(matches) > 1:
                choices = ", ".join(f"{item['index']}:{item['name']}" for item in matches)
                raise CLIError(f"input device name is ambiguous ({choices}); use an index", 3)
            selected_index = int(matches[0]["index"])

    matching = [item for item in devices if int(item["index"]) == selected_index]
    if not matching:
        raise CLIError(f"device {selected_index} is not an audio input", 3)
    try:
        details = dict(sd.query_devices(selected_index))
    except Exception as error:
        raise CLIError(f"could not inspect input device {selected_index}: {error}", 3) from error
    details["index"] = selected_index
    details["host_api"] = matching[0]["host_api"]
    return selected_index, details


def print_devices(as_json: bool) -> int:
    """Print available input devices."""
    devices = input_devices()
    if as_json:
        print(json.dumps(devices, ensure_ascii=False, sort_keys=True, indent=2))
    elif devices:
        print(f"{'INDEX':>5}  {'DEFAULT':7}  {'CHANNELS':>8}  {'RATE':>7}  DEVICE")
        for item in devices:
            marker = "yes" if item["default"] else ""
            print(
                f"{item['index']:>5}  {marker:7}  {item['max_input_channels']:>8}  "
                f"{item['default_samplerate']:>7}  {item['name']} [{item['host_api']}]"
            )
    else:
        print("No audio input devices found.")
    return 0 if devices else 3


def format_catalog() -> List[Dict[str, Any]]:
    """Return writable libsndfile formats and their compatible subtypes."""
    try:
        formats = sf.available_formats()
        return [
            {
                "format": code,
                "description": description,
                "default_subtype": sf.default_subtype(code),
                "subtypes": sf.available_subtypes(code),
            }
            for code, description in sorted(formats.items())
            if code != "RAW"
        ]
    except Exception as error:
        raise CLIError(f"could not query libsndfile formats: {error}", 1) from error


def print_formats(as_json: bool) -> int:
    """Print writable audio formats."""
    catalog = format_catalog()
    if as_json:
        print(json.dumps(catalog, ensure_ascii=False, sort_keys=True, indent=2))
    else:
        for item in catalog:
            subtypes = ", ".join(item["subtypes"].keys())
            print(f"{item['format']:<8} {item['description']}")
            print(f"         default={item['default_subtype']} subtypes={subtypes}")
    return 0


def dependency_version(distribution: str) -> Optional[str]:
    """Return an installed distribution version when available."""
    try:
        return importlib.metadata.version(distribution)
    except importlib.metadata.PackageNotFoundError:
        return None


def doctor_report() -> Dict[str, Any]:
    """Build an audio environment diagnostic report."""
    report: Dict[str, Any] = {
        "python": sys.version.split()[0],
        "platform": sys.platform,
        "packages": {
            "sounddevice": dependency_version("sounddevice"),
            "soundfile": dependency_version("soundfile"),
        },
        "portaudio": None,
        "libsndfile": getattr(sf, "__libsndfile_version__", None),
        "input_devices": [],
        "ok": False,
    }
    try:
        version_number, version_text = sd.get_portaudio_version()
        report["portaudio"] = {"version": version_number, "description": version_text}
        report["input_devices"] = input_devices()
        report["ok"] = bool(report["input_devices"])
    except Exception as error:
        report["error"] = str(error)
    return report


def print_doctor(as_json: bool) -> int:
    """Print dependency and audio-device diagnostics."""
    report = doctor_report()
    if as_json:
        print(json.dumps(report, ensure_ascii=False, sort_keys=True, indent=2))
    else:
        print(f"Python:       {report['python']} ({report['platform']})")
        print(f"sounddevice:  {report['packages']['sounddevice'] or 'missing'}")
        print(f"soundfile:    {report['packages']['soundfile'] or 'missing'}")
        portaudio = report.get("portaudio")
        print(f"PortAudio:    {portaudio['description'] if portaudio else 'unavailable'}")
        print(f"libsndfile:   {report.get('libsndfile') or 'unavailable'}")
        print(f"Input devices:{len(report.get('input_devices', [])):>3}")
        if report.get("error"):
            print(f"Error:        {report['error']}")
        print(f"Status:       {'ready' if report['ok'] else 'not ready'}")
    return 0 if report["ok"] else 1


def resolve_output(path_text: str, overwrite: bool) -> Path:
    """Validate and normalize the requested output path."""
    output = Path(path_text).expanduser()
    if not output.suffix:
        output = output.with_suffix(".wav")
    try:
        output = output.resolve(strict=False)
    except OSError as error:
        raise CLIError(f"could not resolve output path: {error}", 4) from error
    if output.exists() and output.is_dir():
        raise CLIError(f"output is a directory: {output}", 4)
    if output.exists() and not overwrite:
        raise CLIError(f"output already exists: {output} (use --overwrite)", 4)
    if not output.parent.is_dir():
        raise CLIError(f"output directory does not exist: {output.parent}", 4)
    if not os.access(str(output.parent), os.W_OK):
        raise CLIError(f"output directory is not writable: {output.parent}", 4)
    return output


def resolve_format(output: Path, requested: Optional[str], subtype: Optional[str]) -> Tuple[str, Optional[str]]:
    """Resolve and validate a libsndfile format/subtype combination."""
    audio_format = requested.upper() if requested else FORMAT_BY_SUFFIX.get(output.suffix.lower())
    if audio_format is None:
        supported = ", ".join(sorted(FORMAT_BY_SUFFIX))
        raise CLIError(f"cannot infer audio format from {output.suffix!r}; use --format or one of: {supported}")
    available = sf.available_formats()
    if audio_format not in available:
        raise CLIError(f"audio format is unavailable in this libsndfile build: {audio_format}")
    normalized_subtype = subtype.upper() if subtype else None
    if not sf.check_format(audio_format, normalized_subtype):
        choices = ", ".join(sf.available_subtypes(audio_format).keys())
        raise CLIError(
            f"unsupported format/subtype combination: {audio_format}/{normalized_subtype}; "
            f"available subtypes: {choices}"
        )
    return audio_format, normalized_subtype


def microphone_permission_error(error: BaseException) -> bool:
    """Return whether an audio error appears to be a permission denial."""
    text = str(error).casefold()
    return any(term in text for term in ("permission", "not permitted", "access denied", "-9986"))


def validate_input_settings(
    device_index: Optional[int],
    device: Dict[str, Any],
    channels: int,
    samplerate: Optional[int],
) -> int:
    """Select a sample rate and validate PortAudio input settings."""
    maximum = int(device.get("max_input_channels", 0))
    if channels > maximum:
        raise CLIError(
            f"device {device_index} supports {maximum} input channel(s), not {channels}",
            3,
        )
    selected_rate = samplerate or int(round(float(device.get("default_samplerate", 0))))
    if selected_rate <= 0:
        raise CLIError("the selected device has no usable default sample rate; pass --samplerate", 3)
    try:
        sd.check_input_settings(
            device=device_index,
            channels=channels,
            dtype="float32",
            samplerate=selected_rate,
        )
    except Exception as error:
        code = 77 if microphone_permission_error(error) else 3
        raise CLIError(f"unsupported input settings: {error}", code) from error
    return selected_rate


def countdown(seconds: int, stop_event: threading.Event, quiet: bool) -> None:
    """Display an interruptible recording countdown."""
    for remaining in range(seconds, 0, -1):
        if stop_event.is_set():
            return
        log(f"recording starts in {remaining}…", quiet=quiet)
        stop_event.wait(1.0)


def show_progress(frames: int, samplerate: int, duration: float, enabled: bool) -> None:
    """Update interactive recording progress on stderr."""
    if not enabled:
        return
    elapsed = frames / samplerate
    if duration > 0:
        print(f"\rRecording: {elapsed:7.1f} / {duration:.1f} seconds", end="", file=sys.stderr, flush=True)
    else:
        print(f"\rRecording: {elapsed:7.1f} seconds — Ctrl-C to stop", end="", file=sys.stderr, flush=True)


def make_temporary_output(output: Path) -> Path:
    """Create a private temporary output path with the final extension."""
    try:
        descriptor, name = tempfile.mkstemp(
            prefix=f".{output.stem}.",
            suffix=output.suffix,
            dir=str(output.parent),
        )
        os.close(descriptor)
        return Path(name)
    except OSError as error:
        raise CLIError(f"could not create temporary output: {error}", 4) from error


def record(args: argparse.Namespace) -> Tuple[Dict[str, Any], int]:
    """Stream audio to an atomic output and return metadata plus exit status."""
    output = resolve_output(args.output, args.overwrite)
    audio_format, subtype = resolve_format(output, args.audio_format, args.subtype)
    device_index, device = resolve_device(args.device, quiet=args.quiet or args.json)
    samplerate = validate_input_settings(device_index, device, args.channels, args.samplerate)
    target_frames = int(round(args.duration * samplerate)) if args.duration > 0 else None
    block_frames = max(64, int(round(samplerate * 0.1)))
    temporary = make_temporary_output(output)
    frames_written = 0
    overflow_count = 0
    interrupted_signal: Optional[int] = None
    stop_event = threading.Event()
    progress_enabled = not args.no_progress and not args.quiet and not args.json and sys.stderr.isatty()

    previous_handlers: Dict[int, Any] = {}

    def request_stop(signum: int, _frame: Any) -> None:
        nonlocal interrupted_signal
        interrupted_signal = signum
        stop_event.set()

    for signum in (signal.SIGINT, signal.SIGTERM):
        previous_handlers[signum] = signal.getsignal(signum)
        signal.signal(signum, request_stop)

    try:
        countdown(args.countdown, stop_event, args.quiet or args.json)
        if stop_event.is_set():
            raise CLIError("recording cancelled before capture began", 130 if interrupted_signal == signal.SIGINT else 143)

        log(
            f"recording from device {device_index}: {device.get('name', 'unknown')} "
            f"({samplerate} Hz, {args.channels} channel(s))",
            quiet=args.quiet or args.json,
        )
        try:
            with sf.SoundFile(
                str(temporary),
                mode="w",
                samplerate=samplerate,
                channels=args.channels,
                subtype=subtype,
                format=audio_format,
            ) as audio_file:
                with sd.InputStream(
                    device=device_index,
                    samplerate=samplerate,
                    channels=args.channels,
                    dtype="float32",
                    latency=args.latency,
                    blocksize=block_frames,
                ) as stream:
                    while not stop_event.is_set():
                        if target_frames is not None and frames_written >= target_frames:
                            break
                        request_frames = block_frames
                        if target_frames is not None:
                            request_frames = min(request_frames, target_frames - frames_written)
                        data, overflowed = stream.read(request_frames)
                        if overflowed:
                            overflow_count += 1
                        audio_file.write(data)
                        frames_written += len(data)
                        show_progress(frames_written, samplerate, args.duration, progress_enabled)
        except Exception as error:
            code = 77 if microphone_permission_error(error) else 1
            hint = ""
            if code == 77 and sys.platform == "darwin":
                hint = " Grant microphone access to your terminal in System Settings → Privacy & Security → Microphone."
            raise CLIError(f"audio capture failed: {error}.{hint}", code) from error

        if progress_enabled:
            print(file=sys.stderr)
        if frames_written == 0:
            raise CLIError("no audio frames were captured", 1)
        try:
            if output.exists():
                os.chmod(str(temporary), stat.S_IMODE(output.stat().st_mode))
            os.replace(str(temporary), str(output))
        except OSError as error:
            raise CLIError(f"could not finalize output file: {error}", 4) from error

        actual_duration = frames_written / samplerate
        result = {
            "output": str(output),
            "duration_seconds": round(actual_duration, 6),
            "frames": frames_written,
            "samplerate": samplerate,
            "channels": args.channels,
            "format": audio_format,
            "subtype": subtype or sf.default_subtype(audio_format),
            "device": {
                "index": device_index,
                "name": str(device.get("name", "unknown")),
                "host_api": str(device.get("host_api", "unknown")),
            },
            "input_overflows": overflow_count,
            "interrupted": interrupted_signal is not None,
        }
        if overflow_count:
            log(
                f"warning: PortAudio reported {overflow_count} input overflow(s); "
                "try --latency high, fewer channels, or a lower sample rate",
                quiet=args.quiet or args.json,
            )

        if interrupted_signal == signal.SIGTERM:
            return result, 143
        if interrupted_signal == signal.SIGINT and args.duration > 0:
            return result, 130
        return result, 0
    finally:
        for signum, handler in previous_handlers.items():
            signal.signal(signum, handler)
        if temporary.exists():
            try:
                temporary.unlink()
            except OSError:
                pass


def print_recording_result(result: Dict[str, Any], as_json: bool, quiet: bool) -> None:
    """Print recording metadata."""
    if as_json:
        print(json.dumps(result, ensure_ascii=False, sort_keys=True, indent=2))
    elif not quiet:
        print(f"Saved:      {result['output']}")
        print(f"Duration:   {result['duration_seconds']:.3f} seconds")
        print(f"Audio:      {result['samplerate']} Hz, {result['channels']} channel(s), {result['subtype']}")
        print(f"Device:     {result['device']['index']}: {result['device']['name']}")


def main(argv: Optional[Sequence[str]] = None) -> int:
    """Run the record-audio CLI."""
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        operation_count = sum((args.list_devices, args.list_formats, args.doctor))
        if operation_count > 1:
            raise CLIError("--list-devices, --list-formats, and --doctor are mutually exclusive", 2)
        ensure_dependencies(args)
        if args.list_devices:
            return print_devices(args.json)
        if args.list_formats:
            return print_formats(args.json)
        if args.doctor:
            return print_doctor(args.json)
        result, exit_code = record(args)
        print_recording_result(result, args.json, args.quiet)
        return exit_code
    except CLIError as error:
        print(f"{PROGRAM_NAME}: error: {error}", file=sys.stderr)
        return error.exit_code
    except KeyboardInterrupt:
        print(f"{PROGRAM_NAME}: interrupted", file=sys.stderr)
        return 130


if __name__ == "__main__":
    raise SystemExit(main())
