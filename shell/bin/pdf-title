#!/usr/bin/env python3
"""Extract defensible titles from one or more PDF documents."""

from __future__ import annotations

import argparse
from dataclasses import asdict, dataclass
import importlib
import importlib.metadata
import importlib.util
import json
import math
import os
from pathlib import Path
import re
import stat
import subprocess
import sys
import tempfile
from typing import Any, Dict, Iterable, List, Optional, Sequence, Tuple
from urllib.parse import unquote


PROGRAM_NAME = "pdf-title"
VERSION = "1.0.0"
DEPENDENCY_IMPORT = "pymupdf"
DEPENDENCY_PACKAGE = "pymupdf"
GENERIC_TITLES = {
    "document",
    "no title",
    "none",
    "pdf document",
    "title",
    "unknown",
    "untitled",
}
NON_TITLE_PREFIXES = (
    "abstract",
    "arxiv:",
    "contents",
    "copyright",
    "doi:",
    "keywords",
    "table of contents",
)

pymupdf: Any = None


class CLIError(Exception):
    """Represent an expected command-line failure with a stable exit code."""

    def __init__(self, message: str, exit_code: int = 1) -> None:
        super().__init__(message)
        self.exit_code = exit_code


@dataclass
class Candidate:
    """Represent one typographic title candidate."""

    text: str
    page: int
    score: float
    font_size: float
    bold: bool
    centered: bool
    y_ratio: float
    line_count: int


@dataclass
class TitleResult:
    """Represent one successful title extraction result."""

    path: str
    title: str
    source: str
    confidence: float
    page: Optional[int]
    score: Optional[float]
    fallback: bool


@dataclass
class ErrorResult:
    """Represent one failed input in structured output."""

    path: str
    error: str
    exit_code: int


def positive_int(value: str) -> int:
    """Parse a positive integer for argparse."""
    try:
        parsed = int(value)
    except ValueError as error:
        raise argparse.ArgumentTypeError("must be an integer") from error
    if parsed <= 0:
        raise argparse.ArgumentTypeError("must be greater than zero")
    return parsed


def build_parser() -> argparse.ArgumentParser:
    """Build the command-line parser."""
    parser = argparse.ArgumentParser(
        prog=PROGRAM_NAME,
        description=(
            "Extract a PDF title from metadata, first-page typography, or the "
            "filename. Multiple files are processed independently."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
extraction order:
  auto      usable document metadata, then typographic heading, then filename
  metadata  document metadata only
  heading   typographic heading only
  filename  normalized filename only

input:
  If no PDF arguments are provided and stdin is redirected, newline-delimited
  paths are read from stdin.

dependencies:
  Runtime: Python 3.9+
  Python package: pymupdf

examples:
  pdf-title paper.pdf
  pdf-title *.pdf
  find . -name '*.pdf' -print | pdf-title --format jsonl
  pdf-title report.pdf --explain
  pdf-title encrypted.pdf --password-file ~/.config/pdf-password
  pdf-title *.pdf --format json --output titles.json
  pdf-title paper.pdf --method heading --scan-pages 3
  pdf-title --install-dependencies paper.pdf

exit codes:
  0   success
  1   one or more documents could not be processed
  2   invalid command-line usage
  3   invalid, unreadable, or non-PDF input
  4   output-file failure
  5   encrypted PDF requires a password or authentication failed
  6   --require-detected rejected a filename fallback
  127 missing Python dependency
  130 interrupted
""",
    )
    parser.add_argument("files", nargs="*", metavar="PDF", help="PDF file to inspect")
    parser.add_argument(
        "--method",
        choices=("auto", "metadata", "heading", "filename"),
        default="auto",
        help="title extraction method (default: auto)",
    )
    parser.add_argument(
        "--scan-pages",
        type=positive_int,
        default=3,
        metavar="COUNT",
        help="front-matter pages to inspect for a heading (default: 3)",
    )
    parser.add_argument(
        "--format",
        choices=("plain", "json", "jsonl"),
        default="plain",
        help="result format (default: plain)",
    )
    parser.add_argument(
        "-o",
        "--output",
        metavar="FILE",
        help="write results atomically to FILE instead of stdout",
    )
    parser.add_argument(
        "-f",
        "--force",
        action="store_true",
        help="replace an existing output file",
    )
    parser.add_argument(
        "--explain",
        action="store_true",
        help="include source, confidence, and page in plain output",
    )
    parser.add_argument(
        "--require-detected",
        action="store_true",
        help="exit 6 when auto mode must fall back to a filename",
    )
    parser.add_argument(
        "--password-file",
        metavar="FILE",
        help="read the PDF password from the first line of FILE",
    )
    parser.add_argument(
        "--fail-fast",
        action="store_true",
        help="stop after the first document error",
    )
    parser.add_argument(
        "--verbose",
        action="store_true",
        help="show candidate-scoring diagnostics on stderr",
    )
    parser.add_argument(
        "--install-dependencies",
        action="store_true",
        help="install missing Python packages in the active environment",
    )
    parser.add_argument(
        "--no-install-prompt",
        action="store_true",
        help="never offer interactive dependency installation",
    )
    parser.add_argument(
        "-v",
        "--version",
        action="version",
        version=f"{PROGRAM_NAME} {VERSION}",
    )
    return parser


def log(message: str) -> None:
    """Write an informational diagnostic to stderr."""
    print(f"{PROGRAM_NAME}: {message}", file=sys.stderr)


def debug(message: str, enabled: bool) -> None:
    """Write a diagnostic when verbose mode is enabled."""
    if enabled:
        print(f"{PROGRAM_NAME}: debug: {message}", file=sys.stderr)


def dependency_available() -> bool:
    """Return whether the canonical PyMuPDF import is available."""
    return importlib.util.find_spec(DEPENDENCY_IMPORT) is not None


def install_dependency() -> None:
    """Install PyMuPDF into the active Python environment."""
    command = [
        sys.executable,
        "-m",
        "pip",
        "install",
        "--disable-pip-version-check",
        DEPENDENCY_PACKAGE,
    ]
    log("running: " + " ".join(command))
    try:
        completed = subprocess.run(command, check=False)
    except OSError as error:
        raise CLIError(f"could not start pip: {error}", 127) from error
    if completed.returncode != 0:
        raise CLIError(
            "dependency installation failed; use a virtual environment or run: "
            f"{sys.executable} -m pip install {DEPENDENCY_PACKAGE}",
            127,
        )
    importlib.invalidate_caches()


def ensure_dependency(args: argparse.Namespace) -> Any:
    """Load PyMuPDF, optionally offering an explicit installation."""
    global pymupdf
    missing = not dependency_available()
    should_install = bool(args.install_dependencies)
    if missing and not should_install:
        can_prompt = (
            not args.no_install_prompt
            and sys.stdin.isatty()
            and sys.stderr.isatty()
            and bool(args.files)
        )
        if can_prompt:
            print("Missing Python package: pymupdf", file=sys.stderr)
            response = input("Install it into the active Python environment? [y/N] ")
            should_install = response.strip().casefold() in {"y", "yes"}
    if missing and should_install:
        install_dependency()
        missing = not dependency_available()
    if missing:
        raise CLIError(
            "missing Python package: pymupdf. Install it with: "
            f"{sys.executable} -m pip install pymupdf",
            127,
        )
    try:
        pymupdf = importlib.import_module(DEPENDENCY_IMPORT)
    except (ImportError, OSError) as error:
        raise CLIError(f"could not load PyMuPDF: {error}", 127) from error
    return pymupdf


def dependency_version() -> Optional[str]:
    """Return the installed PyMuPDF distribution version."""
    try:
        return importlib.metadata.version("PyMuPDF")
    except importlib.metadata.PackageNotFoundError:
        return None


def read_input_paths(arguments: Sequence[str]) -> List[str]:
    """Return PDF paths from arguments or redirected standard input."""
    if arguments:
        return list(arguments)
    if sys.stdin.isatty():
        raise CLIError("at least one PDF is required", 2)
    paths = [line.rstrip("\r\n") for line in sys.stdin if line.rstrip("\r\n")]
    if not paths:
        raise CLIError("stdin did not contain any PDF paths", 2)
    return paths


def read_password(path_text: Optional[str]) -> Optional[str]:
    """Read a password from a protected file or the PDF_PASSWORD environment variable."""
    if path_text:
        path = Path(path_text).expanduser()
        try:
            first_line = path.read_text(encoding="utf-8").splitlines()
        except (OSError, UnicodeError) as error:
            raise CLIError(f"could not read password file {path}: {error}", 5) from error
        if not first_line:
            raise CLIError(f"password file is empty: {path}", 5)
        return first_line[0]
    return os.environ.get("PDF_PASSWORD")


def normalize_title(value: Any) -> str:
    """Normalize extracted title text without changing meaningful case."""
    if value is None:
        return ""
    text = str(value).replace("\x00", " ")
    text = "".join(character if character.isprintable() else " " for character in text)
    text = re.sub(r"\s+", " ", text).strip(" \t\r\n-–—|:")
    return text


def usable_title(value: Any) -> bool:
    """Return whether a title is meaningful enough to report."""
    title = normalize_title(value)
    if len(title) < 2 or len(title) > 500:
        return False
    if title.casefold() in GENERIC_TITLES:
        return False
    if not any(character.isalnum() for character in title):
        return False
    return True


def usable_metadata_title(value: Any) -> bool:
    """Return whether a metadata title appears intentional rather than generated."""
    title = normalize_title(value)
    if not usable_title(title):
        return False
    folded = title.casefold()
    if folded.startswith(("microsoft word -", "microsoft powerpoint -")):
        return False
    if re.match(r"^[a-z][a-z0-9+.-]*://", folded):
        return False
    if re.search(r"\.(?:doc|docx|odt|pdf|ppt|pptx)$", folded):
        return False
    return True


def filename_title(path: Path) -> str:
    """Create a readable fallback title from a PDF filename."""
    value = unquote(path.stem)
    value = re.sub(r"_+", " ", value)
    value = re.sub(r"\s+", " ", value).strip()
    return value or "Untitled"


def weighted_median(values: Iterable[Tuple[float, int]]) -> float:
    """Return a character-weighted median font size."""
    ordered = sorted((size, max(weight, 1)) for size, weight in values if size > 0)
    if not ordered:
        return 11.0
    total = sum(weight for _, weight in ordered)
    midpoint = total / 2.0
    accumulated = 0
    for size, weight in ordered:
        accumulated += weight
        if accumulated >= midpoint:
            return size
    return ordered[-1][0]


def extract_lines(page: Any, page_number: int) -> List[Dict[str, Any]]:
    """Extract normalized text lines and typography from one PDF page."""
    try:
        data = page.get_text("dict", sort=True)
    except TypeError:
        data = page.get_text("dict")
    page_width = max(float(page.rect.width), 1.0)
    page_height = max(float(page.rect.height), 1.0)
    lines: List[Dict[str, Any]] = []
    for block_index, block in enumerate(data.get("blocks", [])):
        if block.get("type", 0) != 0:
            continue
        for line_index, line in enumerate(block.get("lines", [])):
            spans = [span for span in line.get("spans", []) if normalize_title(span.get("text"))]
            if not spans:
                continue
            text = normalize_title(" ".join(str(span.get("text", "")) for span in spans))
            if not text:
                continue
            bbox = line.get("bbox") or (
                min(float(span["bbox"][0]) for span in spans),
                min(float(span["bbox"][1]) for span in spans),
                max(float(span["bbox"][2]) for span in spans),
                max(float(span["bbox"][3]) for span in spans),
            )
            sizes = [float(span.get("size", 0.0)) for span in spans]
            flags = 0
            for span in spans:
                flags |= int(span.get("flags", 0))
            x0, y0, x1, y1 = (float(item) for item in bbox)
            line_center = (x0 + x1) / 2.0
            centered = abs(line_center - page_width / 2.0) <= page_width * 0.12
            lines.append(
                {
                    "text": text,
                    "page": page_number,
                    "block": block_index,
                    "line": line_index,
                    "bbox": (x0, y0, x1, y1),
                    "size": max(sizes) if sizes else 0.0,
                    "bold": bool(flags & 16),
                    "centered": centered,
                    "y_ratio": max(0.0, min(y0 / page_height, 1.0)),
                    "page_width": page_width,
                    "page_height": page_height,
                    "line_count": 1,
                }
            )
    return sorted(lines, key=lambda item: (item["page"], item["bbox"][1], item["bbox"][0]))


def combined_lines(lines: Sequence[Dict[str, Any]]) -> List[Dict[str, Any]]:
    """Add wrapped two- and three-line heading candidates."""
    candidates = list(lines)
    for start in range(len(lines)):
        group = [lines[start]]
        for offset in (1, 2):
            index = start + offset
            if index >= len(lines):
                break
            previous = group[-1]
            current = lines[index]
            if current["page"] != previous["page"] or current["block"] != previous["block"]:
                break
            larger = max(float(previous["size"]), float(current["size"]), 1.0)
            smaller = min(float(previous["size"]), float(current["size"]))
            gap = float(current["bbox"][1]) - float(previous["bbox"][3])
            if smaller / larger < 0.78 or gap > larger * 1.8:
                break
            group.append(current)
            text = normalize_title(" ".join(item["text"] for item in group))
            if len(text) > 300:
                break
            x0 = min(float(item["bbox"][0]) for item in group)
            y0 = min(float(item["bbox"][1]) for item in group)
            x1 = max(float(item["bbox"][2]) for item in group)
            y1 = max(float(item["bbox"][3]) for item in group)
            page_width = float(group[0]["page_width"])
            candidates.append(
                {
                    "text": text,
                    "page": group[0]["page"],
                    "block": group[0]["block"],
                    "line": group[0]["line"],
                    "bbox": (x0, y0, x1, y1),
                    "size": max(float(item["size"]) for item in group),
                    "bold": any(bool(item["bold"]) for item in group),
                    "centered": abs((x0 + x1) / 2.0 - page_width / 2.0) <= page_width * 0.12,
                    "y_ratio": float(group[0]["y_ratio"]),
                    "page_width": page_width,
                    "page_height": float(group[0]["page_height"]),
                    "line_count": len(group),
                }
            )
    return candidates


def score_candidate(
    line: Dict[str, Any],
    body_size: float,
    maximum_size: float,
    repeated_texts: Dict[str, int],
) -> Optional[Candidate]:
    """Score one possible title using typography, placement, and content."""
    text = normalize_title(line["text"])
    if not usable_title(text) or len(text) > 300:
        return None
    words = text.split()
    if len(words) > 36:
        return None
    folded = text.casefold()
    if any(folded.startswith(prefix) for prefix in NON_TITLE_PREFIXES):
        return None
    if re.fullmatch(r"(?:page\s+)?\d+(?:\s+of\s+\d+)?", folded):
        return None

    font_size = max(float(line["size"]), 1.0)
    size_ratio = font_size / max(body_size, 1.0)
    score = max(0.0, math.log(size_ratio, 2.0)) * 3.2
    score += (font_size / max(maximum_size, 1.0)) * 1.8
    score += (1.0 - float(line["y_ratio"])) * 2.0
    score -= int(line["page"]) * 0.65
    score += max(int(line.get("line_count", 1)) - 1, 0) * 0.35
    if bool(line["bold"]):
        score += 1.0
    if bool(line["centered"]):
        score += 1.25
    if 8 <= len(text) <= 180:
        score += 0.8
    if 2 <= len(words) <= 18:
        score += 0.45
    if text.isupper() and len(text) > 12:
        score += 0.2
    if text.endswith(('.', ';', ',')):
        score -= 0.4
    if repeated_texts.get(folded, 0) > 1:
        score -= 2.25
    if float(line["y_ratio"]) > 0.72:
        score -= 2.0
    if size_ratio < 1.12 and not bool(line["bold"]):
        score -= 3.0

    return Candidate(
        text=text,
        page=int(line["page"]) + 1,
        score=round(score, 4),
        font_size=round(font_size, 3),
        bold=bool(line["bold"]),
        centered=bool(line["centered"]),
        y_ratio=round(float(line["y_ratio"]), 4),
        line_count=int(line.get("line_count", 1)),
    )


def heading_candidates(document: Any, scan_pages: int) -> List[Candidate]:
    """Return ranked typographic title candidates from front-matter pages."""
    page_count = min(int(document.page_count), scan_pages)
    all_lines: List[Dict[str, Any]] = []
    font_samples: List[Tuple[float, int]] = []
    occurrence_pages: Dict[str, set] = {}
    for page_number in range(page_count):
        page_lines = extract_lines(document.load_page(page_number), page_number)
        all_lines.extend(page_lines)
        for line in page_lines:
            font_samples.append((float(line["size"]), len(str(line["text"]))))
            occurrence_pages.setdefault(str(line["text"]).casefold(), set()).add(page_number)
    if not all_lines:
        return []

    body_size = weighted_median(font_samples)
    maximum_size = max(float(line["size"]) for line in all_lines)
    repeated = {text: len(pages) for text, pages in occurrence_pages.items()}
    scored: List[Candidate] = []
    seen = set()
    for line in combined_lines(all_lines):
        identity = (int(line["page"]), normalize_title(line["text"]).casefold())
        if identity in seen:
            continue
        seen.add(identity)
        candidate = score_candidate(line, body_size, maximum_size, repeated)
        if candidate is not None:
            scored.append(candidate)
    return sorted(scored, key=lambda item: (-item.score, item.page, item.text.casefold()))


def confidence_from_score(score: float) -> float:
    """Map an open-ended heuristic score onto a conservative confidence value."""
    confidence = 0.50 + 0.45 / (1.0 + math.exp(-(score - 5.5) / 1.4))
    return round(min(max(confidence, 0.50), 0.95), 3)


def authenticate_document(document: Any, password: Optional[str], path: Path) -> None:
    """Authenticate an encrypted PDF or raise a stable CLI error."""
    if not bool(document.needs_pass):
        return
    if password is None:
        raise CLIError(
            f"encrypted PDF requires a password: {path} "
            "(use --password-file or PDF_PASSWORD)",
            5,
        )
    try:
        authenticated = bool(document.authenticate(password))
    except Exception as error:
        raise CLIError(f"could not authenticate encrypted PDF {path}: {error}", 5) from error
    if not authenticated:
        raise CLIError(f"incorrect password for encrypted PDF: {path}", 5)


def extract_title(
    path_text: str,
    method: str,
    scan_pages: int,
    password: Optional[str],
    verbose: bool,
) -> TitleResult:
    """Extract a title from one PDF according to the requested method."""
    path = Path(path_text).expanduser()
    try:
        resolved = path.resolve(strict=True)
    except FileNotFoundError as error:
        raise CLIError(f"file not found: {path}", 3) from error
    except OSError as error:
        raise CLIError(f"could not resolve input {path}: {error}", 3) from error
    if not resolved.is_file():
        raise CLIError(f"input is not a regular file: {resolved}", 3)

    try:
        document = pymupdf.open(str(resolved))
    except Exception as error:
        raise CLIError(f"could not open PDF {resolved}: {error}", 3) from error

    try:
        if not bool(getattr(document, "is_pdf", True)):
            raise CLIError(f"input is not a PDF document: {resolved}", 3)
        authenticate_document(document, password, resolved)
        metadata = document.metadata or {}
        metadata_title = normalize_title(metadata.get("title"))

        if method in {"auto", "metadata"} and usable_metadata_title(metadata_title):
            debug(f"{resolved}: selected metadata title {metadata_title!r}", verbose)
            return TitleResult(
                path=str(resolved),
                title=metadata_title,
                source="metadata",
                confidence=1.0,
                page=None,
                score=None,
                fallback=False,
            )
        if method == "metadata":
            raise CLIError(f"PDF metadata does not contain a usable title: {resolved}", 1)

        if method in {"auto", "heading"}:
            candidates = heading_candidates(document, scan_pages)
            for candidate in candidates[:5]:
                debug(
                    f"{resolved}: candidate score={candidate.score:.3f} "
                    f"page={candidate.page} size={candidate.font_size:.2f} "
                    f"lines={candidate.line_count} "
                    f"bold={candidate.bold} centered={candidate.centered} "
                    f"text={candidate.text!r}",
                    verbose,
                )
            if candidates and candidates[0].score >= 4.0:
                selected = candidates[0]
                return TitleResult(
                    path=str(resolved),
                    title=selected.text,
                    source="heading",
                    confidence=confidence_from_score(selected.score),
                    page=selected.page,
                    score=selected.score,
                    fallback=False,
                )
            if method == "heading":
                raise CLIError(f"no credible typographic heading was found: {resolved}", 1)

        fallback_title = filename_title(resolved)
        return TitleResult(
            path=str(resolved),
            title=fallback_title,
            source="filename",
            confidence=0.25,
            page=None,
            score=None,
            fallback=True,
        )
    finally:
        document.close()


def validate_output(output_text: Optional[str], inputs: Sequence[str], force: bool) -> Optional[Path]:
    """Validate and normalize an optional output path."""
    if output_text is None:
        return None
    output = Path(output_text).expanduser()
    try:
        output = output.resolve(strict=False)
    except OSError as error:
        raise CLIError(f"could not resolve output path: {error}", 4) from error
    if not output.parent.is_dir():
        raise CLIError(f"output directory does not exist: {output.parent}", 4)
    if output.exists() and output.is_dir():
        raise CLIError(f"output is a directory: {output}", 4)
    if output.exists() and not force:
        raise CLIError(f"output already exists: {output} (use --force)", 4)
    for path_text in inputs:
        try:
            input_path = Path(path_text).expanduser().resolve(strict=True)
        except OSError:
            continue
        if input_path == output:
            raise CLIError(f"refusing to overwrite input PDF with result output: {output}", 4)
    return output


def plain_line(result: TitleResult, multiple: bool, explain: bool) -> str:
    """Render one successful result as a tab-delimited plain-text line."""
    fields: List[str] = []
    if multiple:
        fields.append(result.path)
    fields.append(result.title)
    if explain:
        fields.extend(
            [
                result.source,
                f"{result.confidence:.3f}",
                str(result.page) if result.page is not None else "-",
            ]
        )
    return "\t".join(fields)


def render_results(
    successes: Sequence[TitleResult],
    failures: Sequence[ErrorResult],
    output_format: str,
    explain: bool,
    input_count: int,
) -> str:
    """Render successful and failed results in the selected format."""
    if output_format == "plain":
        return "".join(
            plain_line(result, input_count > 1, explain) + "\n" for result in successes
        )
    records: List[Dict[str, Any]] = [asdict(result) for result in successes]
    records.extend(asdict(failure) for failure in failures)
    if output_format == "jsonl":
        return "".join(
            json.dumps(record, ensure_ascii=False, sort_keys=True) + "\n" for record in records
        )
    return json.dumps(records, ensure_ascii=False, indent=2, sort_keys=True) + "\n"


def write_output(path: Optional[Path], content: str) -> None:
    """Write rendered results to stdout or an atomic output file."""
    if path is None:
        sys.stdout.write(content)
        return
    descriptor = -1
    temporary_name = ""
    previous_mode = stat.S_IMODE(path.stat().st_mode) if path.exists() else None
    try:
        descriptor, temporary_name = tempfile.mkstemp(
            prefix=f".{path.name}.",
            dir=str(path.parent),
            text=True,
        )
        with os.fdopen(descriptor, "w", encoding="utf-8", newline="\n") as stream:
            descriptor = -1
            stream.write(content)
            stream.flush()
            os.fsync(stream.fileno())
        if previous_mode is not None:
            os.chmod(temporary_name, previous_mode)
        os.replace(temporary_name, path)
    except OSError as error:
        if descriptor >= 0:
            os.close(descriptor)
        if temporary_name:
            try:
                Path(temporary_name).unlink()
            except OSError:
                pass
        raise CLIError(f"could not write output {path}: {error}", 4) from error


def process_inputs(
    paths: Sequence[str], args: argparse.Namespace, password: Optional[str]
) -> Tuple[List[TitleResult], List[ErrorResult], int]:
    """Process all inputs and return successes, failures, and aggregate status."""
    successes: List[TitleResult] = []
    failures: List[ErrorResult] = []
    for path_text in paths:
        try:
            result = extract_title(
                path_text,
                args.method,
                args.scan_pages,
                password,
                args.verbose,
            )
            successes.append(result)
        except CLIError as error:
            failure = ErrorResult(path=path_text, error=str(error), exit_code=error.exit_code)
            failures.append(failure)
            if args.format == "plain":
                print(f"{PROGRAM_NAME}: error: {error}", file=sys.stderr)
            if args.fail_fast:
                break
    if failures:
        aggregate_status = failures[0].exit_code if len(paths) == 1 else 1
    elif args.require_detected and any(result.fallback for result in successes):
        aggregate_status = 6
    else:
        aggregate_status = 0
    return successes, failures, aggregate_status


def main(argv: Optional[Sequence[str]] = None) -> int:
    """Run the pdf-title CLI."""
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        paths = read_input_paths(args.files)
        output = validate_output(args.output, paths, args.force)
        password = read_password(args.password_file)
        ensure_dependency(args)
        debug(f"PyMuPDF version: {dependency_version() or 'unknown'}", args.verbose)
        successes, failures, status = process_inputs(paths, args, password)
        content = render_results(successes, failures, args.format, args.explain, len(paths))
        write_output(output, content)
        if output is not None:
            log(f"saved {len(successes)} result(s) to {output}")
        if args.require_detected and any(result.fallback for result in successes):
            for result in successes:
                if result.fallback:
                    log(f"filename fallback rejected by --require-detected: {result.path}")
        return status
    except CLIError as error:
        print(f"{PROGRAM_NAME}: error: {error}", file=sys.stderr)
        return error.exit_code
    except KeyboardInterrupt:
        print(f"{PROGRAM_NAME}: interrupted", file=sys.stderr)
        return 130


if __name__ == "__main__":
    raise SystemExit(main())
