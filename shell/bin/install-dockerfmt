#!/usr/bin/env bash
set -euo pipefail

# ============================================
# install-dockerfmt
# Install dockerfmt (Dockerfile formatter) from GitHub release archive.
# Reference: https://github.com/reteps/dockerfmt
# Supports: latest, specific version, or specific SHA256
# ============================================

# -----------------------------
# Config
# -----------------------------
OWNER="reteps"
REPO="dockerfmt"
INSTALL_DIR="/usr/local/bin"

# Detect platform
OS="$(uname -s)"
ARCH="$(uname -m)"

case "$OS" in
  Linux)  PLATFORM="linux" ;;
  Darwin) PLATFORM="darwin" ;;
  *) echo "❌ Unsupported OS: $OS"; exit 1 ;;
esac

case "$ARCH" in
  x86_64)        ARCH_LABEL="amd64" ;;
  arm64|aarch64) ARCH_LABEL="arm64" ;;
  *) echo "❌ Unsupported architecture: $ARCH"; exit 1 ;;
esac

# -----------------------------
# Functions
# -----------------------------

get_latest_release() {
  curl -s "https://api.github.com/repos/$OWNER/$REPO/releases/latest" \
    | grep '"tag_name":' \
    | sed -E 's/.*"v([^"]+)".*/\1/'
}

download_and_install() {
  local version="$1"

  FILENAME="dockerfmt-v${version}-${PLATFORM}-${ARCH_LABEL}.tar.gz"
  DOWNLOAD_URL="https://github.com/${OWNER}/${REPO}/releases/download/v${version}/${FILENAME}"

  echo "📦 Downloading dockerfmt v${version} from ${DOWNLOAD_URL}..."
  curl -fsSL "$DOWNLOAD_URL" -o "/tmp/$FILENAME"

  # Verify checksum if md5 file is available
  MD5_URL="https://github.com/${OWNER}/${REPO}/releases/download/v${version}/${FILENAME}.md5"
  MD5_FILE="/tmp/dockerfmt_${FILENAME}.md5"
  if curl -fsSL "$MD5_URL" -o "$MD5_FILE" 2>/dev/null; then
    EXPECTED_MD5="$(awk '{print $1}' "$MD5_FILE")"
    if [[ -n "$EXPECTED_MD5" ]]; then
      echo "🔐 Verifying MD5 checksum..."
      if command -v md5sum >/dev/null 2>&1; then
        echo "${EXPECTED_MD5}  /tmp/${FILENAME}" | md5sum --check --quiet
      elif command -v md5 >/dev/null 2>&1; then
        ACTUAL_MD5="$(md5 -q "/tmp/${FILENAME}")"
        if [[ "$ACTUAL_MD5" != "$EXPECTED_MD5" ]]; then
          echo "❌ MD5 checksum mismatch: expected ${EXPECTED_MD5}, got ${ACTUAL_MD5}"
          exit 1
        fi
      else
        echo "⚠️  No md5sum or md5 found; skipping checksum verification"
      fi
      echo "✅ Checksum verified"
    fi
    rm -f "$MD5_FILE"
  fi

  echo "📂 Extracting and installing to $INSTALL_DIR..."
  tar -xzf "/tmp/$FILENAME" -C /tmp dockerfmt
  sudo mv "/tmp/dockerfmt" "$INSTALL_DIR/dockerfmt"
  sudo chmod +x "$INSTALL_DIR/dockerfmt"
  rm -f "/tmp/$FILENAME"

  echo "✅ Installed dockerfmt v${version} at $(command -v dockerfmt)"
  dockerfmt version
}

# -----------------------------
# Main
# -----------------------------
usage() {
  echo "Usage: $0 [--version x.y.z] [--help]"
  exit 1
}

VERSION=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --version)
      VERSION="$2"
      shift 2
      ;;
    --help|-h)
      usage
      ;;
    *)
      echo "❌ Unknown argument: $1"
      usage
      ;;
  esac
done

if [[ -z "$VERSION" ]]; then
  echo "🔍 Fetching latest dockerfmt release..."
  VERSION=$(get_latest_release)
fi

download_and_install "$VERSION"
