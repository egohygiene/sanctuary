# -----------------------------------------------------------------------------
# Universal .dockerignore
# -----------------------------------------------------------------------------
#
# Purpose:
#   Reduce Docker build context size, improve build performance,
#   and avoid copying unnecessary local/development artifacts into images.
#
# Design Goals:
#   - safe universal defaults
#   - cross-language compatibility
#   - monorepo friendly
#   - conservative exclusions
#
# Reference:
#   https://docs.docker.com/build/building/context/
#
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Version Control
# -----------------------------------------------------------------------------

.git/
.gitmodules
.hg/
.svn/

# -----------------------------------------------------------------------------
# Operating System Artifacts
# -----------------------------------------------------------------------------

.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Editor / IDE Files
# -----------------------------------------------------------------------------

.idea/
.vscode/

*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------

*.log
logs/

# -----------------------------------------------------------------------------
# Environment / Secrets
# -----------------------------------------------------------------------------

.env
.env.*
!.env.example

*.pem
*.key
*.crt

secrets/
secrets.yaml
secrets.yml
secrets.json

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------

node_modules/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

.next/
.nuxt/
.turbo/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------

__pycache__/

*.pyc
*.pyo
*.pyd

.Python

.pytest_cache/
.mypy_cache/
.ruff_cache/

.venv/
venv/
env/

# -----------------------------------------------------------------------------
# Java / JVM
# -----------------------------------------------------------------------------

target/
*.class

# -----------------------------------------------------------------------------
# Rust
# -----------------------------------------------------------------------------

target/

# -----------------------------------------------------------------------------
# Go
# -----------------------------------------------------------------------------

bin/

# -----------------------------------------------------------------------------
# Build Artifacts
# -----------------------------------------------------------------------------

build/
dist/
out/
release/
coverage/

# -----------------------------------------------------------------------------
# Temporary / Cache Directories
# -----------------------------------------------------------------------------

.cache/
tmp/
temp/

# -----------------------------------------------------------------------------
# Archives / Packages
# -----------------------------------------------------------------------------

*.tar
*.gz
*.tgz
*.bz2
*.xz
*.zip

# -----------------------------------------------------------------------------
# Containers / Orchestration
# -----------------------------------------------------------------------------

docker-compose.override.yml

# -----------------------------------------------------------------------------
# Dev Containers
# -----------------------------------------------------------------------------

.devcontainer/

# -----------------------------------------------------------------------------
# Testing / Mock Data
# -----------------------------------------------------------------------------

tests/
test/
__tests__/
__mocks__/
mocks/

# -----------------------------------------------------------------------------
# Media / Large Binary Assets
# -----------------------------------------------------------------------------

*.mp4
*.mp3
*.mov
*.psd

# -----------------------------------------------------------------------------
# Documentation Build Outputs
# -----------------------------------------------------------------------------

site/
docs/_build/

# -----------------------------------------------------------------------------
# Local Runtime Data
# -----------------------------------------------------------------------------

uploads/
volumes/
