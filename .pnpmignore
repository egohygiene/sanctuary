# -----------------------------------------------------------------------------
# Universal .pnpmignore
# -----------------------------------------------------------------------------
#
# Purpose:
#   Exclude development-only artifacts from published pnpm packages.
#
# Design Goals:
#   - conservative defaults
#   - safe package publishing
#   - cross-language compatibility
#   - monorepo friendly
#
# IMPORTANT:
#   Prefer using the "files" field in package.json for deterministic publishing
#   whenever possible.
#
# Reference:
#   https://pnpm.io/package_json#files
#
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Dependency Directories
# -----------------------------------------------------------------------------

node_modules/
.pnpm/

# -----------------------------------------------------------------------------
# Lock Files
# -----------------------------------------------------------------------------

pnpm-lock.yaml
package-lock.json
yarn.lock

# -----------------------------------------------------------------------------
# Build / Coverage Artifacts
# -----------------------------------------------------------------------------

coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# Temporary / Cache Files
# -----------------------------------------------------------------------------

.cache/
tmp/
temp/

*.log
*.tmp

# -----------------------------------------------------------------------------
# Editor / IDE Files
# -----------------------------------------------------------------------------

.idea/
.vscode/

*.swp
*.swo

*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Operating System Files
# -----------------------------------------------------------------------------

.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Test Files
# -----------------------------------------------------------------------------

test/
tests/
__tests__/
__mocks__/
mocks/

# -----------------------------------------------------------------------------
# Environment / Secrets
# -----------------------------------------------------------------------------

.env
.env.*

*.pem
*.key
*.crt

.secret

# -----------------------------------------------------------------------------
# Documentation Source Files
# -----------------------------------------------------------------------------
#
# NOTE:
# README.md and LICENSE should generally be published.
#

docs/

# -----------------------------------------------------------------------------
# Development Scripts
# -----------------------------------------------------------------------------

scripts/

# -----------------------------------------------------------------------------
# Development Containers / CI
# -----------------------------------------------------------------------------

.devcontainer/

.github/

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------

*.tsbuildinfo
