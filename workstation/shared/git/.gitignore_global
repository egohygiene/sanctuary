# ------------------------------------------------------------------------------
# Global Git Ignore
# ------------------------------------------------------------------------------
#
# Purpose:
#   Ignore operating system, editor, and user-specific artifacts that should
#   never be committed to any repository.
#
# Language- and project-specific ignores belong in repository-level
# .gitignore files.
#
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# macOS
# ------------------------------------------------------------------------------

.DS_Store
.AppleDouble
.LSOverride

.Spotlight-V100
.Trashes

._*

# ------------------------------------------------------------------------------
# Windows
# ------------------------------------------------------------------------------

Thumbs.db
ehthumbs.db
Desktop.ini

$RECYCLE.BIN/

# ------------------------------------------------------------------------------
# Linux
# ------------------------------------------------------------------------------

*~
.nfs*

# ------------------------------------------------------------------------------
# Vim
# ------------------------------------------------------------------------------

*.swp
*.swo
*.swn
*.un~

# ------------------------------------------------------------------------------
# Emacs
# ------------------------------------------------------------------------------

\#*\#
.\#*

# ------------------------------------------------------------------------------
# JetBrains
# ------------------------------------------------------------------------------

*.iws

# ------------------------------------------------------------------------------
# Temporary Files
# ------------------------------------------------------------------------------

*.tmp
*.bak
*.orig
*.rej
