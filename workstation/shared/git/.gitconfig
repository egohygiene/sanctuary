# ------------------------------------------------------------------------------
# Git Configuration
# ------------------------------------------------------------------------------
#
# Purpose:
#   Portable Git defaults for the Sanctuary developer platform.
#
# Machine-specific settings (user name, email, signing keys, etc.) should live
# in a separate local configuration or be configured using:
#
#   git config --global user.name "..."
#   git config --global user.email "..."
#
# Documentation:
#   https://git-scm.com/docs/git-config
#
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# Core
# ------------------------------------------------------------------------------

[core]
    excludesfile = ~/.gitignore_global

# ------------------------------------------------------------------------------
# Repository Initialization
# ------------------------------------------------------------------------------

[init]
    defaultBranch = main

# ------------------------------------------------------------------------------
# Pull / Push
# ------------------------------------------------------------------------------

[pull]
    rebase = false

[push]
    default = current
    autoSetupRemote = true

[fetch]
    prune = true

# ------------------------------------------------------------------------------
# Merge
# ------------------------------------------------------------------------------

[merge]
    conflictStyle = zdiff3

[rerere]
    enabled = true

# ------------------------------------------------------------------------------
# Diff
# ------------------------------------------------------------------------------

[diff]
    colorMoved = default

# ------------------------------------------------------------------------------
# Help
# ------------------------------------------------------------------------------

[help]
    autocorrect = prompt

# ------------------------------------------------------------------------------
# Aliases
# ------------------------------------------------------------------------------

[alias]

    # --------------------------------------------------------------------------
    # Status
    # --------------------------------------------------------------------------

    s  = status
    ss = status --short

    # --------------------------------------------------------------------------
    # Branches
    # --------------------------------------------------------------------------

    b  = branch
    ba = branch --all

    # --------------------------------------------------------------------------
    # Switching
    # --------------------------------------------------------------------------

    sw  = switch
    swc = switch --create

    # --------------------------------------------------------------------------
    # Restore
    # --------------------------------------------------------------------------

    rs = restore

    # --------------------------------------------------------------------------
    # Fetch / Sync
    # --------------------------------------------------------------------------

    f = fetch --all --prune

    sync = !"git fetch --all --prune && git pull"

    # --------------------------------------------------------------------------
    # Commit
    # --------------------------------------------------------------------------

    c  = commit
    ca = commit --amend

    # --------------------------------------------------------------------------
    # Push / Pull
    # --------------------------------------------------------------------------

    pl = pull
    ps = push

    # --------------------------------------------------------------------------
    # Diff
    # --------------------------------------------------------------------------

    d = diff

    # --------------------------------------------------------------------------
    # Logs
    # --------------------------------------------------------------------------

    lg = log --graph --decorate --oneline --all

    lga = log \
        --graph \
        --decorate \
        --abbrev-commit \
        --all \
        --pretty=format:"%C(auto)%h %C(cyan)%d%Creset %s %C(green)(%cr) %C(blue)<%an>%Creset"

    last = log -1 HEAD

    # --------------------------------------------------------------------------
    # Stash
    # --------------------------------------------------------------------------

    st = stash
    sp = stash pop
    sl = stash list

    # --------------------------------------------------------------------------
    # Tags
    # --------------------------------------------------------------------------

    tags = tag --list
