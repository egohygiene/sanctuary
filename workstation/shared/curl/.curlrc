# ------------------------------------------------------------------------------
# curl Configuration
# ------------------------------------------------------------------------------
#
# Purpose:
#   Portable defaults for interactive use of curl.
#
# Philosophy:
#   - Safe defaults
#   - Human-friendly output
#   - Automatic recovery from transient network failures
#   - Avoid changing request semantics
#
# Documentation:
#   https://curl.se/docs/manpage.html
#
# ------------------------------------------------------------------------------

# Follow HTTP redirects.
location

# Display errors even when running silently.
show-error

# Display a compact progress bar.
progress-bar

# Preserve server timestamps when downloading files.
remote-time

# Retry transient failures.
retry = 5

# Wait between retries.
retry-delay = 2

# Retry when the connection is refused.
retry-connrefused

# Retry all transient errors (curl ≥ 7.71).
retry-all-errors

# Maximum time allowed to establish a connection.
connect-timeout = 30

# Maximum time for the entire transfer.
max-time = 300

# Maximum redirects to follow.
max-redirs = 10

# Automatically send the previous URL as the Referer when following redirects.
referer = ";auto"

# Prefer compressed responses when supported.
compressed

# ------------------------------------------------------------------------------
# Optional Settings
# ------------------------------------------------------------------------------

# Uncomment for verbose debugging.
# verbose

# Uncomment to ignore certificate validation (NOT recommended).
# insecure

# Uncomment to save response headers.
# include

# Uncomment to force IPv4.
# ipv4

# Uncomment to force IPv6.
# ipv6

# Uncomment to use a SOCKS proxy.
# socks5 = localhost:9050
# -----------------------------------------------------------------------------
# cURL Configuration
# -----------------------------------------------------------------------------
#
# Ego Hygiene Engineering Standard
#
# Documentation:
#   https://curl.se/docs/manpage.html
#
# Purpose:
#   Provides opinionated defaults for interactive cURL usage while remaining
#   conservative, portable, and safe across operating systems.
#
# Design Goals:
#   - Conservative defaults
#   - Predictable behavior
#   - Human-friendly output
#   - Automatic recovery from transient failures
#   - Avoid changing HTTP request semantics
#
# Notes:
#   These defaults are intended for interactive use. Scripts should continue
#   to specify any behavior they depend on explicitly.
# -----------------------------------------------------------------------------

###############################################################################
# Networking
###############################################################################

# Follow HTTP redirects.
location

# Maximum time allowed to establish a connection.
connect-timeout = 30

# Maximum number of redirects to follow.
max-redirs = 10

###############################################################################
# Reliability
###############################################################################

# Retry transient failures.
retry = 5

# Wait between retry attempts.
retry-delay = 2

# Retry when the connection is refused.
retry-connrefused

# Retry all transient errors (curl >= 7.71).
retry-all-errors

###############################################################################
# Output
###############################################################################

# Display errors even when running silently.
show-error

# Display a compact progress bar.
progress-bar

# Preserve server timestamps when downloading files.
remote-time

###############################################################################
# HTTP
###############################################################################

# Automatically send the previous URL as the Referer when following redirects.
referer = ";auto"

# Request compressed responses when supported.
compressed

###############################################################################
# Optional Settings
###############################################################################

# Uncomment for verbose debugging.
# verbose

# Uncomment to include HTTP response headers in the output.
# include

# Uncomment to fail on HTTP 4xx/5xx responses.
# fail

# Uncomment to force IPv4.
# ipv4

# Uncomment to force IPv6.
# ipv6

# Uncomment to use a SOCKS5 proxy.
# socks5 = localhost:9050

# Uncomment to disable TLS certificate verification.
# Use ONLY for local development or debugging.
# insecure
