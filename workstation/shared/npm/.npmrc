# ------------------------------------------------------------------------------
# npm User Configuration
# ------------------------------------------------------------------------------
#
# Purpose:
#   Portable defaults for interactive npm usage.
#
# Documentation:
#   https://docs.npmjs.com/cli/configuring-npm/npmrc
#
# ------------------------------------------------------------------------------

# Save exact dependency versions.
save-exact = true

# Do not display funding messages after installs.
fund = false

# Disable automatic audit during installs.
audit = false

# Use the modern web authentication flow.
auth-type = web

# Retry transient fetch failures.
fetch-retries = 3

# Prefer cached packages when possible.
prefer-offline = true

# Use colored output.
color = true

# Display progress bars.
progress = true

# Keep package-lock files.
package-lock = true

# Use strict engine checks.
engine-strict = true

# Store cache under XDG when possible.
cache = ~/.cache/npm

# ------------------------------------------------------------------------------
# Optional Settings
# ------------------------------------------------------------------------------

# registry=https://registry.npmjs.org/
# ignore-scripts=false
# loglevel=notice
