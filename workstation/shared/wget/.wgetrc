# ------------------------------------------------------------------------------
# Wget Configuration
# ------------------------------------------------------------------------------
#
# Purpose:
#   Portable defaults for interactive use of GNU Wget.
#
# Philosophy:
#   - Safe defaults
#   - Human-friendly downloads
#   - Automatic recovery from transient failures
#   - Preserve server metadata
#
# Documentation:
#   https://www.gnu.org/software/wget/manual/
#
# ------------------------------------------------------------------------------

# Reject automatically generated directory index pages.
reject = index.html*

# Continue interrupted downloads.
continue = on

# Retry transient failures.
tries = 5

# Retry when the connection is refused.
retry_connrefused = on

# Wait briefly between retries.
waitretry = 5

# Preserve server timestamps.
timestamping = on
use_server_timestamps = on

# Follow redirects using the server-provided filename.
trust_server_names = on

# Enable HTTP compression.
compression = auto

# Keep HTTP keep-alive enabled.
http_keep_alive = on

# Enable certificate verification.
check_certificate = on

# Prefer IPv4 when both families are available.
prefer_family = IPv4

# Maximum connection timeout.
connect_timeout = 30

# Maximum read timeout.
read_timeout = 300

# Overall timeout.
timeout = 300

# Display useful progress.
progress = bar

# Be quiet unless errors occur.
quiet = off
verbose = off

# Store HSTS cache under the XDG configuration directory.
hstsfile = ~/.config/wget/.wget-hsts

# ------------------------------------------------------------------------------
# Optional Settings
# ------------------------------------------------------------------------------

# user_agent = Mozilla/5.0 (...)
# limit_rate = 5m
# recursive = on
# mirror = on
# robots = off
# no_proxy = localhost,127.0.0.1,::1
