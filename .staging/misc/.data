#!/bin/sh

export GHCUP_USE_XDG_DIRS="true"
export PYTHONIOENCODING="UTF-8"
export PYTHONUTF8=1
export POETRY_PREVIEW=1
export PIPENV_VENV_IN_PROJECT=1
export LANG="en_US"
export LC_ALL="en_US.UTF-8"

# Colorize GCC warnings and errors.
export GCC_COLORS='error=01;31:warning=01;35:note=01;36:caret=01;32:locus=01:quote=01'

# Avoid issues with `gpg` as installed via Homebrew.
# https://stackoverflow.com/a/42265848/96656
export GPG_TTY=$(tty);

export CLICOLOR=1

export MAVEN_OPTS="-Dmaven.repo.local=$M2_HOME/repos"

[ -s "$CARGO_HOME/env" ] && . "$CARGO_HOME/env"
[ -s "${NVM_DIR}/nvm.sh" ] && \. "${NVM_DIR}/nvm.sh"
[ -s "${NVM_DIR}/bash_completion" ] && \. "${NVM_DIR}/bash_completion"

[ -d "$WAKATIME_HOME" ] || mkdir -p "$WAKATIME_HOME"

case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# Need to set reports directory for all
export NODE_OPTIONS="--max-old-space-size=4096 --report-directory=$USER_SYS_REPORTS/node"












# Set Java directory.
# https://www.java.com/
export JAVA_HOME="$USER_SYS_APPS/java/jdks/openjdk17"

# Set the JDK for Intellij.
export IDEA_JDK="$JAVA_HOME"

# Set android home directory.
export ANDROID_HOME="$USER_SYS_APPS/android/.android"

# Set the android sdk preferences directory.
export ANDROID_SDK_HOME="$ANDROID_HOME/.sdk"

# Set the installation directory of the Android NDK package.
export ANDROID_NDK_ROOT="$ANDROID_HOME/.ndk"

# Set android emulator configuration.
export ANDROID_EMULATOR_HOME="$ANDROID_HOME/emulator"
export ANDROID_AVD_HOME="$ANDROID_EMULATOR_HOME/avd"
export ANDROID_EMULATOR_USE_SYSTEM_LIBS=0

# Android studio configuration.
export STUDIO_CONFIG_DIR="$USER_SYS_CONFIG/android-studio"
export STUDIO_VM_OPTIONS="$STUDIO_CONFIG_DIR/studio.vmoptions"
export STUDIO_PROPERTIES="$STUDIO_CONFIG_DIR/idea.properties"
export STUDIO_JDK="$JAVA_HOME"
export STUDIO_GRADLE_JDK="$JAVA_HOME"

# Dart server directory.
export ANALYZER_STATE_LOCATION_OVERRIDE="$USER_SYS_APPS/dart/.dartServer"


# Nuget packages directory.
export NUGET_PACKAGES="$USER_SYS_APPS/.nuget/packages"


# hledger file.
export LEDGER_FILE="$USER_SYS_APPS/hledger/.hledger.journal"

# wine:
export WINEPREFIX="$USER_SYS_APPS/wine"


# julia
export JULIA_DEPOT_PATH="$USER_SYS_APPS/julia:$JULIA_DEPOT_PATH" 

# Set the pip configuration file.
export PIP_CONFIG_FILE="$USER_SYS_CONFIG/pip/pip.conf"

# Set docker client configuration file.
export DOCKER_CONFIG="$USER_SYS_CONFIG/docker"

# Location of curl configuration file.
export CURLRC="$USER_SYS_CONFIG/curl/.curlrc"

# Set the location of the wget startup file.
export WGETRC="$USER_SYS_CONFIG/wget/.wgetrc"

# Set inputrc configuration file.
export INPUTRC="$USER_SYS_CONFIG/readline/.inputrc"

# npm configuration: 
export NPM_CONFIG_USERCONFIG="$USER_SYS_CONFIG/npm/.npmrc"

# GTK 1.0:
export GTK_RC_FILES="$USER_SYS_CONFIG/gtk-1.0/gtkrc"

# Set screenrc configuration file.
# https://www.gnu.org/software/screen/manual/html_node/Startup-Files.html
export SCREENRC="$USER_SYS_CONFIG/screen/.screenrc"

# Nvidia settings configuration file.
export NVIDIA_SETTINGS_RC="$USER_SYS_CONFIG/nvidia/.nvidia-settings-rc"

# mpv video player configuration.
# https://mpv.io/manual/stable/#environment-variables
export MPV_HOME="$USER_SYS_CONFIG/mpv"
export MPV_VERBOSE="0"
export MPV_LEAK_REPORT="0"

# Set gtk2 rc file location.
export GTK2_RC_FILES="$USER_SYS_CONFIG/gtk-2.0/gtkrc"

# Set python startup script location.
export PYTHONSTARTUP="$USER_SYS_CONFIG/python/.pythonrc"

# Set the Jupyter configuration directory.
export JUPYTER_CONFIG_DIR="$USER_SYS_CONFIG/jupyter"

# Set Intellij's VM options overrides file.
export IDEA_VM_OPTIONS="$USER_SYS_CONFIG/intellij/idea.vmoptions"

# Set Intellij's platform properties overrides file.
export IDEA_PROPERTIES="$USER_SYS_CONFIG/intellij/idea.properties"

# Amazon Web Services (AWS) - aws-cli
export AWS_SHARED_CREDENTIALS_FILE="$USER_SYS_CONFIG/aws/credentials"
export AWS_CONFIG_FILE="$USER_SYS_CONFIG/aws/config"

# jupyter
export JUPYTER_CONFIG_DIR="$USER_SYS_CONFIG/jupyter"

# openjdk
export _JAVA_OPTIONS="-Djava.util.prefs.userRoot='$USER_SYS_CONFIG/java' -Djavafx.cachedir='$XDG_CACHE_HOME/openjfx'"

# asdf
export ASDF_CONFIG_FILE="$USER_SYS_CONFIG/asdf/asdfrc"

# aspell
export ASPELL_CONF="per-conf $USER_SYS_CONFIG/aspell/aspell.conf; personal $USER_SYS_CONFIG/aspell/en.pws; repl $USER_SYS_CONFIG/aspell/en.prepl"

# bash-completion
export BASH_COMPLETION_USER_FILE="$USER_SYS_CONFIG/bash-completion/bash_completion"

# GEF
export GEF_RC="$USER_SYS_CONFIG/gef/.gef.rc"

# ack: https://linux.die.net/man/1/ack
export ACKRC="$USER_SYS_CONFIG/ack/.ackrc"

# most
# https://manpages.ubuntu.com/manpages/lunar/en/man1/most.1.html
export MOST_INITFILE="$USER_SYS_CONFIG/most/mostrc"

# ncmpc
# https://manpages.ubuntu.com/manpages/lunar/en/man1/ncmpc.1.html
export NCMPC_CONFIG_DIR="$USER_SYS_CONFIG/ncmpc/config"

# Set xsel logfile location.
export XSEL_LOGFILE="$USER_SYS_LOGS/xsel/.xsel.log"

# Calibre settings
# https://manual.calibre-ebook.com/customize.html#id1
export CALIBRE_CONFIG_DIRECTORY="$USER_SYS_CONFIG/calibre"
export CALIBRE_TEMP_DIR="$USER_SYS_TEMP/calibre"

# urxvtd
export RXVT_SOCKET="$XDG_RUNTIME_DIR/urxvtd"

# Homebrew logs directory.
export HOMEBREW_LOGS="$USER_SYS_LOGS/homebrew"

# Homebrew temp directory.
export HOMEBREW_TEMP="$USER_SYS_TEMP/homebrew"

export GVIMINIT='let $MYGVIMRC="$USER_SYS_CONFIG/vim/gvimrc" | source $MYGVIMRC'
export VIMINIT='let $MYVIMRC="$USER_SYS_CONFIG/vim/vimrc" | source $MYVIMRC'


