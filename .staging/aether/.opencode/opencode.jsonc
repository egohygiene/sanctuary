{
  "$schema": "https://opencode.ai/config.json",

  "username": "alan",
  "logLevel": "INFO",

  "model": "ollama/llama3.1",
  "small_model": "ollama/phi",

  "default_agent": "build",

  "share": "disabled",

  "agent": {
    "build": {
      "name": "build",
      "description": "A helpful builder agent that can use tools to get things done.",
      "prompt": "You are a helpful builder agent that can use tools to get things done. Always try to use tools when appropriate, and be concise in your responses.",
      "model": "ollama/llama3.1",
      "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",

        "edit": "deny",
        "bash": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "lsp": "deny",
        "todowrite": "deny",
        "skill": "allow",
        "question": "allow"
      }
    }
  },

  "permission": {
    "read": "allow",
    "edit": "allow",
    "grep": "allow",
    "glob": "allow",
    "bash": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "todowrite": "allow",
    "question": "allow",
    "lsp": "allow",
    "skill": "allow"
  },

  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3
  },

  "provider": {
    "ollama": {
      "name": "Ollama Local",
      "api": "http://localhost:11434/v1",
      "models": {
        "llama3.1": {
          "id": "llama3.1",
          "name": "Llama 3",
          "family": "llama",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 8192,
            "output": 2048
          }
        },

        "phi": {
          "id": "phi",
          "name": "Phi (fast)",
          "family": "phi",
          "reasoning": false,
          "tool_call": false,
          "limit": {
            "context": 4096,
            "output": 1024
          }
        },

        "mistral": {
          "id": "mistral",
          "name": "Mistral (balanced)",
          "family": "mistral",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 8192,
            "output": 2048
          }
        }
      }
    }
  }
}

