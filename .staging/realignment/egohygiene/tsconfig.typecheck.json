{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",

  "compilerOptions": {
    "noEmit": true
  },

  "include": [
    "apps/**/*",
    "packages/**/*",
    "astro.config.*",
    "vite.config.*",
    "vitest.config.*",
    "types/**/*.d.ts"
  ],

  "exclude": [
    "node_modules",
    "dist",
    "dist-node",
    "coverage",
    "generated",
    ".cache"
  ],

  "typeRoots": ["./types", "./node_modules/@types"]
}
