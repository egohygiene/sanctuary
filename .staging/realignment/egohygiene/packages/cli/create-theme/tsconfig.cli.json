{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../../../tsconfig.base.json",

  "compilerOptions": {
    "composite": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "declaration": false,
    "noEmit": false,
    "types": ["node"]
  },

  "include": [
    "scripts",
    "src/utils/cli",
    "vite.config.ts"
  ],

  "exclude": [
    "node_modules",
    "dist",
    "generated"
  ]
}
