#!/bin/bash

# Check if an argument is provided
if [ "$#" -ne 1 ]; then
    echo "Usage: $0 <image_file>"
    exit 1
fi

# Input file
input_image=$1

# Output file (change extension to .ico)
output_image="${input_image%.*}.ico"

# Convert image to ICO format
convert "$input_image" -resize 256x256 "$output_image"

echo "Converted $input_image to $output_image"
