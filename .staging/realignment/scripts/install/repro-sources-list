#!/usr/bin/env bash
# shellcheck shell=bash
set -Eeuo pipefail

## @file repro-sources-list
## @brief Configure APT to use a reproducible snapshot of Ubuntu or Debian package sources.
## @version 1.0.0
## @description
##   Replaces the current APT sources with a pinned snapshot URL from either
##   snapshot.ubuntu.com or snapshot.debian.org, making package installations
##   reproducible across builds. Supports both the legacy sources.list format
##   (Ubuntu ≤ 23.10, Debian) and the modern DEB822 .sources format (Ubuntu ≥ 24.04).
##
##   Adapted from https://github.com/reproducible-containers/repro-sources-list.sh
##   (Apache-2.0 license)
## @usage
##   repro-sources-list [TIMESTAMP]
##   repro-sources-list 20240101T000000Z
## @arg TIMESTAMP  Optional snapshot timestamp in YYYYMMDDTHHMMSSZ format.
##                 Defaults to the current UTC date/time.
## @env ID                   OS identifier from /etc/os-release (ubuntu or debian).
## @env VERSION_CODENAME     Release codename from /etc/os-release.
## @env UBUNTU_CODENAME      Ubuntu-specific codename (used when VERSION_CODENAME is absent).
## @exitcode 0  Sources configured successfully.
## @exitcode 1  Unsupported distribution or missing OS metadata.

TIMESTAMP="${1:-}"

if [[ -z "${TIMESTAMP}" ]]; then
  TIMESTAMP="$(date -u +%Y%m%dT%H%M%SZ)"
  echo "⏱️  No timestamp provided; using current UTC time: ${TIMESTAMP}" >&2
fi

# ---------------------------------------------------------------------------
# Load OS metadata
# ---------------------------------------------------------------------------
if [[ ! -f /etc/os-release ]]; then
  echo "❌ /etc/os-release not found; cannot detect distro." >&2
  exit 1
fi

# shellcheck disable=SC1091
. /etc/os-release

DISTRO="${ID:-}"
CODENAME="${VERSION_CODENAME:-${UBUNTU_CODENAME:-}}"

if [[ -z "${DISTRO}" ]]; then
  echo "❌ Could not determine OS ID from /etc/os-release." >&2
  exit 1
fi

if [[ -z "${CODENAME}" ]]; then
  echo "❌ Could not determine release codename from /etc/os-release." >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Helper: detect whether the system uses DEB822 sources (Ubuntu 24.04+).
# Ubuntu 24.04 (Noble) and later ship with /etc/apt/sources.list.d/ubuntu.sources
# in DEB822 format instead of the legacy one-per-line sources.list.
# ---------------------------------------------------------------------------
_uses_deb822() {
  # Prefer an explicit check for the default DEB822 sources file that Ubuntu
  # 24.04+ creates; fall back to checking the apt version for edge cases.
  if [[ -f /etc/apt/sources.list.d/ubuntu.sources ]]; then
    return 0
  fi
  local ver
  ver="$(dpkg-query --showformat='${Version}' --show apt 2>/dev/null || echo '0')"
  dpkg --compare-versions "${ver}" ge "2.7.14" 2>/dev/null
}

# ---------------------------------------------------------------------------
# Ubuntu
# ---------------------------------------------------------------------------
_configure_ubuntu() {
  local snapshot_url="http://snapshot.ubuntu.com/ubuntu/${TIMESTAMP}"

  echo "🔗 Ubuntu snapshot URL: ${snapshot_url}"

  if _uses_deb822; then
    # Ubuntu 24.04+ — DEB822 (.sources) format
    echo "🗂️  Configuring DEB822 sources for Ubuntu ${CODENAME}…"

    # Truncate the legacy sources.list (leave it empty rather than removing
    # it so tools that expect the file to exist don't break).
    truncate -s 0 /etc/apt/sources.list

    # Disable all existing .list and .sources files in sources.list.d to
    # prevent them from overriding the snapshot.
    shopt -s nullglob
    for f in /etc/apt/sources.list.d/*.list /etc/apt/sources.list.d/*.sources; do
      # Skip files we already created on a previous run
      [[ "${f}" == */snapshot.sources ]] && continue
      mv "${f}" "${f}.disabled"
      echo "   ↳ Disabled: ${f}"
    done
    shopt -u nullglob

    cat > /etc/apt/sources.list.d/snapshot.sources <<EOF
# Reproducible snapshot — ${TIMESTAMP}
# Generated by repro-sources-list (https://github.com/reproducible-containers/repro-sources-list.sh)
Types: deb
URIs: ${snapshot_url}
Suites: ${CODENAME} ${CODENAME}-updates ${CODENAME}-security
Components: main restricted universe multiverse
Signed-By: /usr/share/keyrings/ubuntu-archive-keyring.gpg
EOF

    echo "✅ Wrote /etc/apt/sources.list.d/snapshot.sources"

  else
    # Ubuntu ≤ 23.10 — legacy one-per-line format
    echo "🗂️  Configuring legacy sources.list for Ubuntu ${CODENAME}…"

    shopt -s nullglob
    for f in /etc/apt/sources.list.d/*.list; do
      mv "${f}" "${f}.disabled"
      echo "   ↳ Disabled: ${f}"
    done
    shopt -u nullglob

    cat > /etc/apt/sources.list <<EOF
# Reproducible snapshot — ${TIMESTAMP}
# Generated by repro-sources-list (https://github.com/reproducible-containers/repro-sources-list.sh)
deb ${snapshot_url}/ ${CODENAME} main restricted universe multiverse
deb ${snapshot_url}/ ${CODENAME}-updates main restricted universe multiverse
deb ${snapshot_url}/ ${CODENAME}-security main restricted universe multiverse
EOF

    echo "✅ Wrote /etc/apt/sources.list"
  fi
}

# ---------------------------------------------------------------------------
# Debian
# ---------------------------------------------------------------------------
_configure_debian() {
  local snapshot_url="http://snapshot.debian.org/archive/debian/${TIMESTAMP}"
  local security_url="http://snapshot.debian.org/archive/debian-security/${TIMESTAMP}"

  echo "🔗 Debian snapshot URL: ${snapshot_url}"
  echo "🔗 Debian security snapshot URL: ${security_url}"

  shopt -s nullglob
  for f in /etc/apt/sources.list.d/*.list /etc/apt/sources.list.d/*.sources; do
    [[ "${f}" == */snapshot.sources ]] && continue
    mv "${f}" "${f}.disabled"
    echo "   ↳ Disabled: ${f}"
  done
  shopt -u nullglob

  cat > /etc/apt/sources.list <<EOF
# Reproducible snapshot — ${TIMESTAMP}
# Generated by repro-sources-list (https://github.com/reproducible-containers/repro-sources-list.sh)
deb ${snapshot_url}/ ${CODENAME} main
deb ${snapshot_url}/ ${CODENAME}-updates main
deb ${security_url}/ ${CODENAME}-security main
EOF

  echo "✅ Wrote /etc/apt/sources.list"
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
case "${DISTRO}" in
  ubuntu) _configure_ubuntu ;;
  debian) _configure_debian ;;
  *)
    echo "❌ Unsupported distribution: '${DISTRO}'. Only 'ubuntu' and 'debian' are supported." >&2
    exit 1
    ;;
esac

echo "📌 APT sources pinned to snapshot: ${TIMESTAMP}"
