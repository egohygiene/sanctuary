#!/usr/bin/env bash
# shellcheck shell=bash
set -Eeuo pipefail

## @file install-gitinspector
## @brief Install gitinspector (Git repository statistics analyzer) via pip.
## @version 1.0.0
## @description
##   Installs gitinspector from PyPI using pip and verifies the installation.
##   gitinspector generates statistical reports for Git repositories.
##   Reference: https://github.com/ejwa/gitinspector
##
## @usage
##   install-gitinspector [--version <version>] [--debug] [--no-color]
##
## @options
##   --version <v>    Package version to install (default: latest).
##   --debug          Extra logging.
##   --no-color       Disable ANSI colors in logs.
##   -h, --help       Show help and exit.
##
## @env GITINSPECTOR_VERSION    Package version (default: latest).
## @env DEBUG                   Verbose logs when "true".
## @env USE_COLOR               ANSI color (default true).

# ---------------- defaults ----------------
GITINSPECTOR_VERSION="${GITINSPECTOR_VERSION:-}"
USE_COLOR="${USE_COLOR:-true}"
DEBUG="${DEBUG:-false}"

# ---------------- logging ----------------
color() { [[ "${USE_COLOR}" == true ]] || { printf ''; return; }
  case "${1:-}" in red) printf '\033[31m';; green) printf '\033[32m';;
    yellow) printf '\033[33m';; cyan) printf '\033[36m';; reset) printf '\033[0m';; esac; }
log() { local t="$1"; shift || true; local p c;
  case "$t" in info) p='👉'; c=$(color cyan);;
    ok) p='✅'; c=$(color green);;
    warn) p='⚠️ '; c=$(color yellow);;
    err) p='❌'; c=$(color red);;
    dbg) [[ "${DEBUG}" == true ]] || return 0; p='🐞'; c=$(color cyan);;
    *) p=''; c=$(color reset);; esac
  printf '%s%s %s%s\n' "$c" "$p" "$*" "$(color reset)" >&2; }
die() { local c="$1"; shift || true; log err "$*"; exit "$c"; }
[[ -t 2 ]] || USE_COLOR=false
have() { command -v "$1" >/dev/null 2>&1; }

usage() { sed -n '2,120p' "${BASH_SOURCE[0]}" | sed -n '/^## @file/,/^## @env/p' | sed 's/^## \{0,1\}//'; }

# ---------------- args ----------------
while [[ $# -gt 0 ]]; do
  case "$1" in
    --version)   GITINSPECTOR_VERSION="$2"; shift ;;
    --debug)     DEBUG=true ;;
    --no-color)  USE_COLOR=false ;;
    -h|--help)   usage; exit 0 ;;
    *) die 1 "Unknown option: $1" ;;
  esac; shift
done

# ---------------- install ----------------
install_gitinspector() {
  have pip || have pip3 || die 127 "pip is required but not found"

  local pip_cmd
  pip_cmd="$(command -v pip3 2>/dev/null || command -v pip)"

  local package="gitinspector"
  if [[ -n "${GITINSPECTOR_VERSION}" ]]; then
    package="gitinspector==${GITINSPECTOR_VERSION}"
  fi

  log info "Installing ${package} via pip…"
  "${pip_cmd}" install --no-cache-dir "${package}"
}

# ---------------- verify ----------------
verify() {
  log info "Verifying gitinspector on PATH…"
  if have gitinspector; then
    gitinspector --version 2>/dev/null || true
    log ok "gitinspector installed: $(command -v gitinspector)"
  else
    die 1 "gitinspector not found after install"
  fi
}

main() {
  install_gitinspector
  verify
  log ok "Done."
}

main "$@"
