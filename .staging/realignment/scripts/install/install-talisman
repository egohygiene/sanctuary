#!/usr/bin/env bash
set -euo pipefail

# ============================================
# install-talisman
# Install Talisman as a global git hook from GitHub release.
# Reference: https://thoughtworks.github.io/talisman/docs/installation/global-hook/
# Supports: latest or specific version
# ============================================

# -----------------------------
# Config
# -----------------------------
OWNER="thoughtworks"
REPO="talisman"
TALISMAN_HOME="${TALISMAN_HOME:-${HOME}/.talisman}"
HOOKS_DIR="${TALISMAN_HOOKS_DIR:-${HOME}/.git-templates/hooks}"
HOOK_TYPE="${HOOK_TYPE:-pre-commit}"

# Detect platform
OS="$(uname -s)"
ARCH="$(uname -m)"

case "$OS" in
  Linux)  PLATFORM="linux" ;;
  Darwin) PLATFORM="darwin" ;;
  *) echo "❌ Unsupported OS: $OS"; exit 1 ;;
esac

case "$ARCH" in
  x86_64|amd64)  ARCH_LABEL="amd64" ;;
  arm64|aarch64) ARCH_LABEL="arm64" ;;
  i386|i686)     ARCH_LABEL="386" ;;
  *) echo "❌ Unsupported architecture: $ARCH"; exit 1 ;;
esac

# -----------------------------
# Functions
# -----------------------------

get_latest_release() {
  curl -s "https://api.github.com/repos/$OWNER/$REPO/releases/latest" \
    | grep '"tag_name":' \
    | sed -E 's/.*"v([^"]+)".*/\1/'
}

download_and_install() {
  local version="$1"

  BINARY_NAME="talisman_${PLATFORM}_${ARCH_LABEL}"
  DOWNLOAD_URL="https://github.com/${OWNER}/${REPO}/releases/download/v${version}/${BINARY_NAME}"

  echo "📦 Downloading Talisman v${version} from ${DOWNLOAD_URL}..."

  mkdir -p "${TALISMAN_HOME}/bin"
  curl -fsSL "$DOWNLOAD_URL" -o "${TALISMAN_HOME}/bin/talisman"

  # Verify checksum using the checksums file (no extension)
  CHECKSUMS_URL="https://github.com/${OWNER}/${REPO}/releases/download/v${version}/checksums"
  CHECKSUMS_FILE="/tmp/talisman_checksums"
  if curl -fsSL "$CHECKSUMS_URL" -o "$CHECKSUMS_FILE" 2>/dev/null; then
    EXPECTED=$(grep "${BINARY_NAME}$" "$CHECKSUMS_FILE" | awk '{print $1}' || true)
    if [[ -n "$EXPECTED" ]]; then
      echo "🔐 Verifying checksum..."
      if command -v sha256sum >/dev/null 2>&1; then
        echo "${EXPECTED}  ${TALISMAN_HOME}/bin/talisman" | sha256sum --check --quiet
      elif command -v shasum >/dev/null 2>&1; then
        echo "${EXPECTED}  ${TALISMAN_HOME}/bin/talisman" | shasum -a 256 --check --quiet
      else
        echo "⚠️  No sha256sum or shasum found; skipping checksum verification"
      fi
      echo "✅ Checksum verified"
    fi
    rm -f "$CHECKSUMS_FILE"
  fi

  chmod +x "${TALISMAN_HOME}/bin/talisman"
  echo "✅ Installed Talisman v${version} to ${TALISMAN_HOME}/bin/talisman"
}

setup_global_hook() {
  echo "🔧 Setting up Talisman as a global git hook (${HOOK_TYPE})..."

  mkdir -p "$HOOKS_DIR"

  # Determine which hook types to install
  local hook_types=()
  case "$HOOK_TYPE" in
    pre-commit) hook_types=("pre-commit") ;;
    pre-push)   hook_types=("pre-push") ;;
    both)       hook_types=("pre-commit" "pre-push") ;;
    *)
      echo "❌ Unknown hook type: $HOOK_TYPE (valid: pre-commit, pre-push, both)"
      exit 1
      ;;
  esac

  for hook in "${hook_types[@]}"; do
    HOOK_FILE="${HOOKS_DIR}/${hook}"
    cat > "$HOOK_FILE" <<'HOOK_SCRIPT'
#!/usr/bin/env bash
# Talisman global git hook — auto-generated by install-talisman
CMD="${TALISMAN_HOME:-$HOME/.talisman}/bin/talisman"
if [[ ! -x "$CMD" ]]; then
  echo "⚠️  Talisman not found at $CMD; skipping hook"
  exit 0
fi
HOOK_SCRIPT
    # Append the hook-type-specific invocation (use single-quotes to write literal $CMD)
    echo '"$CMD" --githook '"${hook}" >> "$HOOK_FILE"
    chmod +x "$HOOK_FILE"
    echo "✅ Installed ${hook} hook at ${HOOK_FILE}"
  done

  # Configure git to use the global hooks directory
  git config --global core.hooksPath "$HOOKS_DIR"
  echo "✅ Configured git global core.hooksPath → ${HOOKS_DIR}"

  echo ""
  echo "💡 Add the following to your shell profile (~/.bashrc, ~/.zshrc, etc.):"
  echo "   export TALISMAN_HOME=\"${TALISMAN_HOME}\""
  echo "   export PATH=\"\${TALISMAN_HOME}/bin:\${PATH}\""
}

# -----------------------------
# Main
# -----------------------------
usage() {
  cat <<EOF
Usage: $0 [OPTIONS]

Options:
  --version VERSION     Talisman version to install (default: latest)
  --hook-type TYPE      Hook type: pre-commit, pre-push, or both (default: pre-commit)
  --skip-hook           Install binary only; skip global git hook setup
  --talisman-home DIR   Directory to install Talisman (default: \$HOME/.talisman)
  --hooks-dir DIR       Global git hooks directory (default: \$HOME/.git-templates/hooks)
  -h, --help            Show this help message

Environment variables:
  TALISMAN_HOME         Install directory (default: \$HOME/.talisman)
  TALISMAN_HOOKS_DIR    Git hooks directory (default: \$HOME/.git-templates/hooks)
  HOOK_TYPE             Hook type (default: pre-commit)
EOF
  exit 1
}

VERSION=""
SKIP_HOOK=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --version)
      VERSION="$2"
      shift 2
      ;;
    --hook-type)
      HOOK_TYPE="$2"
      shift 2
      ;;
    --skip-hook)
      SKIP_HOOK=true
      shift
      ;;
    --talisman-home)
      TALISMAN_HOME="$2"
      shift 2
      ;;
    --hooks-dir)
      HOOKS_DIR="$2"
      shift 2
      ;;
    --help|-h)
      usage
      ;;
    *)
      echo "❌ Unknown argument: $1"
      usage
      ;;
  esac
done

if [[ -z "$VERSION" ]]; then
  echo "🔍 Fetching latest Talisman release..."
  VERSION=$(get_latest_release)
fi

download_and_install "$VERSION"

if [[ "$SKIP_HOOK" != true ]]; then
  setup_global_hook
fi
