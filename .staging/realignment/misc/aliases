#!/usr/bin/env bash
# aliases – Shell aliases for DevContainer UX

# ─── Environment and Path ─────────────────────────────────────────────
alias environment='printenv | sort'
alias path='echo "${PATH}" | tr ":" "\n" | sort'

# ─── Filesystem Navigation ────────────────────────────────────────────
alias ls='eza --icons --group-directories-first'
alias ll='eza --all --long --header --group --icons --git --group-directories-first'
alias la='eza --all --icons --group-directories-first'
alias lt='eza --tree --icons --git'
alias lss='eza -lh --total-size --icons --sort=size'
alias dux='du --human-readable --max-depth=1'
alias dud='dust -d 1'
alias dfx='df --human-readable --print-type'
alias mkdirp='mkdir --parents'
alias touchn='touch --no-create' # update timestamp, don't create

# ─── Files and Grep Helpers ──────────────────────────────────────────
alias grepv='grep --invert-match'
alias cpv='cp --verbose'
alias rmf='rm --recursive --force'

# ─── Process Monitoring ───────────────────────────────────────────────
alias psg='ps --no-headers --format=pid,ppid,cmd --sort=-pid'
alias topc='top --interactive --delay=1'
alias freeh='free --human'
alias historyt='history | tail --lines=50'

# ─── Networking ───────────────────────────────────────────────────────
alias ports='ss --listening --numeric --tcp --udp'
alias ipaddr='hostname -I | tr " " "\n"'

# ─── System Utilities ─────────────────────────────────────────────────
alias cls='clear'
alias reload='exec "${SHELL}" --login'

# ─── Safety ───────────────────────────────────────────────────────────
alias cp='cp --interactive --verbose'
alias mv='mv --interactive --verbose'
alias rm='rm --interactive'

# ─── Time ─────────────────────────────────────────────────
alias now='date --iso-8601=seconds'
alias uptime='uptime --pretty'
alias weekday='date +%A'
alias month='date +%B'
alias year='date +%Y'
alias timestamp='date -u +%s'

