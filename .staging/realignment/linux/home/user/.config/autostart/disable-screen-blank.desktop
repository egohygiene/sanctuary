[Desktop Entry]
Type=Application
Name=Disable Screen Blank
Exec=sh -c "gsettings set org.gnome.desktop.session idle-delay 0; gsettings set org.gnome.settings-daemon.plugins.power sleep-inactive-ac-timeout 0; gsettings set org.gnome.settings-daemon.plugins.power sleep-inactive-battery-timeout 0"
X-GNOME-Autostart-enabled=true
Comment=Prevents the screen from blanking
