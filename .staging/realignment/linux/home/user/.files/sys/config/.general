#!/bin/sh
##########################################
# General Environment Settings.          #
#                                        #
# Author: Alan Szmyt                     #
# Date: 09/11/2023                       # 
##########################################

# Set all locale settings to use en_US.UTF-8.
export LANG="en_US"
export LC_ALL="en_US.UTF-8"

# Avoid issues with `gpg` as installed via Homebrew.
# https://stackoverflow.com/a/42265848/96656
export GPG_TTY=$(tty);

export CLICOLOR=1

# Colorize GCC warnings and errors.
export GCC_COLORS='error=01;31:warning=01;35:note=01;36:caret=01;32:locus=01:quote=01'

# Set the max memory size for nodeJS in megabytes.
export NODE_OPTIONS="--max-old-space-size=4096 --report-directory=$USER_SYS_REPORTS/node"

# PEX runtime environment variables: https://pex.readthedocs.io/en/latest/api/vars.html
export PEX_VERBOSE=0

# ghcup
export GHCUP_USE_XDG_DIRS="true"

#########################################
# PYTHON SETTINGS.
# https://docs.python.org/3/using/cmdline.html#environment-variables
#########################################

# Make Python use UTF-8 encoding for output to stdin/stdout/stderr.
export PYTHONIOENCODING="UTF-8"

# Set python encoding to utf-8.
export PYTHONUTF8=1

# Install pre-release version of poetry.
export POETRY_PREVIEW=1

# Set pipenv to install virtual environments in the project directory.
export PIPENV_VENV_IN_PROJECT=1

