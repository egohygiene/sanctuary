#!/usr/bin/env bash
# run-lynis: Runs a Lynis security audit with optional configuration

set -euo pipefail

USE_COLOR=true
VERBOSE=false
DRY_RUN=false
PROFILE="/etc/lynis/default.prf"
LOG_DIR="/var/log"
LYNIS_BIN="lynis"

# ─────────────────────────────────────────────────────────────────────────────
# Logging + CLI
# ─────────────────────────────────────────────────────────────────────────────
print_help() {
    cat <<EOF
Usage: $(basename "$0") [options]

Run a Lynis security audit on the local system.

Options:
  --profile FILE    Path to custom Lynis profile (default: ${PROFILE})
  --log-dir DIR     Directory for log and report output (default: ${LOG_DIR})
  --dry-run         Show what would be done, but don't run the audit
  --verbose         Show verbose output
  --no-color        Disable colorized logs
  -h, --help        Show this help message
EOF
    exit 0
}

color() {
    [[ "${USE_COLOR}" == true ]] || return 0
    case "$1" in
    reset) echo -e "\033[0m" ;;
    cyan) echo -e "\033[36m" ;;
    green) echo -e "\033[32m" ;;
    yellow) echo -e "\033[33m" ;;
    red) echo -e "\033[31m" ;;
    *) echo "" ;;
    esac
}

log() {
    local type="$1"
    shift
    local prefix color_code output
    case "${type}" in
    info)
        prefix="👉"
        color_code=$(color cyan)
        ;;
    success)
        prefix="✅"
        color_code=$(color green)
        ;;
    warn)
        prefix="⚠️"
        color_code=$(color yellow)
        ;;
    error)
        prefix="❌"
        color_code=$(color red)
        ;;
    *)
        prefix=""
        color_code=$(color reset)
        ;;
    esac
    output="${color_code}${prefix} $*$(color reset)"
    if [[ "${type}" == "error" ]]; then
        printf "%s\n" "${output}" >&2
        exit 1
    else
        printf "%s\n" "${output}"
    fi
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
        --profile)
            shift
            PROFILE="$1"
            ;;
        --log-dir)
            shift
            LOG_DIR="$1"
            ;;
        --dry-run) DRY_RUN=true ;;
        --verbose) VERBOSE=true ;;
        --no-color) USE_COLOR=false ;;
        -h | --help) print_help ;;
        *) log error "Unknown argument: $1" ;;
        esac
        shift
    done
}

# ─────────────────────────────────────────────────────────────────────────────
# Core Logic
# ─────────────────────────────────────────────────────────────────────────────
check_requirements() {
    if ! command -v "${LYNIS_BIN}" &>/dev/null; then
        log error "lynis is not installed. Run install-lynis first."
    fi
}

run_audit() {
    local cmd_args=("${LYNIS_BIN}" audit system --no-colors --quick)

    if [[ -f "${PROFILE}" ]]; then
        cmd_args+=(--profile "${PROFILE}")
        log info "Using profile: ${PROFILE}"
    else
        log warn "Profile not found: ${PROFILE} — using Lynis defaults"
    fi

    if [[ "${VERBOSE}" == true ]]; then
        cmd_args+=(--verbose)
    fi

    log info "Starting Lynis security audit..."

    if [[ "${DRY_RUN}" == true ]]; then
        log info "Would run: ${cmd_args[*]}"
        return
    fi

    "${cmd_args[@]}"
    log success "Lynis audit complete. Report saved to ${LOG_DIR}/lynis-report.dat"
}

main() {
    parse_args "$@"
    check_requirements
    run_audit
}

main "$@"
