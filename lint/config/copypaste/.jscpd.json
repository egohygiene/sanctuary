{
    "threshold": 0,
    "reporters": ["html", "consoleFull", "json", "markdown"],
    "ignore": [
        "**/__snapshots__/**",
        "**/node_modules/**",
        "**/.history/**",
        "**/.cache/**",
        "**/reports/**",
        "**/logs/**",
        "**/coverage/**",
        "**/venv/**",
        "**/.venv/**",
        "**/.pnpm-store/**",
        "**/.idea/**",
        "**/.vscode/**",
        "**/.rbenv/**",
        "**/lint/prose/styles/**",
        "**/lint/python/.bandit.yml",
        "package-lock.json",
        "**/package-lock.json",
        "**/*.lock",
        "**/*.svg",
        "**/.git/**",
        "**/.github/**",
        "**/.gitlab/**",
        "**/.bitbucket/**",
        "**/.docker/**",
        "**/.circleci/**",
        "**/.travis/**"
    ],
    "absolute": true,
    "gitignore": true,
    "output": "reports/jscpd"
}
