# -----------------------------------------------------------------------------
# ESLint Ignore Configuration
# -----------------------------------------------------------------------------
#
# Purpose:
#   Exclude generated artifacts, dependencies, caches, and development-only
#   directories from ESLint analysis.
#
# NOTE:
#   Modern ESLint flat configs prefer using:
#
#       ignores: []
#
#   directly inside eslint.config.js/mjs/cjs.
#
#   This file is retained for compatibility with legacy tooling and workflows.
#
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------

node_modules/
.pnpm/
.yarn/

# -----------------------------------------------------------------------------
# Build Artifacts
# -----------------------------------------------------------------------------

dist/
build/
coverage/

# -----------------------------------------------------------------------------
# Cache Directories
# -----------------------------------------------------------------------------

.cache/
.nyc_output/
.vitest/

.eslintcache

# -----------------------------------------------------------------------------
# Minified Assets
# -----------------------------------------------------------------------------

*.min.js

# -----------------------------------------------------------------------------
# TypeScript Incremental State
# -----------------------------------------------------------------------------

*.tsbuildinfo

# -----------------------------------------------------------------------------
# Test Runner Artifacts
# -----------------------------------------------------------------------------

cypress/videos/
cypress/screenshots/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------

*.log

# -----------------------------------------------------------------------------
# Editor / IDE Files
# -----------------------------------------------------------------------------

.vscode/

*.swp
*.swo

# -----------------------------------------------------------------------------
# Git Hooks
# -----------------------------------------------------------------------------

.husky/

# -----------------------------------------------------------------------------
# Development Containers
# -----------------------------------------------------------------------------

.devcontainer/target/
