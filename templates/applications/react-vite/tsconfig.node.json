{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",

  "compilerOptions": {
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "dist-node",

    "types": ["node"],

    "paths": {
      "@egohygiene/plugins/*": ["src/plugins/*"],
      "@egohygiene/db/*": ["db/*"]
    }
  },

  "include": [
    "src/plugins",
    "db",
    "astro.config.ts",
    "vite.config.ts",
    "vitest.config.ts"
  ],

  "exclude": ["dist", "node_modules"]
}
