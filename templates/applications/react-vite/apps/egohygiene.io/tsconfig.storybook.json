{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Storybook renders application components in a browser environment
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    // React automatic JSX runtime
    "jsx": "react-jsx",

    // Application-local imports
    "paths": {
      "@/*": ["./src/*"]
    },

    // Vite asset, stylesheet, HMR, and import.meta declarations
    "types": ["vite/client"]
  },

  // Application stories and shared browser-side Storybook configuration
  "include": [
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "../../.storybook/manager.ts",
    "../../.storybook/preview.ts"
  ]
}

