{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "outDir": "dist",

    "composite": true,
    "noEmitOnError": true
  },

  "include": ["src"],

  "exclude": [
    "dist",
    "dist-node",
    "node_modules",
    "generated",
    "coverage",
    ".cache",
    "**/*.test.*"
  ]
}
