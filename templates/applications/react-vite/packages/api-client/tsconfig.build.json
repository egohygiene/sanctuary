{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // JavaScript plus standard Web APIs used by fetch-based clients
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    // Buildable project and declaration API
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "isolatedDeclarations": true,

    // TypeScript owns declarations; the package bundler owns JavaScript
    "noEmit": false,
    "emitDeclarationOnly": true,
    "noEmitOnError": true,

    // Package source and output boundaries
    "rootDir": "./src",
    "outDir": "./dist",

    // Local incremental-build metadata
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.build.tsbuildinfo"
  },

  // Public package implementation
  "include": ["src"],

  // Non-production source is handled by specialized configurations
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/__tests__"
  ]
}

