{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Buildable project and declaration API
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "isolatedDeclarations": true,

    // TypeScript owns declarations; the package builder owns runtime artifacts
    "noEmit": false,
    "emitDeclarationOnly": true,
    "noEmitOnError": true,

    // Handwritten package source and declaration output
    "rootDir": "./src",
    "outDir": "./dist",

    // Local incremental-build metadata
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.build.tsbuildinfo"
  },

  // Canonical token JSON and the public TypeScript API
  "include": ["src"],

  // Non-production source is handled by Vitest
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/__tests__"
  ]
}

