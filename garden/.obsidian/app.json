{
  "promptDelete": false,
  "defaultViewMode": "source",
  "livePreview": true,
  "legacyEditor": false,
  "foldHeading": true,
  "foldIndent": true,
  "showFrontmatter": true,
  "attachmentFolderPath": "assets/attachments",
  "newLinkFormat": "shortest",
  "useMarkdownLinks": false,
  "newFileFolderPath": "notes",
  "tabSize": 2,
  "spellcheck": true,
  "spellcheckLanguages": ["en-US"],
  "strictLineBreaks": false,
  "readableLineLength": true,
  "showLineNumber": false,
  "vimMode": false,
  "alwaysUpdateLinks": true,
  "userIgnoreFilters": ["assets/attachments", "assets/excalidraw"],
  "pdfExportSettings": {
    "pageSize": "letter",
    "landscape": false,
    "margin": "0",
    "downscalePercent": 100
  }
}
