{
  "folder": "assets/excalidraw",
  "embedType": "svg",
  "embedWikiLink": true,
  "drawingFilenamePrefix": "Drawing ",
  "drawingEmbedPrefixWithFilename": true,
  "drawingFilenameDateTime": "YYYY-MM-DD HH.mm.ss",
  "drawingFilenameEmbedPostfix": " ",
  "compatibilityMode": false,
  "onNewPane": false,
  "showSplashscreen": false,
  "autoexportSVG": true,
  "autoexportPNG": false,
  "autoexportKeepSVGname": true,
  "theme": "light",
  "matchTheme": true,
  "matchThemeAlways": false,
  "matchThemeTrigger": false,
  "defaultLineStyle": "sharpArrow",
  "defaultFillStyle": "hachure",
  "defaultStrokeSharpness": "round",
  "defaultStartArrowHead": "none",
  "defaultEndArrowHead": "arrow",
  "defaultOpacity": 100,
  "leftHandedMode": false,
  "iframelyAllowed": false
}
